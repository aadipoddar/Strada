<div class="cd-scope">
	<SfDialog @ref="_dialog" Width="400px" IsModal="true" ShowCloseIcon="true" @bind-Visible="_isVisible" CssClass="confirm-dialog">

		<MudBlazor.MudHotkey Key=JsKey.Enter OnHotkeyPressed="HandleConfirm" />
		<MudBlazor.MudHotkey Key=JsKey.Escape OnHotkeyPressed="HandleCancel" />

		<DialogTemplates>
			<Header>
				<div class="cd-header">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
						 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
						 style="color: #059669;">
						<polyline points="23 4 23 10 17 10"></polyline>
						<path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
					</svg>
					<span>Recover</span>
				</div>
			</Header>
			<Content>
				<div class="cd-body">
					<div class="cd-detail">
						<span class="cd-detail-label">Item:</span>
						<span class="cd-detail-value">@IdentifierValue</span>
					</div>
					<p class="cd-note cd-note-info">
						The item will be restored and made active again.
					</p>
					<div class="cd-actions">
						<button class="cd-btn cd-btn-cancel" @onclick="HandleCancel">Cancel</button>
						<button class="cd-btn cd-btn-success" @onclick="HandleConfirm">Recover</button>
					</div>
				</div>
			</Content>
		</DialogTemplates>
	</SfDialog>
</div>

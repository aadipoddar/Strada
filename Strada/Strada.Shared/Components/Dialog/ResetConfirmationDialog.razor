<div class="cd-scope">
	<SfDialog @ref="_dialog" Width="400px" IsModal="true" ShowCloseIcon="true" @bind-Visible="_isVisible" CssClass="confirm-dialog">

		<MudBlazor.MudHotkey Key=JsKey.Enter OnHotkeyPressed="HandleConfirm" />
		<MudBlazor.MudHotkey Key=JsKey.Escape OnHotkeyPressed="HandleCancel" />

		<DialogTemplates>
			<Header>
				<div class="cd-header">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
						 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
						 style="color: #ea580c;">
						<polyline points="1 4 1 10 7 10" />
						<path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
					</svg>
					<span>Reset</span>
				</div>
			</Header>
			<Content>
				<div class="cd-body">
					<div class="cd-detail">
						<span class="cd-detail-label">Action:</span>
						<span class="cd-detail-value">Are you sure you want to reset?</span>
					</div>
					<p class="cd-note cd-note-warn">
						This action cannot be undone.
					</p>
					<div class="cd-actions">
						<button class="cd-btn cd-btn-cancel" @onclick="HandleCancel">Cancel</button>
						<button class="cd-btn cd-btn-warn" @onclick="HandleConfirm">Reset</button>
					</div>
				</div>
			</Content>
		</DialogTemplates>
	</SfDialog>
</div>

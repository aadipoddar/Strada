@using Strada.Models.Fleet.OMC
@using Strada.Models.Fleet.Trip
@using Strada.Models.Fleet.Vehicle
@using Strada.Models.Fleet.VehicleDocument

<!-- KPI -->
<div class="launchpad-section">
	<h2 class="launchpad-section-title">Key Figures</h2>
	<div class="dashboard-grid">

		<FioriTile Title="Unbilled Trips" Subtitle="Trips not yet added to a bill" KPI="@_unbilledTripsCount.ToString()" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.Bill)">
			<IconContent>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="1" y="3" width="15" height="13" />
					<polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
					<circle cx="5.5" cy="18.5" r="2.5" />
					<circle cx="18.5" cy="18.5" r="2.5" />
				</svg>
			</IconContent>
		</FioriTile>

		<FioriTile Title="Trips This Month" Subtitle="@_thisMonthTripsTrend" KPI="@_thisMonthTripsCount.ToString()" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TripReport)">
			<IconContent>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="1" y="3" width="15" height="13" />
					<polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
					<circle cx="5.5" cy="18.5" r="2.5" />
					<circle cx="18.5" cy="18.5" r="2.5" />
				</svg>
			</IconContent>
		</FioriTile>

		<FioriTile Title="Revenue This Month" Subtitle="@_thisMonthRevenueTrend" KPI="@_thisMonthRevenue" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TripReport)">
			<IconContent>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
					<polyline points="17 6 23 6 23 12" />
				</svg>
			</IconContent>
		</FioriTile>

		<FioriTile Title="Expense This Month" Subtitle="@_thisMonthExpenseTrend" KPI="@_thisMonthExpense" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TripExpensesReport)">
			<IconContent>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="23 18 13.5 8.5 8.5 13.5 1 6" />
					<polyline points="17 18 23 18 23 12" />
				</svg>
			</IconContent>
		</FioriTile>

		<FioriTile Title="Profit / Loss This Month" Subtitle="@_thisMonthProfitTrend" KPI="@_thisMonthProfit" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleRegisterReport)">
			<IconContent>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="12" y1="20" x2="12" y2="10" />
					<line x1="18" y1="20" x2="18" y2="4" />
					<line x1="6" y1="20" x2="6" y2="16" />
				</svg>
			</IconContent>
		</FioriTile>

		<FioriTile Title="Active Vehicles" Subtitle="@_activeVehiclesNote" KPI="@_activeVehiclesCount.ToString()" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleMaster)">
			<IconContent>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M10 17h4V5H2v12h3" />
					<path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h1" />
					<circle cx="7.5" cy="17.5" r="2.5" />
					<circle cx="17.5" cy="17.5" r="2.5" />
				</svg>
			</IconContent>
		</FioriTile>

		<FioriTile Title="Documents Due Soon" Subtitle="@_dueDocumentsNote" KPI="@_dueDocumentsCount.ToString()" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDocumentRenewalReport)">
			<IconContent>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
					<line x1="16" y1="2" x2="16" y2="6" />
					<line x1="8" y1="2" x2="8" y2="6" />
					<line x1="3" y1="10" x2="21" y2="10" />
					<path d="M8 14l3 3 5-5" />
				</svg>
			</IconContent>
		</FioriTile>

	</div>
</div>

<DashboardChart />

<!-- Attention -->
<div class="launchpad-section attention-row">

	<div class="attention-col">
		<h2 class="launchpad-section-title">Document Renewal</h2>
		<div class="section-card">
			<div class="section-body grid-body">
				<SfGrid @ref="_sfGrid" TValue="VehicleDocumentRenewalOverviewModel" DataSource="_dueDocuments"
						AllowTextWrap="true" AllowSorting="true" AllowResizing="true" AllowPaging="true"
						GridLines="GridLine.Horizontal" CssClass="professional-grid"
						ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "Search" })">

					<GridEvents TValue="VehicleDocumentRenewalOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="5" PageSizes="@(new string[] { "5", "10", "20", "50", "100", "All" })" />

					<GridColumns>
						<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="140" />
						<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.VehicleDocumentTypeName)" HeaderText="Document Type" Width="180" />

						<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.RenewalDate)" HeaderText="Renewal Date" Width="140" Format="dd/MM/yy" Type="ColumnType.DateTime">
							<Template>
								@{
									var item = (context as VehicleDocumentRenewalOverviewModel);
									<span class="@(item.DaysRemaining < _warningDays ? "grid-debit" : string.Empty)">@item.RenewalDate.ToString("dd/MM/yy")</span>
								}
							</Template>
						</GridColumn>
						<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.DaysRemaining)" HeaderText="Days Remaining" Width="140" TextAlign="TextAlign.Right">
							<Template>
								@{
									var item = (context as VehicleDocumentRenewalOverviewModel);
									<span class="@(item.DaysRemaining < _warningDays ? "grid-debit" : string.Empty)">@item.DaysRemaining</span>
								}
							</Template>
						</GridColumn>
					</GridColumns>
				</SfGrid>
			</div>
		</div>
	</div>

	<div class="attention-col">
		<h2 class="launchpad-section-title">Loss-Making Trips</h2>
		<div class="section-card">
			<div class="section-body grid-body">
				<SfGrid @ref="_lossGrid" TValue="TripOverviewModel" DataSource="_lossTrips"
						AllowTextWrap="true" AllowSorting="true" AllowResizing="true" AllowPaging="true"
						GridLines="GridLine.Horizontal" CssClass="professional-grid"
						ContextMenuItems="@_lossContextMenuItems"
						Toolbar="@(new List<string>() { "Search" })">

					<GridEvents TValue="TripOverviewModel" ContextMenuItemClicked="OnLossContextMenuItemClicked" />
					<GridPageSettings PageSize="5" PageSizes="@(new string[] { "5", "10", "20", "50", "100", "All" })" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridAggregateColumn Field="@nameof(TripOverviewModel.NetAmount)" Type="AggregateType.Sum" Format="N2">
									<FooterTemplate>
										@{
											var aggregate = (context as AggregateTemplateContext);
											<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
										}
									</FooterTemplate>
								</GridAggregateColumn>
								<GridAggregateColumn Field="@nameof(TripOverviewModel.TotalExpense)" Type="AggregateType.Sum" Format="N2">
									<FooterTemplate>
										@{
											var aggregate = (context as AggregateTemplateContext);
											<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
										}
									</FooterTemplate>
								</GridAggregateColumn>
								<GridAggregateColumn Field="@nameof(TripOverviewModel.ProfitLoss)" Type="AggregateType.Sum" Format="N2">
									<FooterTemplate>
										@{
											var aggregate = (context as AggregateTemplateContext);
											<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
										}
									</FooterTemplate>
								</GridAggregateColumn>
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<GridColumn Field="@nameof(TripOverviewModel.TransactionDateTime)" HeaderText="Trip Date" Width="130" Format="dd/MM/yy" Type="ColumnType.DateTime" />
						<GridColumn Field="@nameof(TripOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="140" />
						<GridColumn Field="@nameof(TripOverviewModel.RouteDisplay)" HeaderText="Route" Width="200" />
						<GridColumn Field="@nameof(TripOverviewModel.NetAmount)" HeaderText="Net Amount" Width="140" TextAlign="TextAlign.Right" Format="N2" />
						<GridColumn Field="@nameof(TripOverviewModel.TotalExpense)" HeaderText="Total Expense" Width="140" TextAlign="TextAlign.Right" Format="N2" />
						<GridColumn Field="@nameof(TripOverviewModel.ProfitLoss)" HeaderText="Profit / Loss" Width="140" TextAlign="TextAlign.Right">
							<Template>
								@{
									var item = (context as TripOverviewModel);
									<span class="grid-debit">@(item.ProfitLoss?.ToString("N2") ?? "-")</span>
								}
							</Template>
						</GridColumn>
					</GridColumns>
				</SfGrid>
			</div>
		</div>
	</div>

</div>

<div class="launchpad-section attention-row">

	<div class="attention-col">
		<h2 class="launchpad-section-title">Pending Trips</h2>
		<div class="section-card">
			<div class="section-body grid-body">
				<SfGrid @ref="_tripsGrid" TValue="TripOverviewModel" DataSource="_unBilledTrips"
						AllowTextWrap="true" AllowSorting="true" AllowResizing="true" AllowPaging="true"
						GridLines="GridLine.Horizontal" CssClass="professional-grid"
						ContextMenuItems="@_tripContextMenuItems"
						Toolbar="@(new List<string>() { "Search" })">

					<GridEvents TValue="TripOverviewModel" ContextMenuItemClicked="OnTripsContextMenuItemClicked" />
					<GridPageSettings PageSize="5" PageSizes="@(new string[] { "5", "10", "20", "50", "100", "All" })" />

					<GridColumns>
						<GridColumn Field="@nameof(TripOverviewModel.TransactionDateTime)" HeaderText="Trip Date" Width="130" Format="dd/MM/yy" Type="ColumnType.DateTime" />
						<GridColumn Field="@nameof(TripOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="140" />
						<GridColumn Field="@nameof(TripOverviewModel.RouteDisplay)" HeaderText="Route" Width="200" />
						<GridColumn Field="@nameof(TripOverviewModel.PendingDays)" HeaderText="Pending Days" Width="140" TextAlign="TextAlign.Right" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>
	</div>

	<div class="attention-col">
		<h2 class="launchpad-section-title">Idle Vehicles</h2>
		<div class="section-card">
			<div class="section-body grid-body">
				<SfGrid @ref="_idleGrid" TValue="VehicleModel" DataSource="_idleVehicles"
						AllowTextWrap="true" AllowSorting="true" AllowResizing="true" AllowPaging="true"
						GridLines="GridLine.Horizontal" CssClass="professional-grid"
						ContextMenuItems="@_idleContextMenuItems"
						Toolbar="@(new List<string>() { "Search" })">

					<GridEvents TValue="VehicleModel" ContextMenuItemClicked="OnIdleContextMenuItemClicked" />
					<GridPageSettings PageSize="5" PageSizes="@(new string[] { "5", "10", "20", "50", "100", "All" })" />

					<GridColumns>
						<GridColumn Field="@nameof(VehicleModel.Code)" HeaderText="Vehicle" Width="160" />
						<GridColumn Field="@nameof(VehicleModel.CompanyId)" HeaderText="Company" Width="220">
							<Template>
								@{
									var item = (context as VehicleModel);
									var company = _companies.FirstOrDefault(c => c.Id == item.CompanyId);
									<span>@(company is not null ? company.Name : "N/A")</span>
								}
							</Template>
						</GridColumn>
						<GridColumn Field="@nameof(VehicleModel.OMCId)" HeaderText="OMC" Width="220">
							<Template>
								@{
									var item = (context as VehicleModel);
									var omc = _omcs.FirstOrDefault(o => o.Id == item.OMCId);
									<span>@(omc is not null ? omc.Name : "N/A")</span>
								}
							</Template>
						</GridColumn>
					</GridColumns>
				</SfGrid>
			</div>
		</div>
	</div>

</div>

<div class="launchpad-section attention-row">

	<div class="attention-col">
		<h2 class="launchpad-section-title">OMC Card Balances</h2>
		<div class="section-card">
			<div class="section-body grid-body">
				<SfGrid @ref="_cardGrid" TValue="OMCCardModel" DataSource="_omcCards"
						AllowTextWrap="true" AllowSorting="true" AllowResizing="true" AllowPaging="true"
						GridLines="GridLine.Horizontal" CssClass="professional-grid"
						Toolbar="@(new List<string>() { "Search" })">

					<GridPageSettings PageSize="5" PageSizes="@(new string[] { "5", "10", "20", "50", "100", "All" })" />

					<GridColumns>
						<GridColumn Field="@nameof(OMCCardModel.Code)" HeaderText="Card" Width="140" />
						<GridColumn Field="@nameof(OMCCardModel.CardNumber)" HeaderText="Card Number" Width="200" />
						<GridColumn Field="@nameof(OMCCardModel.OMCId)" HeaderText="OMC" Width="180">
							<Template>
								@{
									var item = (context as OMCCardModel);
									var omc = _omcs.FirstOrDefault(o => o.Id == item.OMCId);
									<span>@(omc is not null ? omc.Name : "N/A")</span>
								}
							</Template>
						</GridColumn>
						<GridColumn Field="@nameof(OMCCardModel.CurrentBalance)" HeaderText="Current Balance" Width="160" TextAlign="TextAlign.Right" Format="N2" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>
	</div>

</div>
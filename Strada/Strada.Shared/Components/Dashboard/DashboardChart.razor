<div class="launchpad-section">

	<!-- Row 1: Revenue (line) + Expense (bar) trend -->
	<div class="chart-row">

		<div class="chart-card">
			<div class="chart-card-title">
				<span class="chart-dot dot-revenue"></span>
				<span>Revenue</span>
			</div>
			@if (_revenueSeries.Count == 0)
			{
				<div class="chart-empty">Loading…</div>
			}
			else
			{
				<MudBlazor.MudChart ChartType="MudBlazor.ChartType.Line"
									ChartSeries="@_revenueSeries"
									ChartLabels="@_labels"
									Width="100%"
									Height="100%"
									ChartOptions="@_revenueOptions" />
			}
		</div>

		<div class="chart-card">
			<div class="chart-card-title">
				<span class="chart-dot dot-expense"></span>
				<span>Expense</span>
			</div>
			@if (_expenseSeries.Count == 0)
			{
				<div class="chart-empty">Loading…</div>
			}
			else
			{
				<MudBlazor.MudChart ChartType="MudBlazor.ChartType.Bar"
									ChartSeries="@_expenseSeries"
									ChartLabels="@_labels"
									Width="100%"
									Height="100%"
									ChartOptions="@_expenseOptions" />
			}
		</div>

	</div>

	<!-- Row 2: Top 10 Vehicles by Profit + Expense Breakdown by Type -->
	<div class="chart-row">

		<div class="chart-card">
			<div class="chart-card-title">
				<span class="chart-dot dot-profit"></span>
				<span>Top Vehicles by Profit</span>
			</div>
			@if (_vehicleProfitSeries.Count == 0)
			{
				<div class="chart-empty">Loading…</div>
			}
			else
			{
				<MudBlazor.MudChart ChartType="MudBlazor.ChartType.Bar"
									ChartSeries="@_vehicleProfitSeries"
									ChartLabels="@_vehicleLabels"
									Width="100%"
									Height="100%"
									MatchBoundsToSize="true"
									ChartOptions="@_vehicleProfitOptions" />
			}
		</div>

		<div class="chart-card">
			<div class="chart-card-title">
				<span class="chart-dot dot-mix"></span>
				<span>Expense Breakdown by Type</span>
			</div>
			@if (_expenseTypeSeries.Count == 0)
			{
				<div class="chart-empty">Loading…</div>
			}
			else
			{
				<MudBlazor.MudChart ChartType="MudBlazor.ChartType.Pie"
									ChartSeries="@_expenseTypeSeries"
									ChartLabels="@_expenseTypeLabels"
									Width="100%"
									Height="380px"
									ChartOptions="@_expenseTypeOptions" />
			}
		</div>

	</div>

</div>

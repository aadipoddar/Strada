@if (Visible)
{
    <div class="animated-loader-overlay">
        <div class="animated-loader-container">
            <img src="_content/Strada.Shared/images/loading.gif" alt="Loading" class="animated-loader-gif" />
            <p class="animated-loader-text">Checking the Tire Pressure on the Servers.</p>
        </div>
    </div>
}

<style>
    .animated-loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: fadeIn 0.3s ease;
    }

    .animated-loader-container {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .animated-loader-gif {
        width: 300px;
        height: 300px;
        object-fit: contain;
    }

    .animated-loader-text {
        margin-top: 8px;
        color: #000;
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 0.2px;
        text-align: center;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    /* Responsive */
    @@media (max-width: 576px) {
        .animated-loader-gif {
            width: 200px;
            height: 200px;
        }

        .animated-loader-text {
            font-size: 15px;
            padding: 0 12px;
        }
    }
</style>

@code {
    [Parameter]
    public bool Visible { get; set; }
}

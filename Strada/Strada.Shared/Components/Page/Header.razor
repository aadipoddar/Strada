<MudBlazor.MudHotkey Key=JsKey.KeyD KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateToHome" />
<MudBlazor.MudHotkey Key=JsKey.KeyL KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="Logout" />
<MudBlazor.MudHotkey Key=JsKey.F2 OnHotkeyPressed="FocusSearchBox" />

<div class="page-header">
	<div class="header-left">
		<button type="button" class="header-logo-button" title="Go to Home (Ctrl+D)" @onclick="NavigateToHome">
			<img src="images/logo.png" alt="Strada" class="header-logo" />
		</button>
		@if (LeftContent != null)
		{
			@LeftContent
		}
	</div>
	<div class="header-center">
		<h1 class="page-title">@Title</h1>
	</div>
	<div class="header-right">
		<div class="global-search-container">
			<div class="global-search-input">
				<CustomAutoComplete @ref="_globalSearch" T="GlobalSearchItem"
									Value="_selectedSearchItem"
									ValueChanged="OnRouteSelected"
									SearchFunction="HeaderSearch"
									FieldValue="@nameof(GlobalSearchItem.DisplayText)"
									Placeholder="Search Route, Code, Trans (F2)"
									Required="false" />
			</div>
			<IconButton Icon="IconType.View" Variant="ButtonVariant.View" Title="View" OnClick="NavigateToSearch" />
			<IconButton Icon="IconType.Pdf" Variant="ButtonVariant.Pdf" Title="Print PDF" OnClick="DownloadPdfFromSearch" />

			<div class="header-divider"></div>
			@if (RightContent != null)
			{
				@RightContent
			}
			<button type="button" class="user-badge" title="Logout (Ctrl+L)" @onclick="Logout">
				<span class="user-name-text">@_user?.Name</span>
				<span class="logout-power-button">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18.36 6.64a9 9 0 1 1-12.73 0" />
						<line x1="12" y1="2" x2="12" y2="12" />
					</svg>
				</span>
			</button>
		</div>
	</div>
</div>

<style>
	/* Professional Header Section */
	.page-header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: #ffffff;
		border-bottom: 1px solid #e2e8f0;
		padding: 10px 24px;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 16px;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
		min-height: 52px;
	}

	.header-left {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.header-logo {
		width: 32px;
		height: 32px;
		flex-shrink: 0;
	}

	.header-logo-button {
		border: none;
		background: transparent;
		padding: 0;
		display: flex;
		align-items: center;
		cursor: pointer;
	}

	.header-divider {
		width: 1px;
		height: 24px;
		background: #e2e8f0;
		flex-shrink: 0;
	}

	.header-center {
		text-align: center;
	}

	.page-title {
		font-size: 17px;
		font-weight: 600;
		color: #0f172a;
		margin: 0;
		letter-spacing: -0.2px;
	}

	.header-right {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 6px;
	}

	/* User badge — the whole pill is the logout button */
	.user-badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 3px 4px 3px 12px;
		background: #f8fafc;
		border: 1px solid #e2e8f0;
		border-radius: 999px;
		cursor: pointer;
		font-family: inherit;
		transition: all 0.15s ease;
	}

		.user-badge:hover {
			background: #fef2f2;
			border-color: #fecaca;
		}

		.user-badge:active {
			transform: scale(0.98);
		}

	.user-name-text {
		font-size: 13px;
		font-weight: 500;
		color: #0f172a;
		line-height: 1;
	}

	/* Power glyph inside the badge */
	.logout-power-button {
		width: 26px;
		height: 26px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		border-radius: 50%;
		background: #ffffff;
		color: #64748b;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
		transition: all 0.15s ease;
	}

		.logout-power-button svg {
			width: 15px;
			height: 15px;
		}

	.user-badge:hover .logout-power-button {
		color: #ef4444;
	}

	.global-search-container {
		display: flex;
		align-items: center;
		gap: 6px;
		margin-left: 12px;
		background-color: #f1f5f9;
		padding: 4px 8px;
		border-radius: 8px;
	}

	.global-search-input {
		width: 250px;
	}

	/* Keep the MudBlazor AutoComplete compact so it fits the header height */
	::deep .global-search-input .mud-input-control {
		margin: 0;
	}

	::deep .global-search-input .mud-input-control-helper-container {
		display: none;
	}

	::deep .global-search-input .mud-input.mud-input-outlined {
		background: #ffffff;
	}

		::deep .global-search-input .mud-input.mud-input-outlined input {
			font-size: 13px;
			padding-top: 6px;
			padding-bottom: 6px;
		}

	@@media (max-width: 768px) {

		.header-divider,
		.global-search-container {
			display: none;
		}

		.user-name-text {
			display: none;
		}

		.user-badge {
			padding: 3px;
		}
	}
</style>

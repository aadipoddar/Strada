@using Microsoft.AspNetCore.Components

<SfButton CssClass="@CssClasses" OnClick="OnClick" Disabled="@Disabled">
    <div class="card-content">
        <div class="card-icon-wrapper">
            @IconContent
        </div>
        <h3 class="card-title">@Title</h3>
        <p class="@DescriptionCssClass">@Description</p>
    </div>
</SfButton>

<style>
    /* Dashboard Card Component Styles */

    /* Dashboard Card Base */
    .dashboard-card {
        background: linear-gradient(to bottom, #ffffff 0%, #f8fafc 100%) !important;
        border: 2px solid #e2e8f0 !important;
        border-radius: 10px !important;
        padding: 16px !important;
        cursor: pointer !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        position: relative !important;
        overflow: visible !important;
        height: auto !important;
        min-height: 120px !important;
        text-align: left !important;
        width: 240px !important;
        min-width: 240px !important;
        max-width: 240px !important;
        flex-shrink: 0 !important;
    }

    .dashboard-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
        transform: scaleX(0);
        transition: transform 0.3s ease;
        border-radius: 12px 12px 0 0;
    }

    .dashboard-card:hover {
        transform: translateY(-4px) !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
        border-color: #3b82f6 !important;
        background: #f8fafc !important;
    }

    .dashboard-card:hover::before {
        transform: scaleX(1);
    }

    .dashboard-card:active {
        transform: translateY(-2px) !important;
        box-shadow: 0 8px 16px rgba(59, 130, 246, 0.2) !important;
    }

    .dashboard-card:focus {
        outline: 2px solid #3b82f6 !important;
        outline-offset: 2px !important;
    }

    /* Card Content Structure */
    .card-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        height: 100%;
        white-space: normal;
    }

    .card-icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        transition: all 0.3s ease;
    }

    .dashboard-card:hover .card-icon-wrapper {
        transform: scale(1.1) rotate(5deg);
    }

    .card-icon-wrapper svg {
        width: 28px;
        height: 28px;
    }

    .card-title {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
        margin: 0 0 6px 0;
        letter-spacing: -0.3px;
        white-space: normal !important;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .card-description {
        font-size: 11px;
        color: #64748b;
        margin: 0;
        line-height: 1.3;
        white-space: normal !important;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .card-description-preline {
        white-space: pre-line;
    }

    .card-running {
        background: linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%) !important;
        border-color: #fda4af !important;
    }

    .card-running::before {
        background: linear-gradient(90deg, #fb7185 0%, #f43f5e 100%);
        transform: scaleX(1);
    }

    .card-running .card-title {
        color: #9f1239;
    }

    .card-running .card-description {
        color: #be123c;
    }

    .card-running .card-icon-wrapper {
        background: linear-gradient(135deg, #ffe4e6 0%, #fecdd3 100%);
        color: #e11d48;
    }

    .card-running:hover {
        border-color: #fb7185 !important;
        box-shadow: 0 12px 24px rgba(244, 63, 94, 0.2) !important;
        background: linear-gradient(135deg, #ffe4e6 0%, #fecdd3 100%) !important;
    }

    .card-available {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%) !important;
        border-color: #86efac !important;
    }

    .card-available::before {
        background: linear-gradient(90deg, #4ade80 0%, #22c55e 100%);
        transform: scaleX(1);
    }

    .card-available .card-title {
        color: #166534;
    }

    .card-available .card-description {
        color: #15803d;
    }

    .card-available .card-icon-wrapper {
        background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
        color: #16a34a;
    }

    .card-available:hover {
        border-color: #4ade80 !important;
        box-shadow: 0 12px 24px rgba(34, 197, 94, 0.18) !important;
        background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%) !important;
    }

    /* Color Variations */

    /* Blue */
    .card-blue::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-blue .card-icon-wrapper {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        color: #2563eb;
    }

    .card-blue:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
    }

    /* Green */
    .card-green::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-green .card-icon-wrapper {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);

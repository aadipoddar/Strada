    }

    /* Indigo */
    .card-indigo::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-indigo .card-icon-wrapper {
        background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);

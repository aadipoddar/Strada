    }

    /* Amber */
    .card-amber::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-amber .card-icon-wrapper {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        color: #d97706;
    }

    .card-amber:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
    }

    /* Emerald */
    .card-emerald::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-emerald .card-icon-wrapper {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #10b981;
    }

    .card-emerald:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
    }

    /* Cyan */
    .card-cyan::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-cyan .card-icon-wrapper {
        background: linear-gradient(135deg, #cffafe 0%, #a5f3fc 100%);
        color: #0891b2;
    }

    .card-cyan:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
    }

    /* Rose */
    .card-rose::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-rose .card-icon-wrapper {
        background: linear-gradient(135deg, #ffe4e6 0%, #fecdd3 100%);
        color: #e11d48;
    }

    .card-rose:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
    }

    /* Sky */
    .card-sky::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-sky .card-icon-wrapper {
        background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
        color: #0284c7;
    }

    .card-sky:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
    }

    /* Violet */
    .card-violet::before {
        background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    }

    .card-violet .card-icon-wrapper {
        background: linear-gradient(135deg, #ddd6fe 0%, #c4b5fd 100%);
        color: #7c3aed;
    }

    .card-violet:hover {
        border-color: #3b82f6 !important;
        box-shadow: 0 12px 24px rgba(59, 130, 246, 0.15) !important;
    }

    @@media (max-width: 600px) {
        .dashboard-card {
            width: calc(50% - 8px) !important;
            min-width: calc(50% - 8px) !important;
            max-width: calc(50% - 8px) !important;
            min-height: 96px !important;
            padding: 10px !important;
        }

        .card-icon-wrapper {
            width: 36px;
            height: 36px;
            margin-bottom: 8px;
        }

        .card-icon-wrapper svg {
            width: 20px;
            height: 20px;
        }

        .card-title {
            font-size: 12px;
            margin: 0 0 4px 0;
        }

        .card-description {
            font-size: 10px;
            line-height: 1.2;
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
        }
    }
</style>

@code {
    private string DescriptionCssClass => PreserveDescriptionLineBreaks ? "card-description card-description-preline" :
"card-description";
}

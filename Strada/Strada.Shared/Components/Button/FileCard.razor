@using Microsoft.AspNetCore.Components

<SfButton CssClass="file-card" OnClick="OnClick">
    <div class="file-wrapper">
        <div class="file-body">
            <div class="file-accent"></div>
            <div class="file-corner">
                <div class="file-corner-inner"></div>
            </div>
            <div class="file-content">
                <div class="file-header">
                    @if (IconContent != null)
                    {
                        <div class="file-icon">
                            @IconContent
                        </div>
                    }
                    <p class="file-title">@Title</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <p class="file-desc">@Description</p>
                }
            </div>
            <div class="file-footer">
                <div class="file-lines">
                    <div class="f-line"></div>
                    <div class="f-line short"></div>
                </div>
                <div class="file-action">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </div>
            </div>
            <div class="file-shine"></div>
        </div>
    </div>
</SfButton>

<style>
    .file-card {
        background: transparent !important;
        border: none !important;
        padding: 0 !important;
        cursor: pointer !important;
        display: inline-block !important;
        width: 200px !important;
        height: 170px !important;
        flex-shrink: 0 !important;
        text-align: left !important;
        box-shadow: none !important;
        outline: none !important;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    }

        .file-card:hover {
            transform: translateY(-6px) !important;
        }

        .file-card:active {
            transform: translateY(-2px) scale(0.98) !important;
            transition: transform 0.1s ease !important;
        }

    .file-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .file-body {
        position: relative;
        width: 170px;
        height: 145px;
        background: #FFFFFF;
        border: 1px solid #E5E9F0;
        border-radius: 10px;
        box-shadow:
            0 1px 2px rgba(15, 23, 42, 0.04),
            0 2px 6px rgba(15, 23, 42, 0.05);
        display: flex;
        flex-direction: column;
        padding: 12px 12px 10px 12px;
        transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
        overflow: hidden;
    }

    .file-card:hover .file-body {
        box-shadow:
            0 4px 8px rgba(15, 23, 42, 0.06),
            0 12px 28px rgba(59, 130, 246, 0.12);
        border-color: #DBEAFE;
    }

    /* Accent bar at top */
    .file-accent {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--primary-blue, #3B82F6) 0%, #60A5FA 100%);
        border-radius: 10px 10px 0 0;
        opacity: 0.9;
        transition: height 0.3s ease, opacity 0.3s ease;
    }

    .file-card:hover .file-accent {
        height: 4px;
        opacity: 1;
    }

    /* Folded corner - more refined */
    .file-corner {
        position: absolute;
        top: 0;
        right: 0;
        width: 0;
        height: 0;
        border-style: solid;
        border-width: 0 18px 18px 0;
        border-color: transparent #F1F5F9 transparent transparent;
        z-index: 2;
        transition: border-width 0.3s ease;
    }

    .file-corner-inner {
        position: absolute;
        top: 0;
        right: -18px;
        width: 18px;
        height: 18px;
        background: linear-gradient(225deg, rgba(0, 0, 0, 0.06) 0%, transparent 60%);
        border-bottom-left-radius: 4px;
    }

    .file-card:hover .file-corner {
        border-width: 0 22px 22px 0;
    }

    .file-card:hover .file-corner-inner {
        right: -22px;
        width: 22px;
        height: 22px;
    }

    /* Subtle shine overlay on hover */
    .file-shine {
        position: absolute;
        top: 0;
        left: -75%;
        width: 50%;
        height: 100%;
        background: linear-gradient(115deg,
            transparent 0%,
            rgba(255, 255, 255, 0) 40%,
            rgba(255, 255, 255, 0.4) 50%,
            rgba(255, 255, 255, 0) 60%,
            transparent 100%);
        transform: skewX(-20deg);
        transition: left 0.6s ease;
        pointer-events: none;
    }

    .file-card:hover .file-shine {
        left: 125%;
    }

    .file-content {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        margin-top: 2px;
    }

    .file-header {
        display: flex;
        align-items: center;
        gap: 9px;
    }

    .file-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
        border: 1px solid #DBEAFE;
        border-radius: 8px;
        color: var(--primary-blue, #3B82F6);
        flex-shrink: 0;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.3s ease;
    }

        .file-icon svg {
            width: 17px;
            height: 17px;
        }

    .file-card:hover .file-icon {
        transform: scale(1.08) rotate(-3deg);
        background: linear-gradient(135deg, var(--primary-blue, #3B82F6) 0%, #60A5FA 100%);
        color: #FFFFFF;
        border-color: transparent;
    }

    .file-title {
        font-size: 13px;
        font-weight: 600;
        color: #0F172A;
        margin: 0;
        line-height: 1.35;
        white-space: normal;
        overflow-wrap: break-word;
        word-break: break-word;
        letter-spacing: -0.2px;
        flex: 1;
    }

    .file-desc {
        font-size: 10.5px;
        color: #64748B;
        margin: 0;
        line-height: 1.45;
        white-space: normal;
        overflow-wrap: break-word;
        word-break: break-word;
        font-weight: 450;
    }

    .file-footer {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 6px;
        gap: 8px;
    }

    .file-lines {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .f-line {
        height: 2px;
        background: #F1F5F9;
        border-radius: 2px;
        width: 100%;
        transition: background 0.3s ease;
    }

        .f-line.short {
            width: 55%;
        }

    .file-card:hover .f-line {
        background: #E0E7FF;
    }

    .file-action {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #F1F5F9;
        color: #94A3B8;
        opacity: 0;
        transform: translateX(-4px);
        transition: opacity 0.25s ease, transform 0.25s ease, background 0.25s ease, color 0.25s ease;
    }

        .file-action svg {
            width: 12px;
            height: 12px;
        }

    .file-card:hover .file-action {
        opacity: 1;
        transform: translateX(0);
        background: var(--primary-blue, #3B82F6);
        color: #FFFFFF;
    }

    @@media (max-width: 600px) {
        .file-card {
            width: 175px !important;
            height: 155px !important;
        }

        .file-body {
            width: 150px;
            height: 132px;
            padding: 10px 10px 8px 10px;
        }

        .file-title {
            font-size: 12px;
        }

        .file-desc {
            font-size: 9.5px;
        }

        .file-icon {
            width: 28px;
            height: 28px;
        }

            .file-icon svg {
                width: 15px;
                height: 15px;
            }
    }
</style>

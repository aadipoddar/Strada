@using Microsoft.AspNetCore.Components

<SfButton CssClass="file-card" OnClick="OnClick">
    <div class="file-wrapper">
        <div class="file-body">
            <div class="file-corner"></div>
            <div class="file-content">
                <div class="file-header">
                    @if (IconContent != null)
                    {
                        <div class="file-icon">
                            @IconContent
                        </div>
                    }
                    <p class="file-title">@Title</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <p class="file-desc">@Description</p>
                }
            </div>
            <div class="file-lines">
                <div class="f-line"></div>
                <div class="f-line short"></div>
            </div>
        </div>
    </div>
</SfButton>

<style>
    .file-card {
        background: transparent !important;
        border: none !important;
        padding: 0 !important;
        cursor: pointer !important;
        display: inline-block !important;
        width: 200px !important;
        height: 170px !important;
        flex-shrink: 0 !important;
        text-align: left !important;
        box-shadow: none !important;
        outline: none !important;
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

        .file-card:hover {
            transform: translateY(-5px) !important;
        }

        .file-card:active {
            transform: translateY(-2px) scale(0.98) !important;
        }

    .file-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .file-body {
        position: relative;
        width: 170px;
        height: 140px;
        background: #FFFFFF;
        border: 1.5px solid #E2E8F0;
        border-radius: 4px 12px 4px 4px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07), 0 1px 2px rgba(0, 0, 0, 0.04);
        display: flex;
        flex-direction: column;
        padding: 14px 14px 10px 14px;
        transition: box-shadow 0.25s ease, border-color 0.25s ease;
        overflow: hidden;
    }

    .file-card:hover .file-body {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1), 0 2px 6px rgba(0, 0, 0, 0.06);
        border-color: #CBD5E1;
    }

    /* Folded corner */
    .file-corner {
        position: absolute;
        top: 0;
        right: 0;
        width: 22px;
        height: 22px;
        background: linear-gradient(225deg, #F1F5F9 50%, #E2E8F0 50%);
        border-bottom-left-radius: 6px;
        border-top-right-radius: 12px;
        box-shadow: -1px 1px 3px rgba(0, 0, 0, 0.08);
        transition: width 0.25s ease, height 0.25s ease;
    }

    .file-card:hover .file-corner {
        width: 26px;
        height: 26px;
    }

    .file-content {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
    }

    .file-header {
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }

    .file-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        background: var(--primary-blue, #3B82F6);
        border-radius: 6px;
        color: #ffffff;
        flex-shrink: 0;
        transition: transform 0.2s ease;
    }

        .file-icon svg {
            width: 16px;
            height: 16px;
        }

    .file-card:hover .file-icon {
        transform: scale(1.08);
    }

    .file-title {
        font-size: 13px;
        font-weight: 650;
        color: #1e293b;
        margin: 0;
        line-height: 1.4;
        white-space: normal;
        overflow-wrap: break-word;
        word-break: break-word;
        letter-spacing: -0.1px;
        flex: 1;
    }

    .file-desc {
        font-size: 10.5px;
        color: #64748B;
        margin: 0;
        line-height: 1.4;
        white-space: normal;
        overflow-wrap: break-word;
        word-break: break-word;
    }

    .file-lines {
        margin-top: auto;
        padding-top: 6px;
    }

    .f-line {
        height: 3px;
        background: #F1F5F9;
        border-radius: 2px;
        margin-bottom: 4px;
        width: 100%;
    }

        .f-line.short {
            width: 55%;
            margin-bottom: 0;
        }

    @@media (max-width: 600px) {
        .file-card {
            width: 180px !important;
            height: 160px !important;
        }

        .file-body {
            width: 155px;
            height: 130px;
            padding: 12px 12px 8px 12px;
        }

        .file-title {
            font-size: 12px;
        }

        .file-desc {
            font-size: 9.5px;
        }

        .file-icon {
            width: 26px;
            height: 26px;
        }

            .file-icon svg {
                width: 15px;
                height: 15px;
            }
    }
</style>

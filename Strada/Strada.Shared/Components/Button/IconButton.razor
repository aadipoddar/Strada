@using Microsoft.AspNetCore.Components

<button class="@GetCssClass()" @onclick="OnClick" title="@Title" disabled="@Disabled">
    @switch (Icon)
    {
        case IconType.Pdf:
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
                <line x1="10" y1="9" x2="8" y2="9" />
            </svg>
            break;

        case IconType.View:
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
            </svg>
            break;

        case IconType.Refresh:
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10" />
                <polyline points="1 20 1 14 7 14" />
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
            </svg>
            break;

        case IconType.Delete:
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                <line x1="10" y1="11" x2="10" y2="17" />
                <line x1="14" y1="11" x2="14" y2="17" />
            </svg>
            break;

        case IconType.Back:
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            break;

        case IconType.Add:
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            break;

        case IconType.Get:
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path
                d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
            </svg>
            break;

        default:
            break;
    }
    @if (!string.IsNullOrEmpty(Text))
    {
        <span>@Text</span>
    }
</button>

<style>
    /* Icon Button Base Styles - iOS 26 Glass Effect */
    .icon-btn {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.3);
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.7) 100%);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        color: #64748b;
        padding: 0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 4px 16px rgba(0, 0, 0, 0.04), inset 0 1px 1px rgba(255, 255, 255, 0.8);
        position: relative;
        overflow: hidden;
    }

    .icon-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 50%;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 100%);
        border-radius: 12px 12px 0 0;
        pointer-events: none;
    }

    .icon-btn:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.85) 100%);
        border-color: rgba(59, 130, 246, 0.4);
        color: #3b82f6;
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15), 0 8px 24px rgba(0, 0, 0, 0.08), inset 0 1px 1px rgba(255, 255, 255, 0.9);
    }

    .icon-btn:active:not(:disabled) {
        transform: translateY(0) scale(0.98);
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06), inset 0 1px 1px rgba(255, 255, 255, 0.6);
        transition: all 0.1s ease;
    }

    .icon-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        backdrop-filter: blur(10px);
    }

    /* PDF Button - Glass Red */
    .icon-btn.icon-btn-pdf {
        color: #dc2626;
        border-color: rgba(220, 38, 38, 0.3);
        background: linear-gradient(135deg, rgba(254, 242, 242, 0.9) 0%, rgba(254, 226, 226, 0.7) 100%);
    }

    .icon-btn.icon-btn-pdf:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(254, 242, 242, 0.95) 0%, rgba(254, 202, 202, 0.8) 100%);
        border-color: rgba(185, 28, 28, 0.5);
        color: #b91c1c;
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.2), 0 8px 24px rgba(220, 38, 38, 0.1), inset 0 1px 1px rgba(255, 255, 255, 0.9);
    }

    /* View Button - Glass Blue */
    .icon-btn.icon-btn-view {
        color: #3b82f6;
        border-color: rgba(59, 130, 246, 0.3);
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.9) 0%, rgba(219, 234, 254, 0.7) 100%);
    }

    .icon-btn.icon-btn-view:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.95) 0%, rgba(191, 219, 254, 0.8) 100%);
        border-color: rgba(37, 99, 235, 0.5);
        color: #2563eb;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2), 0 8px 24px rgba(59, 130, 246, 0.1), inset 0 1px 1px rgba(255, 255, 255, 0.9);
    }

    /* Delete Button - Glass Red */
    .icon-btn.icon-btn-delete {
        color: #ef4444;
        border-color: rgba(239, 68, 68, 0.3);
        background: linear-gradient(135deg, rgba(254, 242, 242, 0.9) 0%, rgba(254, 226, 226, 0.7) 100%);
    }

    .icon-btn.icon-btn-delete:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(254, 242, 242, 0.95) 0%, rgba(254, 202, 202, 0.8) 100%);
        border-color: rgba(220, 38, 38, 0.5);
        color: #dc2626;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2), 0 8px 24px rgba(239, 68, 68, 0.1), inset 0 1px 1px rgba(255, 255, 255, 0.9);
    }

    /* Small Button Variant */
    .icon-btn.icon-btn-small {
        width: 32px;
        height: 28px;
        border-radius: 10px;
    }

    /* Grid Action Button Variant */
    .icon-btn.icon-btn-grid {
        width: 28px;
        height: 28px;
        border-radius: 8px;
    }

    /* Get Button - Glass Light Green */
    .icon-btn.icon-btn-get {
        color: #10b981;
        border-color: rgba(16, 185, 129, 0.3);
        background: linear-gradient(135deg, rgba(236, 253, 245, 0.9) 0%, rgba(209, 250, 229, 0.7) 100%);
    }

    .icon-btn.icon-btn-get:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(236, 253, 245, 0.95) 0%, rgba(167, 243, 208, 0.8) 100%);
        border-color: rgba(5, 150, 105, 0.5);
        color: #059669;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2), 0 8px 24px rgba(16, 185, 129, 0.1), inset 0 1px 1px rgba(255, 255, 255, 0.9);
    }

    /* Add Button - Primary Action Glass */
    .icon-btn.icon-btn-add {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.9) 0%, rgba(99, 102, 241, 0.85) 100%);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3), 0 8px 24px rgba(99, 102, 241, 0.2), inset 0 1px 1px rgba(255, 255, 255, 0.3);
    }

    .icon-btn.icon-btn-add::before {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0) 100%);
    }

    .icon-btn.icon-btn-add:hover:not(:disabled) {
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.95) 0%, rgba(79, 70, 229, 0.9) 100%);
        color: #ffffff;
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 6px 16px rgba(59, 130, 246, 0.4), 0 12px 32px rgba(99, 102, 241, 0.25), inset 0 1px 1px rgba(255, 255, 255, 0.4);
    }

    .icon-btn.icon-btn-add:active:not(:disabled) {
        transform: translateY(0) scale(0.98);
        box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.2);
    }
</style>

@using MudBlazor
@using StradaLibrary.Models.Accounts.Masters

@if (_isFocused && AddNewRoute is not null)
{
	<MudHotkey Key="JsKey.F12" OnHotkeyPressed="NavigateToAddNew" />
}

<div @onfocusin="OnFocusIn" @onfocusout="OnFocusOut">

	<div class="date-year-wrapper">
		<MudDatePicker @ref="_datePicker"
					   Date="@DateValue"
					   DateChanged="OnDateChangedInternal"
					   DateFormat="dd/MM/yy"
					   Mask="@(new DateMask("dd/MM/yy"))"
					   Placeholder="DD/MM/YY"
					   Label="@Label"
					   Required="@Required"
					   RequiredError=""
					   ErrorText=""
					   AutoClose="true"
					   Editable="true"
					   Margin="MudBlazor.Margin.Dense"
					   Variant="MudBlazor.Variant.Outlined"
					   IconSize="Size.Small" />
		@if (ShowFinancialYear)
		{
			<MudTextField T="string"
						  Value="@(FinancialYear is null ? "Select Financial Year" : $"{FinancialYear.StartDate:yyyy} to {FinancialYear.EndDate:yyyy}")"
						  Placeholder="Financial Year"
						  Label="Financial Year"
						  ReadOnly="true"
						  tabindex="-1"
						  Margin="MudBlazor.Margin.Dense"
						  Variant="MudBlazor.Variant.Filled"
						  Adornment="@(AddNewRoute is not null ? Adornment.End : Adornment.None)"
						  AdornmentIcon="@(AddNewRoute is not null ? Icons.Material.Filled.Add : null)"
						  AdornmentColor="Color.Primary"
						  IconSize="Size.Small"
						  OnAdornmentClick="NavigateToAddNew"
						  AdornmentAriaLabel="New" />
		}
	</div>
</div>

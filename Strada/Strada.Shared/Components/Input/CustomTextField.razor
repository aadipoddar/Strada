@using MudBlazor

@if (_isFocused && AddNewRoute is not null)
{
	<MudHotkey Key="JsKey.F12" OnHotkeyPressed="NavigateToAddNew" />
}

<div class="ctf-root" @onfocusin="OnFocusIn" @onfocusout="OnFocusOut">
	<MudTextField T="string"
				  @ref="_textField"
				  Value="Value"
				  ValueChanged="OnValueChangedInternal"
				  Label="@Label"
				  Placeholder="@Placeholder"
				  Required="@Required"
				  RequiredError=""
				  ErrorText=""
				  ReadOnly="@ReadOnly"
				  InputType="@InputType"
				  Class="@(ReadOnly ? "ctf-readonly" : null)"
				  Lines="@Lines"
				  Sizing="@(Lines > 1 ? InputSizing.Auto : InputSizing.Fixed)"
				  MaxLines="@(Lines > 1 ? MaxLines : 0)"
				  MaxLength="@MaxLength"
				  Tabindex="@TabIndex"
				  Immediate="true"
				  Clearable="!Required && !ReadOnly"
				  Margin="MudBlazor.Margin.Dense"
				  Variant="MudBlazor.Variant.Outlined"
				  Adornment="@(ShowAddNew ? Adornment.End : Adornment.None)"
				  AdornmentIcon="@(ShowAddNew ? Icons.Material.Filled.Add : null)"
				  AdornmentColor="Color.Primary"
				  IconSize="Size.Small"
				  OnAdornmentClick="NavigateToAddNew" />
</div>

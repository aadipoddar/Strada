    <PackageReference Include="Syncfusion.Blazor.Inputs" Version="33.2.10" />
    <PackageReference Include="Syncfusion.Blazor.Notifications" Version="33.2.10" />
    <PackageReference Include="Syncfusion.Blazor.Popups" Version="33.2.10" />
    <PackageReference Include="Syncfusion.Blazor.Themes" Version="33.2.10" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\StradaLibrary\StradaLibrary.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Strada.Shared.Services" />
    <Using Include="StradaLibrary.Common" />
    <Using Include="StradaLibrary.DataAccess" />
  </ItemGroup>

</Project>
@attribute [Route(PageRouteNames.Dashboard)]

<PageTitle>Dashboard - Strada</PageTitle>

@if (!_isUpdating && (_isLoading || _user is null))
{
	<LoadingScreen />
}
else if (_isUpdating)
{
	<!-- Update Progress Overlay -->
	<div class="update-overlay">
		<div class="update-container">
			<div class="update-header">
				<svg class="update-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2" />
				</svg>
				<h2 class="update-title">Updating Strada</h2>
				<p class="update-subtitle">Please wait while we update your app</p>
			</div>

			<div class="update-progress-section">
				<div class="progress-info">
					<span class="progress-label">Progress</span>
					<span class="progress-percentage">@_updateProgress%</span>
				</div>
				<div class="progress-bar-container">
					<div class="progress-bar-fill" style="width: @(_updateProgress)%"></div>
				</div>
				<div class="time-remaining">
					@if (_timeRemaining > 0)
					{
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10" />
							<polyline points="12 6 12 12 16 14" />
						</svg>
						<span>Estimated time: @_timeRemaining seconds</span>
					}
					else
					{
						<span>Calculating...</span>
					}
				</div>
			</div>

			<div class="update-status">
				<div class="status-dot"></div>
				<span>@_updateStatus</span>
			</div>
		</div>
	</div>
}
else
{
	<div class="page-shell">
		<Header Title="Dashboard">
			<RightContent>
				<IconButton Icon="IconType.Refresh" Title="Force Update" Disabled="@(_isLoading || _isUpdating)" OnClick="ForceUpdate" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container launchpad">

			<MudBlazor.MudTabs Rounded="true"
							   Color="MudBlazor.Color.Transparent"
							   SliderColor="MudBlazor.Color.Primary"
							   MinimumTabWidth="120px"
							   ApplyEffectsToContainer="false"
							   TabHeaderClass="launchpad-tab-header"
							   TabPanelsClass="launchpad-tab-panels">

				<!-- ANALYSIS (Overview) -->
				<MudBlazor.MudTabPanel Text="Analysis">
					<DashboardAnalysis />
					<DashboardAttention />
				</MudBlazor.MudTabPanel>

				<!-- ACCOUNTS -->
				<MudBlazor.MudTabPanel Text="Accounts" Visible="_user.Accounts">

					<!-- Entry Pages -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Entry Pages</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Financial Accounting" Subtitle="Record journal entries and transactions" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialAccounting)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<line x1="12" y1="1" x2="12" y2="23" />
										<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

					<!-- Financial Reports -->
					@if (_user.Reports)
					{
						<div class="launchpad-section">
							<h2 class="launchpad-section-title">Financial Reports</h2>
							<div class="dashboard-grid">
								<FioriTile Title="Financial Accounting Report" Subtitle="View accounting transaction history" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialAccountingReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Ledger Report" Subtitle="View detailed ledger transactions" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.AccountingLedgerReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
											<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Trial Balance" Subtitle="View trial balance summary" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TrialBalanceReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
											<line x1="8" y1="21" x2="16" y2="21" />
											<line x1="12" y1="17" x2="12" y2="21" />
											<line x1="7" y1="7" x2="7" y2="11" />
											<line x1="12" y1="7" x2="12" y2="11" />
											<line x1="17" y1="7" x2="17" y2="11" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Profit &amp; Loss" Subtitle="View income and expense summary" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.ProfitAndLossReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<line x1="12" y1="1" x2="12" y2="23" />
											<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Balance Sheet" Subtitle="View assets, liabilities &amp; equity" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.BalanceSheetReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<line x1="12" y1="3" x2="12" y2="21" />
											<line x1="3" y1="6" x2="21" y2="6" />
											<path d="M5 6L3 12h4L5 6" />
											<path d="M19 6l-2 6h4l-2-6" />
											<line x1="7" y1="21" x2="17" y2="21" />
										</svg>
									</IconContent>
								</FioriTile>
							</div>
						</div>
					}

					<!-- Master Data -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Master Data</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Ledgers" Subtitle="Manage ledger accounts" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.LedgerMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
										<polyline points="14 2 14 8 20 8" />
										<line x1="16" y1="13" x2="8" y2="13" />
										<line x1="16" y1="17" x2="8" y2="17" />
										<line x1="10" y1="9" x2="8" y2="9" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Group" Subtitle="Manage account groups" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.GroupMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
										<circle cx="9" cy="7" r="4" />
										<path d="M23 21v-2a4 4 0 0 0-3-3.87" />
										<path d="M16 3.13a4 4 0 0 1 0 7.75" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Account Type" Subtitle="Manage account types" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.AccountTypeMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
										<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Voucher" Subtitle="Manage voucher types" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VoucherMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
										<polyline points="14 2 14 8 20 8" />
										<line x1="12" y1="18" x2="12" y2="12" />
										<line x1="9" y1="15" x2="15" y2="15" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Financial Years" Subtitle="Manage financial year periods" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialYearMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
										<line x1="16" y1="2" x2="16" y2="6" />
										<line x1="8" y1="2" x2="8" y2="6" />
										<line x1="3" y1="10" x2="21" y2="10" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="States" Subtitle="Manage state/UT information" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.StateUTMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="12" cy="12" r="10" />
										<line x1="2" y1="12" x2="22" y2="12" />
										<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Company" Subtitle="Manage company settings" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.CompanyMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
										<polyline points="9 22 9 12 15 12 15 22" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

				</MudBlazor.MudTabPanel>

				<!-- FLEET MASTERS -->
				<MudBlazor.MudTabPanel Text="Fleet Masters" Visible="_user.Fleet">

					<!-- Routes & Drivers -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Routes &amp; Drivers</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Route" Subtitle="Manage routes between source and destination locations" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.RouteMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="6" cy="19" r="3" />
										<path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15" />
										<circle cx="18" cy="5" r="3" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Location" Subtitle="Pickup and drop locations used across routes" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.LocationMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M12 21s-6-4.35-6-10a6 6 0 0 1 12 0c0 5.65-6 10-6 10z" />
										<circle cx="12" cy="11" r="2" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Driver" Subtitle="Manage drivers assigned to your fleet" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.DriverMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
										<circle cx="12" cy="7" r="4" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Vehicle Driver" Subtitle="Assign drivers to vehicles for a period of time" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDriverMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M10 17h4V5H2v12h3" />
										<path d="M14 9h4l4 4v4h-3" />
										<circle cx="7.5" cy="17.5" r="2.5" />
										<circle cx="17.5" cy="17.5" r="2.5" />
										<circle cx="12" cy="7" r="2" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

					<!-- OMC -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">OMC</h2>
						<div class="dashboard-grid">
							<FioriTile Title="OMC" Subtitle="Manage oil marketing company list" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.OMCMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M3 21h18" />
										<path d="M5 21V7l8-4v18" />
										<path d="M19 21V11l-6-4" />
										<line x1="9" y1="9" x2="9" y2="9.01" />
										<line x1="9" y1="13" x2="9" y2="13.01" />
										<line x1="9" y1="17" x2="9" y2="17.01" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="OMC Card" Subtitle="Manage fuel cards issued by oil marketing companies" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.OMCCardMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="2" y="5" width="20" height="14" rx="2" ry="2" />
										<line x1="2" y1="10" x2="22" y2="10" />
										<line x1="6" y1="15" x2="10" y2="15" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

					<!-- Documents -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Documents</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Vehicle Document" Subtitle="Upload and track compliance documents per vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDocument)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
										<polyline points="14 2 14 8 20 8" />
										<line x1="9" y1="15" x2="15" y2="15" />
									</svg>
								</IconContent>
							</FioriTile>

							<!-- Document Reports -->
							<FioriTile Title="Document Renewal Report" Subtitle="Latest document status per vehicle with expiry tracking" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDocumentRenewalReport)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
										<line x1="16" y1="2" x2="16" y2="6" />
										<line x1="8" y1="2" x2="8" y2="6" />
										<line x1="3" y1="10" x2="21" y2="10" />
										<path d="M8 14l3 3 5-5" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Document Type" Subtitle="Manage document categories like RC, insurance and PUC" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDocumentTypeMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
										<polyline points="14 2 14 8 20 8" />
										<line x1="8" y1="13" x2="16" y2="13" />
										<line x1="8" y1="17" x2="13" y2="17" />
									</svg>
								</IconContent>
							</FioriTile>

						</div>
					</div>

					<!-- Vehicle Masters -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Vehicle Masters</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Vehicle" Subtitle="Manage your fleet of vehicles" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M10 17h4V5H2v12h3" />
										<path d="M14 9h4l4 4v4h-3" />
										<circle cx="7.5" cy="17.5" r="2.5" />
										<circle cx="17.5" cy="17.5" r="2.5" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Vehicle Type" Subtitle="Categorise vehicles by class &mdash; truck, tanker, trailer" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTypeMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M3 7h18" />
										<path d="M6 3h12v4H6z" />
										<path d="M8 11v10" />
										<path d="M12 11v10" />
										<path d="M16 11v10" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Expense Type" Subtitle="Define expense categories used during data entry" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.ExpenseTypeMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
										<line x1="7" y1="7" x2="7.01" y2="7" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

				</MudBlazor.MudTabPanel>

				<!-- FLEET TRANSACTIONS -->
				<MudBlazor.MudTabPanel Text="Fleet Transactions" Visible="_user.Fleet">

					<!-- Daily Entries -->
					<div class="launchpad-section">
						<div class="dashboard-grid">
							<FioriTile Title="Trip" Subtitle="Record a new trip with route, driver and trip expenses" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.Trip)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="1" y="3" width="15" height="13" />
										<polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
										<circle cx="5.5" cy="18.5" r="2.5" />
										<circle cx="18.5" cy="18.5" r="2.5" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Bill" Subtitle="Generate and manage billing for completed trips" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.Bill)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="2" y="3" width="20" height="18" rx="2" />
										<line x1="7" y1="8" x2="17" y2="8" />
										<line x1="7" y1="12" x2="17" y2="12" />
										<line x1="7" y1="16" x2="13" y2="16" />

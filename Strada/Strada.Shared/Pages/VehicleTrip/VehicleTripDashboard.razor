@attribute [Route(PageRouteNames.VehicleTripDashboard)]

<PageTitle>Vehicle Trip - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => NavigationManager.NavigateTo(PageRouteNames.Dashboard)" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Trip Dashboard" />

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2v20" />
							<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
						</svg>
						<h2 class="section-title">Trip Advance</h2>
					</div>
					<p class="section-subtitle">Manage trip advances, payments, and expense records</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Trip Advance" Description="Record and manage trip advance transactions" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TripAdvance)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 2v20" />
									<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="8" y1="13" x2="16" y2="13" />
							<line x1="8" y1="17" x2="13" y2="17" />
						</svg>
						<h2 class="section-title">Trip Advance Reports</h2>
					</div>
					<p class="section-subtitle">View and analyse trip advance summaries and breakdowns</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Trip Advance Report" Description="Overview of all trip advances" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TripAdvanceReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="8" y1="13" x2="16" y2="13" />
									<line x1="8" y1="17" x2="13" y2="17" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Trip Advance Expenses Report" Description="Breakdown of expenses per trip advance" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TripAdvanceExpensesReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="3" width="20" height="14" rx="2" />
									<line x1="8" y1="21" x2="16" y2="21" />
									<line x1="12" y1="17" x2="12" y2="21" />
									<polyline points="7 10 10 13 13 9 17 12" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Trip Advance Payments Report" Description="Payments made against trip advances" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TripAdvancePaymentsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="2" />
									<line x1="2" y1="10" x2="22" y2="10" />
									<path d="M6 15h2" />
									<path d="M12 15h4" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="3" />
							<path d="M12 2v3" />
							<path d="M12 19v3" />
							<path d="m4.22 4.22 2.12 2.12" />
							<path d="m17.66 17.66 2.12 2.12" />
							<path d="M2 12h3" />
							<path d="M19 12h3" />
							<path d="m4.22 19.78 2.12-2.12" />
							<path d="m17.66 6.34 2.12-2.12" />
						</svg>
						<h2 class="section-title">Vehicle Routes</h2>
					</div>
					<p class="section-subtitle">Manage routes, locations, and assigned drivers</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle Route" Description="Define and manage vehicle routes" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleRouteMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 17l4-8 4 4 4-4 4 8" />
									<path d="M3 7v14" />
									<path d="M21 7v14" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Route Location" Description="Manage pickup and drop-off locations" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleRouteLocationMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
									<circle cx="12" cy="10" r="3" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Vehicle Driver" Description="Manage drivers assigned to vehicles" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDriverMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="8" r="4" />
									<path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="7" width="20" height="14" rx="2" />
							<path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
							<line x1="12" y1="12" x2="12" y2="16" />
							<line x1="10" y1="14" x2="14" y2="14" />
						</svg>
						<h2 class="section-title">OMC</h2>
					</div>
					<p class="section-subtitle">Manage oil marketing company accounts and fuel cards</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="OMC" Description="Manage oil marketing company accounts" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.OMCMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 22V8l9-6 9 6v14H3z" />
									<path d="M9 22V12h6v10" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="OMC Card" Description="Manage fuel cards linked to OMC accounts" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.OMCCardMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="2" />
									<line x1="2" y1="10" x2="22" y2="10" />
									<circle cx="7" cy="15" r="1" fill="currentColor" />
									<line x1="11" y1="15" x2="17" y2="15" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

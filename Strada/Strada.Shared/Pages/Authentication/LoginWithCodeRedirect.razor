@attribute [Route($"{PageRouteNames.LoginWithCodeRedirect}/{{Id}}/{{Code}}")]

<PageTitle>Verifying - Strada</PageTitle>

<div class="redirect-container">
    <div class="redirect-card">
        <!-- Logo Section -->
        <div class="logo-section">
            <img src="images/logo_full.png" alt="Strada Logo" class="redirect-logo" />
        </div>

        <!-- Loading Section -->
        <div class="loading-section">
            <div class="loading-spinner"></div>
            <h2 class="loading-title">Verifying your login...</h2>
            <p class="loading-subtitle">Please wait while we verify your credentials</p>
        </div>
    </div>
</div>

<style>
    /* Color Variables - Matching Dashboard Theme */
    :root {
        --primary-color: #3b82f6;
        --primary-dark: #2563eb;
        --primary-light: #60a5fa;
        --secondary-color: #f8fafc;
        --text-dark: #1e293b;
        --text-light: #64748b;
        --white: #ffffff;
        --border-color: #e2e8f0;
        --shadow: 0 10px 40px rgba(59, 130, 246, 0.15);
        --border-radius: 16px;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    /* Redirect Container */
    .redirect-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 20px;
        background: linear-gradient(135deg, #f7f8fa 0%, #eef2f5 100%);
        position: relative;
    }

    /* Redirect Card */
    .redirect-card {
        background: var(--white);
        border-radius: var(--border-radius);
        box-shadow: var(--shadow);
        padding: 48px 40px;
        width: 100%;
        max-width: 450px;
        text-align: center;
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* Logo Section */
    .logo-section {
        text-align: center;
        margin-bottom: 40px;
    }

    .redirect-logo {
        width: 100%;
        max-width: 340px;
        height: auto;
        object-fit: contain;
        display: block;
        margin: 0 auto;
    }

    /* Loading Section */
    .loading-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
    }

    /* Loading Spinner */
    .loading-spinner {
        width: 60px;
        height: 60px;
        border: 4px solid var(--border-color);
        border-top: 4px solid var(--primary-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .loading-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0;
        letter-spacing: -0.5px;
    }

    .loading-subtitle {
        font-size: 16px;
        color: var(--text-light);
        margin: 0;
        font-weight: 400;
    }

    /* Responsive Design */
    @@media (max-width: 480px) {
        .redirect-card {
            padding: 32px 24px;
        }

        .redirect-logo {
            width: 100%;
            max-width: 220px;
        }

        .loading-spinner {
            width: 50px;
            height: 50px;
        }

        .loading-title {
            font-size: 20px;
        }

        .loading-subtitle {
            font-size: 14px;
        }
    }

    /* Accessibility */
    @@media (prefers-reduced-motion: reduce) {

        .loading-spinner,
        .redirect-card {
            animation: none;
        }
    }

    /* High contrast mode support */
    @@media (prefers-contrast: high) {
        .redirect-card {
            border: 2px solid var(--text-dark);
        }

        .loading-spinner {
            border-width: 5px;
        }
    }
</style>
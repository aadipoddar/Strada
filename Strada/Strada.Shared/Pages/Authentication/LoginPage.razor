        <!-- Login Form -->
        <div class="form-section">
            <!-- Phone/Email Input -->
            <div class="input-group" data-yeti-email="phoneEmailInput">
                <label class="input-label">Phone / Email</label>
                <SfTextBox @ref="_phoneEmailTextBox" Placeholder="Enter phone number or email" CssClass="custom-textbox"
                           Input="OnPhoneEmailInput" ShowClearButton="true">
                </SfTextBox>
            </div>

            <!-- Password Input -->
            <div class="input-group" data-yeti-password="passwordInput">
                <label class="input-label">Password</label>
                <SfTextBox @ref="_passwordTextBox" Type="InputType.Password" Placeholder="@_passwordPlaceholder"
                           CssClass="custom-textbox" Input="OnPasswordInput" ShowClearButton="true">
                </SfTextBox>
            </div>

            <!-- Login Button -->
            <div class="button-group">
                <button class="btn-login" @onclick="OnLoginClick" disabled="@_isVerifying">
                    @if (_isVerifying)
                    {
                        <span class="spinner"></span>
                        <span>Verifying...</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </button>
            </div>

            <!-- Forgot Password Link -->
            @if (_isLoginWithCodeEnabled)
            {
                <div class="forgot-password-section">
                    <a class="forgot-password-link" @onclick="OnForgotPasswordClick">
                        Forgot Password? Login with Code
                    </a>
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="footer-section">
            <p class="copyright">
                &copy; @DateTime.Now.Year A Product By
                <a href="@Secrets.AadiSoftWebsite" target="_blank" class="footer-link">AadiSoft</a>.
                All rights reserved.
            </p>
        </div>
    </div>
</div>

<ToastNotification @ref="_toastNotification" />

<style>
    /* Color Variables - Matching Dashboard Theme */
    :root {
        --primary-color: #3b82f6;
        --primary-dark: #2563eb;
        --primary-light: #60a5fa;
        --secondary-color: #f8fafc;
        --text-dark: #1e293b;
        --text-light: #64748b;
        --white: #ffffff;
        --border-color: #e2e8f0;
        --shadow: 0 10px 40px rgba(59, 130, 246, 0.15);
        --shadow-hover: 0 15px 50px rgba(59, 130, 246, 0.25);
        --border-radius: 16px;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    /* Yeti Animation Section */
    .yeti-section {
        display: flex;
        justify-content: center;
        margin-bottom: 16px;
    }

    .yeti-svg-container {
        position: relative;
        width: 150px;
        height: 150px;
        margin: 0 auto;
        border-radius: 50%;
        pointer-events: none;
        box-shadow: 0 4px 20px rgba(59, 130, 246, 0.15);
        border: 2px solid var(--primary-color);
    }

    .yeti-svg-container div {
        position: relative;
        width: 100%;
        height: 0;
        overflow: hidden;
        border-radius: 50%;
        padding-bottom: 100%;
    }

    .yeti-svg-container .mySVG {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    /* Login Container */
    .login-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 20px;

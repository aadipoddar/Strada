@using StradaLibrary.Accounts.Masters.Models
@using StradaLibrary.Operations.Models
@attribute [Route(PageRouteNames.Settings)]

<PageTitle>Settings - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveSettings" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ShowResetConfirmation" Disabled="@_isProcessing" />

@if (_isLoading)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="System Settings">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveSettings" Disabled="@_isProcessing" />
								<MenuItem Text="Reset to Defaults (Ctrl + R)" IconCss="e-icons e-reset" Id="ResetSettings" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<!-- Primary Configuration -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="3" />
							<path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.09a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.09a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
						</svg>
						<h2 class="section-title">Primary Configuration</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="Select primary company"
												Label="Primary Company"
												ValueChanged="OnCompanyChange"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@PageRouteNames.CompanyMaster" />
						</div>
					</div>
				</div>
			</div>

			<!-- Login Settings -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
							<path d="M7 11V7a5 5 0 0 1 10 0v4" />
						</svg>
						<h2 class="section-title">Login Settings</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_enableLoginWithCode"
												Label="Allow OTP-based login"
												AriaLabel="Allow OTP-based login" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_enableUsersToResetPassword"
												Label="Allow self-service password reset"
												AriaLabel="Allow self-service password reset" />
							</div>
						</div>

						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_maxLoginAttempts"
												Label="Max Login Attempts"
												Placeholder="e.g., 5"
												Format="N0"
												Min="1"
												Max="20"
												Required="false" />
						</div>

						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_codeResendLimit"
												Label="Code Resend Limit"
												Placeholder="e.g., 3"
												Format="N0"
												Min="1"
												Max="10"
												Required="false" />
						</div>

						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_codeExpiryMinutes"
												Label="Code Expiry (Minutes)"
												Placeholder="e.g., 10"
												Format="N0"
												Min="1"
												Max="60"
												Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Master Code Prefixes -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="16 18 22 12 16 6" />
							<polyline points="8 6 2 12 8 18" />
						</svg>
						<h2 class="section-title">Master Code Prefixes</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @bind-Value="_ledgerCodePrefix"
											 Label="Ledger Code Prefix"
											 Placeholder="e.g., LD"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_vehicleTypeCodePrefix"
											 Label="Vehicle Type Code Prefix"
											 Placeholder="e.g., VHTY"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_documentTypeCodePrefix"
											 Label="Document Type Code Prefix"
											 Placeholder="e.g., DCTY"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_omcCodePrefix"
											 Label="OMC Code Prefix"
											 Placeholder="e.g., OMC"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_omcCardCodePrefix"
											 Label="OMC Card Code Prefix"
											 Placeholder="e.g., OMCC"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_locationCodePrefix"
											 Label="Location Code Prefix"
											 Placeholder="e.g., LC"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_routeCodePrefix"
											 Label="Route Code Prefix"
											 Placeholder="e.g., RT"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_driverCodePrefix"
											 Label="Driver Code Prefix"
											 Placeholder="e.g., DR"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_expenseTypeCodePrefix"
											 Label="Expense Type Code Prefix"
											 Placeholder="e.g., EX"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_tyreCompanyCodePrefix"
											 Label="Tyre Company Code Prefix"
											 Placeholder="e.g., TC"
											 Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Transaction Prefixes -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="12" y1="1" x2="12" y2="23" />
							<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
						</svg>
						<h2 class="section-title">Transaction Prefixes</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @bind-Value="_financialAccountingTransactionPrefix"
											 Label="Financial Accounting Prefix"
											 Placeholder="e.g., AC"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_tripTransactionPrefix"
											 Label="Trip Prefix"
											 Placeholder="e.g., TR"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_billTransactionPrefix"
											 Label="Bill Prefix"
											 Placeholder="e.g., BL"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_expenseTransactionPrefix"
											 Label="Expense Prefix"
											 Placeholder="e.g., EX"
											 Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Ledger Linking -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="16" y1="13" x2="8" y2="13" />
							<line x1="16" y1="17" x2="8" y2="17" />
							<line x1="10" y1="9" x2="8" y2="9" />
						</svg>
						<h2 class="section-title">Ledger Linking</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel"
												Value="_selectedCashLedger"
												DataSource="@_ledgers"
												Placeholder="Select cash ledger"
												Label="Cash Ledger"
												ValueChanged="OnCashLedgerChange"
												FieldValue="@nameof(LedgerModel.Name)"
												AddNewRoute="@PageRouteNames.LedgerMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="LedgerModel"
												Value="_selectedGSTLedger"
												DataSource="@_ledgers"
												Placeholder="Select GST ledger"
												Label="GST Ledger"
												ValueChanged="OnGSTLedgerChange"
												FieldValue="@nameof(LedgerModel.Name)"
												AddNewRoute="@PageRouteNames.LedgerMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="LedgerModel"
												Value="_selectedBillLedger"
												DataSource="@_ledgers"
												Placeholder="Select bill ledger"
												Label="Bill Ledger"
												ValueChanged="OnBillLedgerChange"
												FieldValue="@nameof(LedgerModel.Name)"
												AddNewRoute="@PageRouteNames.LedgerMaster" />
						</div>
					</div>
				</div>
			</div>

			<!-- Bank Reconciliation -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="3" y1="21" x2="21" y2="21" />
							<line x1="3" y1="10" x2="21" y2="10" />
							<polyline points="5 6 12 3 19 6" />
							<line x1="4" y1="10" x2="4" y2="21" />
							<line x1="20" y1="10" x2="20" y2="21" />
							<line x1="8" y1="14" x2="8" y2="17" />
							<line x1="12" y1="14" x2="12" y2="17" />
							<line x1="16" y1="14" x2="16" y2="17" />
						</svg>
						<h2 class="section-title">Bank Reconciliation</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="AccountTypeModel"
												Value="_selectedBankAccountType"
												DataSource="@_accountTypes"
												Placeholder="Select bank account type"
												Label="Bank Account Type"
												ValueChanged="OnBankAccountTypeChange"
												FieldValue="@nameof(AccountTypeModel.Name)"
												AddNewRoute="@PageRouteNames.AccountTypeMaster" />
						</div>
					</div>
				</div>
			</div>

			<!-- Default Values -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="4" width="18" height="16" rx="2" />
							<line x1="8" y1="9" x2="16" y2="9" />
							<line x1="8" y1="13" x2="13" y2="13" />
							<line x1="8" y1="17" x2="11" y2="17" />
						</svg>
						<h2 class="section-title">Default Values</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel"
												Value="_selectedDefaultVoucher"
												DataSource="@_vouchers"
												Placeholder="Select default voucher"
												Label="Default Voucher for Accounting Transactions"
												ValueChanged="OnDefaultVoucherChange"
												FieldValue="@nameof(VoucherModel.Name)"
												AddNewRoute="@PageRouteNames.VoucherMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="VoucherModel"
												Value="_selectedBillVoucher"
												DataSource="@_vouchers"
												Placeholder="Select bill voucher"
												Label="Bill Voucher"
												ValueChanged="OnBillVoucherChange"
												FieldValue="@nameof(VoucherModel.Name)"
												AddNewRoute="@PageRouteNames.VoucherMaster" />
						</div>
					</div>
				</div>
			</div>

			<!-- Report Settings -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10" />
							<polyline points="12 6 12 12 16 14" />
						</svg>
						<h2 class="section-title">Report Settings</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_autoRefreshReportTimer"
												Label="Auto Refresh Timer (Minutes)"
												Placeholder="e.g., 5"
												Format="N0"
												Min="1"
												Max="60"
												Required="false" />
						</div>
						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_reportWarningDays"
												Label="Report Warning (Days)"
												Placeholder="e.g., 30"
												Format="N0"
												Min="1"
												Max="365"
												Required="false" />
						</div>
						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_analysisCacheHours"
												Label="Analysis Cache (Hours)"
												Placeholder="e.g., 12"
												Format="N0"
												Min="1"
												Max="168"
												Required="false" />
						</div>
					</div>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
                    OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<NavigationLock ConfirmExternalNavigation="@_isProcessing" />
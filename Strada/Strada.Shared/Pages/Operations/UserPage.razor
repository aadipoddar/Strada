@using StradaLibrary.Operations.Models

@attribute [Route(PageRouteNames.User)]

<PageTitle>User Management - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _loggedInUser is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="User Management">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash" Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel" Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelectedItem" Disabled="@_isProcessing" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
		</Header>

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">User Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @ref="_sfFirstFocus"
											 @bind-Value="_transactionUser.Name"
											 Label="Name (Ctrl + F)"
											 Placeholder="Enter User Name" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_transactionUser.Phone"
											 Label="Phone"
											 Placeholder="Enter 10-digit phone number"
											 MaxLength="10" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_transactionUser.Email"
											 Label="Email"
											 Placeholder="Enter email (optional)"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_transactionUser.Password"
											 Label="Password"
											 Placeholder="Enter password"
											 InputType="MudBlazor.InputType.Password" />
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_transactionUser.Accounts"
												Label="Accounts"
												AriaLabel="Accounts permission" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_transactionUser.Fleet"
												Label="Fleet"
												AriaLabel="Fleet permission" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_transactionUser.Reports"
												Label="Reports"
												AriaLabel="Reports permission" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_transactionUser.Admin"
												Label="Admin"
												AriaLabel="Admin permission" />
							</div>
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_transactionUser.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Users List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_users" AllowPaging="true" AllowSorting="true" AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="UserModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(UserModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(UserModel.Name)" HeaderText="Name" Width="220" />
							<GridColumn Field="@nameof(UserModel.Phone)" HeaderText="Phone" Width="140" />
							<GridColumn Field="@nameof(UserModel.Email)" HeaderText="Email" Width="220" />
							<GridColumn Field="@nameof(UserModel.Accounts)" HeaderText="Accounts" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as UserModel);
										<span class="@(item.Accounts ? "grid-credit" : "grid-debit")">@(item.Accounts ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserModel.Fleet)" HeaderText="Fleet" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as UserModel);
										<span class="@(item.Fleet ? "grid-credit" : "grid-debit")">@(item.Fleet ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserModel.Reports)" HeaderText="Reports" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as UserModel);
										<span class="@(item.Reports ? "grid-credit" : "grid-debit")">@(item.Reports ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserModel.Admin)" HeaderText="Admin" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as UserModel);
										<span class="@(item.Admin ? "grid-credit" : "grid-debit")">@(item.Admin ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserModel.Remarks)" HeaderText="Remarks" Width="220" />
							<GridColumn Field="@nameof(UserModel.Status)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as UserModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<NavigationLock ConfirmExternalNavigation="@_isProcessing" />

@attribute [Route(PageRouteNames.VehicleExpenseDashboard)]

<PageTitle>Vehicle Expense - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => NavigationManager.NavigateTo(PageRouteNames.Dashboard)" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Expense Dashboard" />

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M10 17h4V5H2v12h3" />
							<path d="M14 9h4l4 4v4h-3" />
							<circle cx="7.5" cy="17.5" r="2.5" />
							<circle cx="17.5" cy="17.5" r="2.5" />
						</svg>
						<h2 class="section-title">Vehicle Expenses</h2>
					</div>
					<p class="section-subtitle">Record and manage all vehicle expense transactions</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle Expense" Description="Record and manage vehicle expense entries" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpense)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M10 17h4V5H2v12h3" />
									<path d="M14 9h4l4 4v4h-3" />
									<circle cx="7.5" cy="17.5" r="2.5" />
									<circle cx="17.5" cy="17.5" r="2.5" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="8" y1="13" x2="16" y2="13" />
							<line x1="8" y1="17" x2="13" y2="17" />
						</svg>
						<h2 class="section-title">Vehicle Expense Reports</h2>
					</div>
					<p class="section-subtitle">Analyse and review vehicle expense summaries and details</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle Expense Report" Description="Summary overview of all vehicle expenses" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="8" y1="13" x2="16" y2="13" />
									<line x1="8" y1="17" x2="13" y2="17" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Vehicle Expense Details Report" Description="Line-by-line breakdown of vehicle expenses" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseDetailsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="3" width="20" height="14" rx="2" />
									<line x1="8" y1="21" x2="16" y2="21" />
									<line x1="12" y1="17" x2="12" y2="21" />
									<polyline points="7 10 10 13 13 9 17 12" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
							<rect x="9" y="3" width="6" height="4" rx="1" />
							<line x1="9" y1="12" x2="15" y2="12" />
							<line x1="9" y1="16" x2="12" y2="16" />
						</svg>
						<h2 class="section-title">Expense Type Catalog</h2>
					</div>
					<p class="section-subtitle">Manage the catalog of vehicle expense types</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle Expense Type" Description="Define and manage expense type categories" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseTypeMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
									<rect x="9" y="3" width="6" height="4" rx="1" />
									<line x1="9" y1="12" x2="15" y2="12" />
									<line x1="9" y1="16" x2="12" y2="16" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

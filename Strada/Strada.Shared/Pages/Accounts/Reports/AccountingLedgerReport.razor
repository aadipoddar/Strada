@using Strada.Shared.Components.Card
@using StradaLibrary.Accounts.FinancialAccounting.Models
@using StradaLibrary.Accounts.Masters.Models

@attribute [Route(PageRouteNames.AccountingLedgerReport)]

<PageTitle>Financial Ledger Report - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.FinancialAccounting, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ViewSelectedTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportSelectedTransactionPdf" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportSelectedTransactionExcel" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedTransaction" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Financial Ledger Report">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="Refresh Data (Ctrl + R / F5)" IconCss="e-icons e-refresh" Id="Refresh" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash" Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" IconCss="e-icons e-table" Id="ToggleDetailsView" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf" Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Open" IconCss="e-icons e-folder-open">
							<MenuItems>
								<MenuItem Text="Accounting Report" Id="AccountingReport" Disabled="@_isProcessing" />
								<MenuItem Text="Trial Balance" Id="TrialBalance" Disabled="@_isProcessing" />
								<MenuItem Text="Profit & Loss" Id="ProfitLoss" Disabled="@_isProcessing" />
								<MenuItem Text="Balance Sheet" Id="BalanceSheet" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Periods" IconCss="e-icons e-clock">
							<MenuItems>
								<MenuItem Text="Today" Id="PeriodToday" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Day" Id="PeriodPreviousDay" Disabled="@_isProcessing" />
								<MenuItem Text="Next Day" Id="PeriodNextDay" Disabled="@_isProcessing" />
								<MenuItem Text="Current Month" Id="PeriodCurrentMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Month" Id="PeriodPreviousMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Next Month" Id="PeriodNextMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Current FY" Id="PeriodCurrentFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Previous FY" Id="PeriodPreviousFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Next FY" Id="PeriodNextFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="All Time" Id="PeriodAllTime" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="View (Alt + O)" IconCss="e-icons e-eye" Id="ViewSelected" Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="DownloadSelectedPdf" Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel" Id="DownloadSelectedExcel" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelected" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Filters Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
						</svg>
						<h2 class="section-title">Filters</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="filters-container">
						<div class="filters-grid">
							<!-- Date Range -->
							<div class="form-field">
								<CustomDateRangePicker @ref="_sfFirstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
													   ValueChanged="OnDateRangeChanged"
													   Label="Date Range (Ctrl + F)"
													   Required="false" />
							</div>

							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete T="CompanyModel"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="All Companies"
													Label="Company" Required="false"
													FieldValue="@nameof(CompanyModel.Name)"
													ValueChanged="OnCompanyChanged"
													AddNewRoute="@PageRouteNames.CompanyMaster" />
							</div>

							<!-- Voucher -->
							<div class="form-field">
								<CustomAutoComplete T="VoucherModel"
													Value="_selectedVoucher"
													DataSource="@_vouchers"
													Placeholder="All Vouchers"
													Label="Voucher" Required="false"
													ValueChanged="OnVoucherChanged"
													FieldValue="@nameof(VoucherModel.Name)"
													AddNewRoute="@PageRouteNames.VoucherMaster" />
							</div>

							<!-- Ledger -->
							<div class="form-field">
								<CustomAutoComplete T="LedgerModel"
													Value="_selectedLedger"
													DataSource="@_ledgers"
													Placeholder="All Ledgers"
													Label="Ledger" Required="false"
													FieldValue="@nameof(LedgerModel.Name)"
													ValueChanged="OnLedgerChanged"
													AddNewRoute="@PageRouteNames.LedgerMaster" />
							</div>
						</div>

					</div>
				</div>
			</div>

			<!-- Report Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<line x1="8" y1="6" x2="21" y2="6" />
							<line x1="8" y1="12" x2="21" y2="12" />
							<line x1="8" y1="18" x2="21" y2="18" />
							<line x1="3" y1="6" x2="3.01" y2="6" />
							<line x1="3" y1="12" x2="3.01" y2="12" />
							<line x1="3" y1="18" x2="3.01" y2="18" />
						</svg>
						<h2 class="section-title">Ledger Transactions</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" TValue="FinancialAccountingLedgerOverviewModel"
							DataSource="_transactionOverviews" AllowTextWrap="true" AllowPaging="true" AllowSorting="true"
							AllowResizing="true" AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true"
							GridLines="GridLine.Horizontal" CssClass="professional-grid" AllowGrouping="true"
							ContextMenuItems="@_gridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="FinancialAccountingLedgerOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Entries: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Entries: @aggregate.Count</strong>
											</div>
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Entries: @aggregate.Count</strong>
											</div>
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.Debit)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-debit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-debit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-debit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.Credit)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-credit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-credit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-credit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerReferenceAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerName)" HeaderText="Ledger" Width="350" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerCode)" HeaderText="Code" Width="120" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.AccountTypeName)" HeaderText="Account Type" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.GroupName)" HeaderText="Group" Width="150" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerReferenceType)" HeaderText="Ref Type" Width="130" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerReferenceNo)" HeaderText="Ref No" Width="150" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerReferenceDateTime)" HeaderText="Ref Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerReferenceAmount)" HeaderText="Ref Amt" Width="130" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.Debit)" HeaderText="Debit" Width="140" TextAlign="TextAlign.Right">
								<Template>
									@{
										var detailItem = (context as FinancialAccountingLedgerOverviewModel);
										<span class="grid-debit">@(detailItem.Debit?.ToString("N2") ?? "-")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.Credit)" HeaderText="Credit" Width="140" TextAlign="TextAlign.Right">
								<Template>
									@{
										var detailItem = (context as FinancialAccountingLedgerOverviewModel);
										<span class="grid-credit">@(detailItem.Credit?.ToString("N2") ?? "-")</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LedgerRemarks)" HeaderText="Ledger Remarks" Width="200" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TransactionNo)" HeaderText="Trans No" Width="170" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TransactionDateTime)" HeaderText="Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.CompanyName)" HeaderText="Company" Width="180" Visible="@(_showAllColumns && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.VoucherName)" HeaderText="Voucher Type" Width="150" Visible="@(_showAllColumns && (_selectedVoucher is null || _selectedVoucher.Id <= 0))" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.ReferenceNo)" HeaderText="Ref No" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.FinancialYear)" HeaderText="Financial Year" Width="130" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TotalLedgers)" HeaderText="Ledgers" Width="100" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TotalDebitLedgers)" HeaderText="Debit Ledgers" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TotalCreditLedgers)" HeaderText="Credit Ledgers" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TotalDebitAmount)" HeaderText="Total Debit" Width="150" TextAlign="TextAlign.Right" Visible="_showAllColumns">
								<Template>
									@{
										var item = (context as FinancialAccountingLedgerOverviewModel);
										<span class="grid-debit">@item.TotalDebitAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TotalCreditAmount)" HeaderText="Total Credit" Width="150" TextAlign="TextAlign.Right" Visible="_showAllColumns">
								<Template>
									@{
										var item = (context as FinancialAccountingLedgerOverviewModel);
										<span class="grid-credit">@item.TotalCreditAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.TotalAmount)" HeaderText="Amount" Width="150" TextAlign="TextAlign.Right" Visible="_showAllColumns">
								<Template>
									@{
										var item = (context as FinancialAccountingLedgerOverviewModel);
										<span class="grid-total">@item.TotalAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.Remarks)" HeaderText="Remarks" Width="200" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.CreatedByName)" HeaderText="Created By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.CreatedAt)" HeaderText="Created At" Width="160" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.CreatedFromPlatform)" HeaderText="Created Platform" Width="200" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LastModifiedByUserName)" HeaderText="Modified By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LastModifiedAt)" HeaderText="Modified At" Width="160" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.LastModifiedFromPlatform)" HeaderText="Modified Platform" Width="200" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(FinancialAccountingLedgerOverviewModel.Status)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as FinancialAccountingLedgerOverviewModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">
											@(item.Status ? "Active" : "Deleted")
										</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>

			<!-- Trial Balance Summary Section (Shown when Ledger is selected) -->
			@if (_selectedLedger?.Id > 0 && _selectedTrialBalance != null)
			{
				<div class="section-card trial-balance-summary">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
								 stroke-linejoin="round">
								<rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
								<line x1="8" y1="21" x2="16" y2="21" />
								<line x1="12" y1="17" x2="12" y2="21" />
								<line x1="7" y1="7" x2="7" y2="11" />
								<line x1="12" y1="7" x2="12" y2="11" />
								<line x1="17" y1="7" x2="17" y2="11" />
							</svg>
							<div class="section-title-with-details">
								<h2 class="section-title">@_selectedTrialBalance.LedgerName</h2>
								<div class="ledger-badges">
									<span class="badge badge-group">@_selectedTrialBalance.GroupName</span>
									<span class="badge badge-account">@_selectedTrialBalance.AccountTypeName</span>
								</div>
							</div>
						</div>
					</div>
					<div class="section-body">
						<div class="trial-balance-grid">
							<BalanceInfoCard Label="Opening Balance" Value="@($"₹{_selectedTrialBalance.OpeningBalance:N2}")"
											 Breakdown="@($"Dr: ₹{_selectedTrialBalance.OpeningDebit:N2} • Cr: ₹{_selectedTrialBalance.OpeningCredit:N2}")"
											 Variant="BalanceInfoCard.CardVariant.Opening">
								<Icon>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
										 stroke-linejoin="round">
										<circle cx="12" cy="12" r="10" />
										<polyline points="12 6 12 12 16 14" />
									</svg>
								</Icon>
							</BalanceInfoCard>

							<BalanceInfoCard Label="Period Debit" Value="@($"₹{_selectedTrialBalance.Debit:N2}")"
											 Variant="BalanceInfoCard.CardVariant.Debit">
								<Icon>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
										 stroke-linejoin="round">
										<line x1="12" y1="5" x2="12" y2="19" />
										<polyline points="19 12 12 19 5 12" />
									</svg>
								</Icon>
							</BalanceInfoCard>

							<BalanceInfoCard Label="Period Credit" Value="@($"₹{_selectedTrialBalance.Credit:N2}")"
											 Variant="BalanceInfoCard.CardVariant.Credit">
								<Icon>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
										 stroke-linejoin="round">
										<line x1="12" y1="19" x2="12" y2="5" />
										<polyline points="5 12 12 5 19 12" />
									</svg>
								</Icon>
							</BalanceInfoCard>

							<BalanceInfoCard Label="Closing Balance" Value="@($"₹{_selectedTrialBalance.ClosingBalance:N2}")"
											 Breakdown="@($"Dr: ₹{_selectedTrialBalance.ClosingDebit:N2} • Cr: ₹{_selectedTrialBalance.ClosingCredit:N2}")"
											 Variant="BalanceInfoCard.CardVariant.Closing">
								<Icon>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
										 stroke-linejoin="round">
										<rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
										<line x1="1" y1="10" x2="23" y2="10" />
									</svg>
								</Icon>
							</BalanceInfoCard>
						</div>
					</div>
				</div>
			}
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<NavigationLock ConfirmExternalNavigation="@_isProcessing" />


@using Strada.Shared.Components.Card
@using StradaLibrary.Accounts.FinancialAccounting.Models
@using StradaLibrary.Accounts.Masters.Models

@attribute [Route(PageRouteNames.ProfitAndLossReport)]

<PageTitle>Profit & Loss - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.FinancialAccounting, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadProfitAndLoss" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadProfitAndLoss" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />

@if (_isLoading)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Profit & Loss">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.FinancialAccounting, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadProfitAndLoss" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="() => ToggleDetailsView()" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Accounting Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.FinancialAccountingReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Ledger Report" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.AccountingLedgerReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Bank Reconciliation" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.BankReconciliation, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Trial Balance" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.TrialBalanceReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Balance Sheet" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.BalanceSheetReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<!-- Date Range -->
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<!-- Company -->
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="All Companies"
												Label="Company" Required="false"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@PageRouteNames.CompanyMaster" />
						</div>
					</div>

				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<div class="section-body grid-body">
					<div class="dual-grid-container">
						<!-- Income Grid -->
						<div class="grid-section income-section">
							<div class="grid-section-header">
								<h3 class="grid-section-title">Income</h3>
								<span class="grid-section-count">(@_incomeTrialBalance.Count ledgers)</span>
							</div>
							<SfGrid @ref="_incomeGrid" TValue="TrialBalanceModel" DataSource="_incomeTrialBalance"
									AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
									AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
									GridLines="GridLine.Horizontal" CssClass="professional-grid"
									Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

								<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
								<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

								<GridAggregates>
									<GridAggregate>
										<GridAggregateColumns>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.LedgerName)" Type="AggregateType.Count">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
													}
													<div class="aggregate-label">
														<strong>Total: @aggregate.Count</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.OpeningBalance)" Type="AggregateType.Sum" Format="N2">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														<div class="aggregate-value aggregate-credit">
															<strong>@aggregate.Sum</strong>
														</div>
													}
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.Credit)" Type="AggregateType.Sum" Format="N2">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														<div class="aggregate-value aggregate-credit">
															<strong>@aggregate.Sum</strong>
														</div>
													}
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.ClosingBalance)" Type="AggregateType.Sum" Format="N2">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														<div class="aggregate-value aggregate-credit">
															<strong>@aggregate.Sum</strong>
														</div>
													}
												</FooterTemplate>
											</GridAggregateColumn>
										</GridAggregateColumns>
									</GridAggregate>
								</GridAggregates>

								<GridColumns>
									<GridColumn Field="@nameof(TrialBalanceModel.LedgerName)" HeaderText="Ledger Name" Width="250" />
									<GridColumn Field="@nameof(TrialBalanceModel.GroupName)" HeaderText="Group" Width="150" Visible="_showAllColumns" />
									<GridColumn Field="@nameof(TrialBalanceModel.OpeningBalance)" HeaderText="Opening Balance" Width="140" TextAlign="TextAlign.Right" Visible="_showAllColumns">
										<Template>
											@{
												var item = (context as TrialBalanceModel);
												<span class="grid-credit">@item.OpeningBalance.ToString("N2")</span>
											}
										</Template>
									</GridColumn>
									<GridColumn Field="@nameof(TrialBalanceModel.Credit)" HeaderText="Period Credit" Width="140" TextAlign="TextAlign.Right" Visible="_showAllColumns">
										<Template>
											@{
												var item = (context as TrialBalanceModel);
												<span class="grid-credit">@item.Credit.ToString("N2")</span>
											}
										</Template>
									</GridColumn>
									<GridColumn Field="@nameof(TrialBalanceModel.ClosingBalance)" HeaderText="Closing Balance" Width="140" TextAlign="TextAlign.Right">
										<Template>
											@{
												var item = (context as TrialBalanceModel);
												<span class="grid-credit">@item.ClosingBalance.ToString("N2")</span>
											}
										</Template>
									</GridColumn>
								</GridColumns>
							</SfGrid>
						</div>

						<!-- Expense Grid -->
						<div class="grid-section expense-section">
							<div class="grid-section-header">
								<h3 class="grid-section-title">Expenses</h3>
								<span class="grid-section-count">(@_expenseTrialBalance.Count ledgers)</span>
							</div>
							<SfGrid @ref="_expenseGrid" TValue="TrialBalanceModel" DataSource="_expenseTrialBalance"
									AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
									AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
									GridLines="GridLine.Horizontal" CssClass="professional-grid"
									Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

								<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
								<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

								<GridAggregates>
									<GridAggregate>
										<GridAggregateColumns>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.LedgerName)" Type="AggregateType.Count">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
													}
													<div class="aggregate-label">
														<strong>Total: @aggregate.Count</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.OpeningBalance)" Type="AggregateType.Sum" Format="N2">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														<div class="aggregate-value aggregate-debit">
															<strong>@aggregate.Sum</strong>
														</div>
													}
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.Debit)" Type="AggregateType.Sum" Format="N2">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														<div class="aggregate-value aggregate-debit">
															<strong>@aggregate.Sum</strong>
														</div>
													}
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TrialBalanceModel.ClosingBalance)" Type="AggregateType.Sum" Format="N2">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														<div class="aggregate-value aggregate-debit">
															<strong>@aggregate.Sum</strong>
														</div>
													}
												</FooterTemplate>
											</GridAggregateColumn>
										</GridAggregateColumns>
									</GridAggregate>
								</GridAggregates>

								<GridColumns>
									<GridColumn Field="@nameof(TrialBalanceModel.LedgerName)" HeaderText="Ledger Name" Width="250" />
									<GridColumn Field="@nameof(TrialBalanceModel.GroupName)" HeaderText="Group" Width="150" Visible="_showAllColumns" />
									<GridColumn Field="@nameof(TrialBalanceModel.OpeningBalance)" HeaderText="Opening Balance" Width="140" TextAlign="TextAlign.Right" Visible="_showAllColumns">
										<Template>
											@{
												var item = (context as TrialBalanceModel);
												<span class="grid-debit">@item.OpeningBalance.ToString("N2")</span>
											}
										</Template>
									</GridColumn>
									<GridColumn Field="@nameof(TrialBalanceModel.Debit)" HeaderText="Period Debit" Width="140" TextAlign="TextAlign.Right" Visible="_showAllColumns">
										<Template>
											@{
												var item = (context as TrialBalanceModel);
												<span class="grid-debit">@item.Debit.ToString("N2")</span>
											}
										</Template>
									</GridColumn>
									<GridColumn Field="@nameof(TrialBalanceModel.ClosingBalance)" HeaderText="Closing Balance" Width="140" TextAlign="TextAlign.Right">
										<Template>
											@{
												var item = (context as TrialBalanceModel);
												<span class="grid-debit">@item.ClosingBalance.ToString("N2")</span>
											}
										</Template>
									</GridColumn>
								</GridColumns>
							</SfGrid>
						</div>
					</div>
				</div>
			</div>

			<!-- Summary Section -->
			<div class="section-card profit-loss-summary">
				<div class="section-header">
					<h2 class="section-title">Profit & Loss Summary</h2>
				</div>
				<div class="section-body">
					<div class="profit-loss-grid">
						@{
							var totalIncome = _incomeTrialBalance.Sum(x => x.ClosingBalance);
							var totalExpense = _expenseTrialBalance.Sum(x => x.ClosingBalance);
							var profitLoss = totalIncome - totalExpense;
							var isProfitable = profitLoss >= 0;
						}

						<!-- Total Income Card -->
						<BalanceInfoCard Label="Total Income" Value="@($"₹{totalIncome:N2}")"
										 Breakdown="@($"{_incomeTrialBalance.Count} ledgers")"
										 Variant="BalanceInfoCard.CardVariant.Income">
							<Icon>
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
									 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
									 stroke-linejoin="round">
									<line x1="12" y1="19" x2="12" y2="5" />
									<polyline points="5 12 12 5 19 12" />
								</svg>
							</Icon>
						</BalanceInfoCard>

						<!-- Total Expenses Card -->
						<BalanceInfoCard Label="Total Expenses" Value="@($"₹{totalExpense:N2}")"
										 Breakdown="@($"{_expenseTrialBalance.Count} ledgers")"
										 Variant="BalanceInfoCard.CardVariant.Expense">
							<Icon>
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
									 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
									 stroke-linejoin="round">
									<line x1="12" y1="5" x2="12" y2="19" />
									<polyline points="19 12 12 19 5 12" />
								</svg>
							</Icon>
						</BalanceInfoCard>

						<!-- Net Profit/Loss Card -->
						<BalanceInfoCard Label="@(isProfitable ? "Net Profit" : "Net Loss")"
										 Value="@($"₹{Math.Abs(profitLoss):N2}")"
										 Breakdown="@(totalIncome > 0 ? $"Margin: {((profitLoss / totalIncome) * 100):N2}%" : "")"
										 Variant="@(isProfitable ? BalanceInfoCard.CardVariant.Profit : BalanceInfoCard.CardVariant.Loss)">
							<Icon>
								@if (isProfitable)
								{
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
										 stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12" />
									</svg>
								}
								else
								{
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
										 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
										 stroke-linejoin="round">
										<line x1="18" y1="6" x2="6" y2="18" />
										<line x1="6" y1="6" x2="18" y2="18" />
									</svg>
								}
							</Icon>
						</BalanceInfoCard>
					</div>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />

<style>
	.dual-grid-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 24px;
		padding: 24px;
	}

	/* Profit & Loss Summary Section */
	.profit-loss-summary {
		background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
	}

	.profit-loss-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 14px;
	}
</style>

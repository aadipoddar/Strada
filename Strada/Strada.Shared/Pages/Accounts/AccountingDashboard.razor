@attribute [Route(PageRouteNames.AccountsDashboard)]

<PageTitle>Accounting - Vectus</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => NavigationManager.NavigateTo(PageRouteNames.Dashboard)" />

@if (_isLoading || _user is null)
{
    <LoadingScreen />
}
else
{
    <div class="page-shell">
        <Header Title="Accounting Dashboard" />

        <!-- Main Content Container -->
        <div class="page-container">

            <!-- Entry Pages Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                        <h2 class="section-title">Entry Pages</h2>
                    </div>
                    <p class="section-subtitle">Record financial transactions and accounting entries</p>
                </div>
                <div class="section-body">
                    <div class="dashboard-grid">
                        <!-- Financial Accounting -->
                        <FileCard Title="Financial Accounting" Description="Record journal entries and transactions"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialAccounting)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <line x1="12" y1="1" x2="12" y2="23" />
                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                                </svg>
                            </IconContent>
                        </FileCard>
                    </div>
                </div>
            </div>

            <!-- Reports Section -->
            @if (_user.Reports)
            {
                <div class="section-card">
                    <div class="section-header">
                        <div class="section-title-wrapper">
                            <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14 2 14 8 20 8" />
                                <line x1="16" y1="13" x2="8" y2="13" />
                                <line x1="16" y1="17" x2="8" y2="17" />
                                <line x1="12" y1="18" x2="12" y2="12" />
                            </svg>
                            <h2 class="section-title">Financial Reports</h2>
                        </div>
                        <p class="section-subtitle">View and analyze accounting and financial reports</p>
                    </div>
                    <div class="section-body">
                        <div class="dashboard-grid">
                            <!-- Financial Accounting Report -->
                            <FileCard Title="Financial Accounting Report" Description="View accounting transaction history"
                                        OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialAccountingReport)">
                                <IconContent>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                                    </svg>
                                </IconContent>
                            </FileCard>

                            <!-- Ledger Report -->
                            <FileCard Title="Ledger Report" Description="View detailed ledger transactions"
                                        OnClick="() => NavigationManager.NavigateTo(PageRouteNames.AccountingLedgerReport)">
                                <IconContent>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                                    </svg>
                                </IconContent>
                            </FileCard>

                            <!-- Trial Balance -->
                            <FileCard Title="Trial Balance" Description="View trial balance summary"
                                        OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TrialBalanceReport)">
                                <IconContent>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                                        <line x1="8" y1="21" x2="16" y2="21" />
                                        <line x1="12" y1="17" x2="12" y2="21" />
                                        <line x1="7" y1="7" x2="7" y2="11" />
                                        <line x1="12" y1="7" x2="12" y2="11" />
                                        <line x1="17" y1="7" x2="17" y2="11" />
                                    </svg>
                                </IconContent>
                            </FileCard>

                            <!-- Profit & Loss -->
                            <FileCard Title="Profit & Loss" Description="View income and expense summary"
                                        OnClick="() => NavigationManager.NavigateTo(PageRouteNames.ProfitAndLossReport)">
                                <IconContent>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <line x1="12" y1="1" x2="12" y2="23" />
                                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                                    </svg>
                                </IconContent>
                            </FileCard>

                            <!-- Balance Sheet -->
                            <FileCard Title="Balance Sheet" Description="View assets, liabilities & equity"
                                        OnClick="() => NavigationManager.NavigateTo(PageRouteNames.BalanceSheetReport)">
                                <IconContent>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <line x1="12" y1="3" x2="12" y2="21" />
                                        <line x1="3" y1="6" x2="21" y2="6" />
                                        <path d="M5 6L3 12h4L5 6" />
                                        <path d="M19 6l-2 6h4l-2-6" />
                                        <line x1="7" y1="21" x2="17" y2="21" />
                                    </svg>
                                </IconContent>
                            </FileCard>
                        </div>
                    </div>
                </div>
            }

            <!-- Master Pages Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        <h2 class="section-title">Master Data</h2>
                    </div>
                    <p class="section-subtitle">Manage accounting configuration and master data</p>
                </div>
                <div class="section-body">
                    <div class="dashboard-grid">
                        <!-- Ledgers -->
                        <FileCard Title="Ledgers" Description="Manage ledger accounts"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.LedgerMaster)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                    <polyline points="14 2 14 8 20 8" />
                                    <line x1="16" y1="13" x2="8" y2="13" />
                                    <line x1="16" y1="17" x2="8" y2="17" />
                                    <line x1="10" y1="9" x2="8" y2="9" />
                                </svg>
                            </IconContent>
                        </FileCard>

                        <!-- Group -->
                        <FileCard Title="Group" Description="Manage account groups"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.GroupMaster)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                    <circle cx="9" cy="7" r="4" />
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                                </svg>
                            </IconContent>
                        </FileCard>

                        <!-- Account Type -->
                        <FileCard Title="Account Type" Description="Manage account types"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.AccountTypeMaster)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                                </svg>
                            </IconContent>
                        </FileCard>

                        <!-- Voucher -->
                        <FileCard Title="Voucher" Description="Manage voucher types"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VoucherMaster)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                    <polyline points="14 2 14 8 20 8" />
                                    <line x1="12" y1="18" x2="12" y2="12" />
                                    <line x1="9" y1="15" x2="15" y2="15" />
                                </svg>
                            </IconContent>
                        </FileCard>

                        <!-- Financial Years -->
                        <FileCard Title="Financial Years" Description="Manage financial year periods"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialYearMaster)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                    <line x1="16" y1="2" x2="16" y2="6" />
                                    <line x1="8" y1="2" x2="8" y2="6" />
                                    <line x1="3" y1="10" x2="21" y2="10" />
                                </svg>
                            </IconContent>
                        </FileCard>

                        <!-- States -->
                        <FileCard Title="States" Description="Manage state/UT information"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.StateUTMaster)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="2" y1="12" x2="22" y2="12" />
                                    <path
                                    d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                                </svg>
                            </IconContent>
                        </FileCard>

                        <!-- Company -->
                        <FileCard Title="Company" Description="Manage company settings"
                                    OnClick="() => NavigationManager.NavigateTo(PageRouteNames.CompanyMaster)">
                            <IconContent>
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                    <polyline points="9 22 9 12 15 12 15 22" />
                                </svg>
                            </IconContent>
                        </FileCard>
                    </div>
                </div>
            </div>

        </div>

        <Footer />
    </div>
}

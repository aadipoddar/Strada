@using Strada.Library.Accounts.Masters.Models

@attribute [Route(AccountRouteNames.LedgerMaster)]

<PageTitle>Ledger Management - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Ledger Management">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Master Details</h2>
				</div>

				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @ref="_firstFocus"
											 @bind-Value="_ledger.Name"
											 Label="Name (Ctrl + F)"
											 Placeholder="Enter Ledger Name" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.Code"
											 Label="Code"
											 Placeholder="Auto-generated"
											 ReadOnly="true"
											 TabIndex="-1" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="GroupModel"
												@bind-Value="_selectedGroup"
												DataSource="@_groups"
												Placeholder="Select Group"
												Label="Group"
												FieldValue="@nameof(GroupModel.Name)"
												AddNewRoute="@AccountRouteNames.GroupMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="AccountTypeModel"
												@bind-Value="_selectedAccountType"
												DataSource="@_accountTypes"
												Placeholder="Select Account Type"
												Label="Account Type"
												FieldValue="@nameof(AccountTypeModel.Name)"
												AddNewRoute="@AccountRouteNames.AccountTypeMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="StateUTModel"
												@bind-Value="_selectedStateUT"
												DataSource="@_stateUTs"
												Placeholder="Select State/UT"
												Label="State/UT"
												FieldValue="@nameof(StateUTModel.Name)"
												AddNewRoute="@AccountRouteNames.StateUTMaster" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.GSTNo"
											 Label="GST No"
											 Placeholder="Enter GST No"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.PANNo"
											 Label="PAN No"
											 Placeholder="Enter PAN No"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.CINNo"
											 Label="CIN No"
											 Placeholder="Enter CIN No"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.Alias"
											 Label="Alias"
											 Placeholder="Enter Alias"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.Phone"
											 Label="Phone"
											 Placeholder="Enter Phone"
											 Required="false"
											 MaxLength="10" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.Email"
											 Label="Email"
											 Placeholder="Enter Email"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.Address"
											 Label="Address"
											 Placeholder="Enter Address"
											 Required="false"
											 Lines="2" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_ledger.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Master List</h2>
				</div>

				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_ledgers"
							AllowPaging="true" AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridEvents TValue="LedgerModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridColumns>
							<GridColumn Field="@nameof(LedgerModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(LedgerModel.Name)" HeaderText="Ledger Name" Width="250" />
							<GridColumn Field="@nameof(LedgerModel.Code)" HeaderText="Code" Width="120" />
							<GridColumn Field="@nameof(LedgerModel.GroupId)" HeaderText="Group" Width="120">
								<Template>
									@{
										var item = (context as LedgerModel);
										var group = _groups.FirstOrDefault(g => g.Id == item.GroupId);
										<span>@(group != null ? group.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(LedgerModel.AccountTypeId)" HeaderText="Account Type" Width="150">
								<Template>
									@{
										var item = (context as LedgerModel);
										var accountType = _accountTypes.FirstOrDefault(a => a.Id == item.AccountTypeId);
										<span>@(accountType != null ? accountType.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(LedgerModel.Phone)" HeaderText="Phone" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.Email)" HeaderText="Email" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.Alias)" HeaderText="Alias" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.GSTNo)" HeaderText="GST No" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.CINNo)" HeaderText="CIN No" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.PANNo)" HeaderText="PAN No" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.Address)" HeaderText="Address" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.Remarks)" HeaderText="Remarks" Width="150" />
							<GridColumn Field="@nameof(LedgerModel.Status)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as LedgerModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />

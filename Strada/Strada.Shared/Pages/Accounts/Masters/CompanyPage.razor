@attribute [Route(PageRouteNames.CompanyMaster)]

@using StradaLibrary.Models.Accounts.Masters

<PageTitle>Company Management - Strada</PageTitle>

@if (_isLoading || _user is null)
{
    <AnimatedLoader Visible="true" />
}
else
{
    <div class="page-shell">
        <Header Title="Company Management">
            <LeftContent>
                <SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
                    <MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
                                           Easing="ease" />
                    <MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
                    <MenuItems>
                        <MenuItem Text="File" IconCss="e-icons e-folder">
                            <MenuItems>
                                <MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash"
                                          Id="ToggleDeleted" Disabled="@_isProcessing" />
                                <MenuItem Separator="true" />
                                <MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
                                          Disabled="@_isProcessing" />
                            </MenuItems>
                        </MenuItem>
                        <MenuItem Text="Transaction" IconCss="e-icons e-chart">
                            <MenuItems>
                                <MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelectedItem"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelectedItem"
                                          Disabled="@_isProcessing" />
                            </MenuItems>
                        </MenuItem>
                    </MenuItems>
                </SfMenu>
            </LeftContent>
            <RightContent>
                <IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
            </RightContent>
        </Header>

        <!-- Main Content Container -->
        <div class="page-container">

            <!-- Company Entry Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
                        </svg>
                        <h2 class="section-title">Company Details</h2>
                    </div>
                </div>
                <div class="section-body">
                    <div class="form-grid">
                        <!-- Company Name -->
                        <div class="form-field">
                            <label class="field-label">
                                Company Name <span class="required">*</span>
                            </label>
                            <SfTextBox @bind-Value="_company.Name" Placeholder="Enter company name"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Code -->
                        <div class="form-field">
                            <label class="field-label">
                                Code <span class="required">*</span>
                            </label>
                            <SfTextBox @bind-Value="_company.Code" Placeholder="Enter code"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- State/UT -->
                        <div class="form-field">
                            <label class="field-label">
                                State/UT <span class="required">*</span>
                            </label>
                            <SfDropDownList TValue="int" TItem="StateUTModel" Placeholder="Select State/UT"
                                            DataSource="@_stateUTs" @bind-Value="_company.StateUTId"
                                            FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox">
                                <DropDownListFieldSettings Text="Name" Value="Id" />
                            </SfDropDownList>
                        </div>

                        <!-- GST No -->
                        <div class="form-field">
                            <label class="field-label">GST No</label>
                            <SfTextBox @bind-Value="_company.GSTNo" Placeholder="Enter GST No"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- PAN No -->
                        <div class="form-field">
                            <label class="field-label">PAN No</label>
                            <SfTextBox @bind-Value="_company.PANNo" Placeholder="Enter PAN No"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- CIN No -->
                        <div class="form-field">
                            <label class="field-label">CIN No</label>
                            <SfTextBox @bind-Value="_company.CINNo" Placeholder="Enter CIN No"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Alias -->
                        <div class="form-field">
                            <label class="field-label">Alias</label>
                            <SfTextBox @bind-Value="_company.Alias" Placeholder="Enter Alias"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Phone -->
                        <div class="form-field">
                            <label class="field-label">Phone</label>
                            <SfTextBox @bind-Value="_company.Phone" Placeholder="Enter Phone"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Email -->
                        <div class="form-field">
                            <label class="field-label">Email</label>
                            <SfTextBox @bind-Value="_company.Email" Placeholder="Enter Email"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Address -->
                        <div class="form-field">
                            <label class="field-label">Address</label>
                            <SfTextBox @bind-Value="_company.Address" Placeholder="Enter Address" Multiline="true"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Remarks -->
                        <div class="form-field">
                            <label class="field-label">Remarks</label>
                            <SfTextBox @bind-Value="_company.Remarks" Placeholder="Enter remarks (optional)"
                                       Multiline="true" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Companies List Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <path d="M9 11l3 3L22 4" />
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                        </svg>
                        <h2 class="section-title">Companies List</h2>
                    </div>
                </div>
                <div class="section-body grid-body">
                    <SfGrid @ref="_sfGrid" DataSource="@_companies" AllowPaging="true" AllowSorting="true"
                            AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
                            Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
                        <GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
                        <GridEvents TValue="CompanyModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
                        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                        <GridColumns>
                            <GridColumn Field="@nameof(CompanyModel.Id)" HeaderText="ID" Width="80"
                                        TextAlign="TextAlign.Center" />
                            <GridColumn Field="@nameof(CompanyModel.Name)" HeaderText="Company Name" Width="250" />
                            <GridColumn Field="@nameof(CompanyModel.Alias)" HeaderText="Alias" Width="150" />
                            <GridColumn Field="@nameof(CompanyModel.Code)" HeaderText="Code" Width="120" />
                            <GridColumn Field="@nameof(CompanyModel.Phone)" HeaderText="Phone" Width="150" />
                            <GridColumn Field="@nameof(CompanyModel.Email)" HeaderText="Email" Width="150" />
                            <GridColumn Field="@nameof(CompanyModel.GSTNo)" HeaderText="GST No" Width="150" />
                            <GridColumn Field="@nameof(CompanyModel.CINNo)" HeaderText="CIN No" Width="150" />
                            <GridColumn Field="@nameof(CompanyModel.PANNo)" HeaderText="PAN No" Width="150" />
                            <GridColumn Field="@nameof(CompanyModel.Address)" HeaderText="Address" Width="200" />
                            <GridColumn Field="@nameof(CompanyModel.Remarks)" HeaderText="Remarks" Width="200" />
                            <GridColumn Field="@nameof(CompanyModel.Status)" HeaderText="Status" Width="110"
                                        TextAlign="TextAlign.Center" Visible="_showDeleted">
                                <Template>
                                    @{
                                        var item = (context as CompanyModel);
                                        <span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
                                    }
                                </Template>
                            </GridColumn>
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>

        <Footer />
    </div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Company" IdentifierLabel="Company Name"
                          IdentifierValue="@_deleteTransactionName" Disabled="@_isProcessing" OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Company" IdentifierLabel="Company Name"
                           IdentifierValue="@_recoverTransactionName" Disabled="@_isProcessing" OnConfirm="ConfirmRecover"
                           OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />

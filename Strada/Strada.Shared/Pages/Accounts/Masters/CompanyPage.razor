@using StradaLibrary.Accounts.Masters.Models

@attribute [Route(PageRouteNames.CompanyMaster)]

<PageTitle>Company Management - Vectus</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Company Management">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash" Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel" Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelectedItem" Disabled="@_isProcessing" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Company Entry Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">Company Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- Company Name -->
						<div class="form-field">
							<CustomTextField @ref="_sfFirstFocus"
											 @bind-Value="_company.Name"
											 Label="Company Name"
											 Placeholder="Enter company name (Ctrl + F)" />
						</div>

						<!-- Code -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.Code"
											 Label="Code"
											 Placeholder="Enter code" />
						</div>

						<!-- State/UT -->
						<div class="form-field">
							<CustomAutoComplete T="StateUTModel"
												Value="_selectedStateUT"
												DataSource="@_stateUTs"
												Placeholder="Select State/UT"
												Label="State/UT" Required="true"
												ValueChanged="OnStateUTChanged"
												FieldValue="@nameof(StateUTModel.Name)"
												AddNewRoute="@PageRouteNames.StateUTMaster" />
						</div>

						<!-- GST No -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.GSTNo"
											 Label="GST No"
											 Placeholder="Enter GST No"
											 Required="false" />
						</div>

						<!-- PAN No -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.PANNo"
											 Label="PAN No"
											 Placeholder="Enter PAN No"
											 Required="false" />
						</div>

						<!-- CIN No -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.CINNo"
											 Label="CIN No"
											 Placeholder="Enter CIN No"
											 Required="false" />
						</div>

						<!-- Alias -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.Alias"
											 Label="Alias"
											 Placeholder="Enter Alias"
											 Required="false" />
						</div>

						<!-- Phone -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.Phone"
											 Label="Phone"
											 Placeholder="Enter Phone"
											 Required="false" />
						</div>

						<!-- Email -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.Email"
											 Label="Email"
											 Placeholder="Enter Email"
											 Required="false" />
						</div>

						<!-- Address -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.Address"
											 Label="Address"
											 Placeholder="Enter Address"
											 Required="false"
											 Lines="2" />
						</div>

						<!-- Remarks -->
						<div class="form-field">
							<CustomTextField @bind-Value="_company.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<!-- Companies List Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Companies List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_companies" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="CompanyModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(CompanyModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(CompanyModel.Name)" HeaderText="Company Name" Width="250" />
							<GridColumn Field="@nameof(CompanyModel.Alias)" HeaderText="Alias" Width="150" />
							<GridColumn Field="@nameof(CompanyModel.Code)" HeaderText="Code" Width="120" />
							<GridColumn Field="@nameof(CompanyModel.Phone)" HeaderText="Phone" Width="150" />
							<GridColumn Field="@nameof(CompanyModel.Email)" HeaderText="Email" Width="150" />
							<GridColumn Field="@nameof(CompanyModel.GSTNo)" HeaderText="GST No" Width="150" />
							<GridColumn Field="@nameof(CompanyModel.CINNo)" HeaderText="CIN No" Width="150" />
							<GridColumn Field="@nameof(CompanyModel.PANNo)" HeaderText="PAN No" Width="150" />
							<GridColumn Field="@nameof(CompanyModel.Address)" HeaderText="Address" Width="200" />
							<GridColumn Field="@nameof(CompanyModel.Remarks)" HeaderText="Remarks" Width="200" />
							<GridColumn Field="@nameof(CompanyModel.Status)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as CompanyModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" IdentifierValue="@_deleteTransactionName"
						  OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" IdentifierValue="@_recoverTransactionName"
						   OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />

@attribute [Route(PageRouteNames.Trip)]
@attribute [Route(PageRouteNames.Trip + "/{Id:int}")]

@using StradaLibrary.Accounts.Masters.Models
@using StradaLibrary.Fleet.OMC.Models
@using StradaLibrary.Fleet.Vehicle.Models
@using StradaLibrary.Fleet.Route.Models
@using StradaLibrary.Fleet.Trip.Models

<PageTitle>Trip - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfExpenseTypeAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfOMCCardAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfLedgerAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddExpensesToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportPdfInvoice" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportExcelInvoice" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.TripReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedExpensesCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedExpensesCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_trip.Id > 0 ? $"Edit Trip {_trip.TransactionNo}" : "Create Trip")">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="Save & PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="SavePdfInvoice" Disabled="@_isProcessing" />
								<MenuItem Text="Save & Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="SaveExcelInvoice" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="ExportPdfInvoice" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel" Id="ExportExcelInvoice" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Open" IconCss="e-icons e-folder-open">
							<MenuItems>
								<MenuItem Text="Trip Report (Ctrl + H)" Id="TripReport" Disabled="@_isProcessing" />
								<MenuItem Text="Expenses Report" Id="ExpensesReport" Disabled="@_isProcessing" />
								<MenuItem Text="Card Payments Report" Id="CardPaymentsReport" Disabled="@_isProcessing" />
								<MenuItem Text="Ledger Payments Report" Id="LedgerPaymentsReport" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">


			<div class="four-column-layout">

				<!-- Transaction Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="16" y1="13" x2="8" y2="13" />
								<line x1="16" y1="17" x2="8" y2="17" />
								<polyline points="10 9 9 9 8 9" />
							</svg>
							<h2 class="section-title">Transaction Summary</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Vehicle -->
							<div class="form-field">
								<CustomAutoComplete @ref="_sfFirstFocus" T="VehicleModel"
													Value="_selectedVehicle"
													DataSource="@_vehicles"
													Placeholder="Select a Vehicle"
													Label="Vehicle (Ctrl + F)"
													ValueChanged="OnVehicleChanged"
													FieldValue="@nameof(VehicleModel.Code)"
													AddNewRoute="@PageRouteNames.VehicleMaster" />
							</div>

							<!-- Sl No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_trip.SlNo"
												 Label="Sl No"
												 Placeholder="Enter Sl No..."
												 Required="false" />
							</div>

							<!-- Transaction Date -->
							<div class="form-field">
								<CustomDatePicker Value="_trip.TransactionDateTime"
												  ValueChanged="OnTransactionDateChanged"
												  FinancialYear="@_selectedFinancialYear" />
							</div>

							<!-- Route -->
							<div class="form-field">
								<CustomAutoComplete T="RouteOverviewModel"
													Value="_selectedRoute"
													DataSource="@_routes"
													Placeholder="Select a Route"
													Label="Route"
													ValueChanged="OnRouteChanged"
													FieldValue="@nameof(RouteOverviewModel.RouteDisplay)"
													AddNewRoute="@PageRouteNames.RouteMaster" />
							</div>

							<!-- Driver -->
							<div class="form-field">
								<CustomAutoComplete T="DriverOverviewModel"
													Value="_selectedDriver"
													DataSource="@_drivers"
													Placeholder="Select a Driver"
													Label="Driver"
													ValueChanged="OnDriverChanged"
													FieldValue="@nameof(DriverOverviewModel.DisplayName)"
													AddNewRoute="@PageRouteNames.DriverMaster" />
							</div>

							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete T="CompanyModel"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="Select a Company"
													Label="Company"
													ValueChanged="OnCompanyChanged"
													FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@PageRouteNames.CompanyMaster" />
							</div>

							<!-- OMC -->
							<div class="form-field">
								<CustomAutoComplete T="OMCModel"
													Value="_selectedOMC"
													DataSource="@_omcs"
													Placeholder="Select an OMC"
													Label="OMC"
													ValueChanged="OnOMCChanged"
													FieldValue="@nameof(OMCModel.Name)"
													AddNewRoute="@PageRouteNames.OMCMaster" />
							</div>

							<!-- Empty -->
							<div class="form-field">
								<div class="checkbox-wrapper">
									<CustomCheckBox @bind-Value="_trip.VehicleEmpty"
													Label="Vehicle Empty"
													AriaLabel="Vehicle is empty" />
								</div>
							</div>

						</div>
					</div>
				</div>

				<!-- Financial Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23" />
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
							</svg>
							<h2 class="section-title">Financial Summary</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Challan No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_trip.ChallanNo"
												 Label="Challan No"
												 Placeholder="Enter Challan No..."
												 Required="false" />
							</div>

							<!-- Quantity -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													@bind-Value="_trip.Quantity"
													Label="Quantity"
													Placeholder="Enter Quantity" />
							</div>

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField Value="@_trip.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							<!-- Route Estimated Distance / Cost -->
							<div class="form-field">
								<label class="field-label">
									Estimated Distance / Cost
								</label>
								<div class="date-year-wrapper">
									<CustomNumericField T="int"
														@bind-Value="_selectedRoute.EstimatedDistance"
														Placeholder="Enter estimated distance..."
														Format="N0"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
									<CustomNumericField T="decimal"
														@bind-Value="_selectedRoute.EstimatedCost"
														Placeholder="Enter estimated cost..."
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Route Estimated Hours / Fuel -->
							<div class="form-field">
								<label class="field-label">
									Estimated Hours / Fuel
								</label>
								<div class="date-year-wrapper">
									<CustomNumericField T="int"
														@bind-Value="_selectedRoute.EstimatedHours"
														Placeholder="Enter estimated hours..."
														Format="N0"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
									<CustomNumericField T="int"
														@bind-Value="_selectedRoute.EstimatedFuelConsumption"
														Placeholder="Enter estimated fuel..."
														Format="N0"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Total Expense -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="@_trip.TotalExpense"
													Label="Total Expense"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<!-- Remarks -->
							<div class="form-field">
								<CustomTextField @bind-Value="_trip.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>

						</div>
					</div>
				</div>

				<!-- Card Payments Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
								<line x1="1" y1="10" x2="23" y2="10" />
							</svg>
							<h2 class="section-title">OMC Card Payments</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<!-- OMC Card -->
							<div class="cart-field cart-field-wide">
								<CustomAutoComplete T="OMCCardModel"
													@ref="_sfOMCCardAutoComplete"
													FieldValue="@nameof(OMCCardModel.CardNumber)" Value="_selectedOMCCard"
													DataSource="@_omcCards" Placeholder="Select OMC Card"
													ValueChanged="OnCardPaymentsTypeChanged" OpenOnFocus="false"
													Label="Card (Ctrl + Shift + F)" AddNewRoute="@PageRouteNames.OMCCardMaster" />
							</div>

							<!-- Amount -->
							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal"
													@bind-Value="_selectedCardPaymentCart.Amount"
													Min="0"
													Label="Amount"
													Placeholder="0.00" />
							</div>

							<!-- Remarks -->
							<div class="cart-field cart-field-wide">
								<CustomTextField @bind-Value="_selectedCardPaymentCart.Remarks"
												 Label="Remarks"
												 Placeholder="Item Narration..."
												 Required="false" />
							</div>

							<!-- Add Button -->
							<div class="cart-field cart-field-wide">
								<label class="cart-label">&nbsp;</label>
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add to Cart" OnClick="AddCardPaymentsToCart" />
							</div>
						</div>

						<SfGrid ID="_sfCartGrid" @ref="_sfCardPaymentsCartGrid" DataSource="_cardPaymentsCart"
								AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
								ContextMenuItems="@_cardPaymentsCartGridContextMenuItems">

							<GridEvents TValue="TripCardPaymentsCartModel" ContextMenuItemClicked="OnCardPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(TripCardPaymentsCartModel.OMCCardNumber)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Payment Types: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(TripCardPaymentsCartModel.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(TripCardPaymentsCartModel.OMCCardNumber)" HeaderText="Name" Width="200" />
								<GridColumn Field="@nameof(TripCardPaymentsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(TripCardPaymentsCartModel.Remarks)" HeaderText="Remarks" Width="150" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

				<!-- Ledger Payments Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
								<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
							</svg>
							<h2 class="section-title">Ledger Payments</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<div class="cart-field cart-field-wide">
								<CustomAutoComplete T="LedgerModel"
													@ref="_sfLedgerAutoComplete"
													FieldValue="@nameof(LedgerModel.Name)" Value="_selectedLedger"
													DataSource="@_ledgers" Placeholder="Select a Ledger"
													ValueChanged="OnLedgerPaymentsTypeChanged" OpenOnFocus="false"
													Label="Ledger (Ctrl + Shift + G)" AddNewRoute="@PageRouteNames.LedgerMaster" />
							</div>

							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal"
													@bind-Value="_selectedLedgerPaymentCart.Amount"
													Min="0"
													Label="Amount"
													Placeholder="0.00" />
							</div>

							<div class="cart-field cart-field-wide">
								<CustomTextField @bind-Value="_selectedLedgerPaymentCart.Remarks"
												 Label="Remarks"
												 Placeholder="Item Narration..."
												 Required="false" />
							</div>

							<div class="cart-field cart-field-wide">
								<label class="cart-label">&nbsp;</label>
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add Ledger Payment (Ctrl + Shift + Enter)" OnClick="AddLedgerPaymentsToCart" />
							</div>
						</div>

						<SfGrid @ref="_sfLedgerPaymentsCartGrid" DataSource="_ledgerPaymentsCart"
								AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
								ContextMenuItems="@_ledgerPaymentsCartGridContextMenuItems">

							<GridEvents TValue="TripLedgerPaymentsCartModel" ContextMenuItemClicked="OnLedgerPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(TripLedgerPaymentsCartModel.LedgerName)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Ledgers: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(TripLedgerPaymentsCartModel.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(TripLedgerPaymentsCartModel.LedgerName)" HeaderText="Ledger" Width="200" />
								<GridColumn Field="@nameof(TripLedgerPaymentsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(TripLedgerPaymentsCartModel.Remarks)" HeaderText="Remarks" Width="150" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

			</div>

			<!-- Add to Cart Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Expenses to Cart</h2>
					</div>
				</div>

				<div class="section-body">
					<div class="cart-input-row">
						<!-- Expense Type -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="ExpenseTypeModel"
												@ref="_sfExpenseTypeAutoComplete"
												FieldValue="@nameof(ExpenseTypeModel.Name)" Value="_selectedExpenseType"
												DataSource="@_expenseTypes" Placeholder="Select Expense Type"
												ValueChanged="OnExpensesTypeChanged" OpenOnFocus="false"
												Label="Expense Type (Ctrl + G)" AddNewRoute="@PageRouteNames.ExpenseTypeMaster" />
						</div>

						<!-- Amount -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												@bind-Value="_selectedExpensesCart.Amount"
												Min="0"
												Label="Amount"
												Placeholder="0.00" />
						</div>

						<!-- Remarks -->
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedExpensesCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<!-- Add Button -->
						<div class="cart-field">
							<label class="cart-label">&nbsp;</label>
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart"
										OnClick="AddExpensesToCart" />
						</div>
					</div>
				</div>

			</div>

			<!-- Expenses Cart Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Expenses Cart</h2>
					</div>
				</div>

				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfExpensesCartGrid" DataSource="_expensesCart" AllowTextWrap="true"
							AllowPaging="false" AllowSorting="true" AllowResizing="true" AllowFiltering="true"
							GridLines="GridLine.Horizontal" CssClass="professional-grid"
							ContextMenuItems="@_expensesCartGridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="TripExpensesCartModel" ContextMenuItemClicked="OnExpensesCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(TripExpensesCartModel.ExpenseTypeName)"
														 Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Expense Types: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesCartModel.Amount)"
														 Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(TripExpensesCartModel.ExpenseTypeName)" HeaderText="Name" Width="200" />
							<GridColumn Field="@nameof(TripExpensesCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Amount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(TripExpensesCartModel.Remarks)" HeaderText="Remarks" Width="150" />
						</GridColumns>

					</SfGrid>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<NavigationLock ConfirmExternalNavigation="@_isProcessing" />
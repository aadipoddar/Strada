@using Strada.Library.Accounts.Masters.Models
@using Strada.Library.Fleet.Expense.Models
@using Strada.Library.Fleet.OMC.Models
@using Strada.Library.Fleet.Route.Models
@using Strada.Library.Fleet.Trip.Models
@using Strada.Library.Fleet.Vehicle.Models

@attribute [Route(FleetRouteNames.Trip)]
@attribute [Route(FleetRouteNames.Trip + "/{Id:int}")]

<PageTitle>Trip - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfExpenseTypeAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfOMCCardAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfLedgerAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddExpensesToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(FleetRouteNames.TripReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedExpensesCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedExpensesCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_trip.Id > 0 ? $"Edit Trip {_trip.TransactionNo}" : "Create Trip")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Trip Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(FleetRouteNames.TripReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Expenses Report" OnClick="() => AuthenticationService.NavigateToRoute(FleetRouteNames.TripExpensesReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Card Payments Report" OnClick="() => AuthenticationService.NavigateToRoute(FleetRouteNames.TripCardPaymentsReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Ledger Payments Report" OnClick="() => AuthenticationService.NavigateToRoute(FleetRouteNames.TripLedgerPaymentsReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
			<RightContent>
				<RecheckSaveButton OnClick="() => SaveTransaction()" Disabled="@_isProcessing" />
			</RightContent>
		</Header>

		<div class="page-container">

			<div class="four-column-layout">

				<!-- Transaction -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Transaction</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Vehicle -->
							<div class="form-field">
								<CustomAutoComplete @ref="_firstFocus" T="VehicleModel"
													Value="_selectedVehicle"
													DataSource="@_vehicles"
													Placeholder="Select a Vehicle"
													Label="Vehicle (Ctrl + F)"
													ValueChanged="OnVehicleChanged"
													FieldValue="@nameof(VehicleModel.Code)"
													AddNewRoute="@FleetRouteNames.VehicleMaster" />
							</div>

							<!-- Sl No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_trip.SlNo"
												 Label="Sl No"
												 Placeholder="Enter Sl No..."
												 Required="true" />
							</div>

							<!-- Transaction Date -->
							<div class="form-field">
								<CustomDatePicker Value="_trip.TransactionDateTime"
												  ValueChanged="OnTransactionDateChanged"
												  FinancialYear="@_selectedFinancialYear" />
							</div>

							<!-- Route -->
							<div class="form-field">
								<CustomAutoComplete T="RouteOverviewModel"
													Value="_selectedRoute"
													DataSource="@_routes"
													Placeholder="Select a Route"
													Label="Route"
													ValueChanged="OnRouteChanged"
													FieldValue="@nameof(RouteOverviewModel.RouteDisplay)"
													AddNewRoute="@FleetRouteNames.RouteMaster" />
							</div>

							<!-- Driver -->
							<div class="form-field">
								<CustomAutoComplete T="DriverOverviewModel"
													Value="_selectedDriver"
													DataSource="@_drivers"
													Placeholder="Select a Driver"
													Label="Driver"
													ValueChanged="OnDriverChanged"
													FieldValue="@nameof(DriverOverviewModel.DisplayName)"
													AddNewRoute="@FleetRouteNames.DriverMaster" />
							</div>

							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete T="CompanyModel"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="Select a Company"
													Label="Company"
													ValueChanged="OnCompanyChanged"
													FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@AccountRouteNames.CompanyMaster" />
							</div>

							<!-- OMC -->
							<div class="form-field">
								<CustomAutoComplete T="OMCModel"
													Value="_selectedOMC"
													DataSource="@_omcs"
													Placeholder="Select an OMC"
													Label="OMC"
													ValueChanged="OnOMCChanged"
													FieldValue="@nameof(OMCModel.Name)"
													AddNewRoute="@FleetRouteNames.OMCMaster" />
							</div>

							<!-- Empty -->
							<div class="form-field">
								<div class="checkbox-wrapper">
									<CustomCheckBox @bind-Value="_trip.VehicleEmpty"
													Label="Vehicle Empty" />
								</div>
							</div>

						</div>
					</div>
				</div>

				<!-- Financial -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Financial</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Challan No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_trip.ChallanNo"
												 Label="Challan No"
												 Placeholder="Enter Challan No..."
												 Required="false" />
							</div>

							<!-- Quantity -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													@bind-Value="_trip.Quantity"
													Label="Quantity"
													Placeholder="Enter Quantity" />
							</div>

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField Value="@_trip.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							<!-- Route Estimated Distance / Cost -->
							<div class="form-field">
								<div class="date-year-wrapper">
									<CustomNumericField T="int"
														@bind-Value="_selectedRoute.EstimatedDistance"
														Placeholder="Estimated distance to Destination"
														Label="Estimated Distance"
														Format="N0"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
									<CustomNumericField T="decimal"
														@bind-Value="_selectedRoute.EstimatedCost"
														Placeholder="Estimated cost to Destination"
														Label="Estimated Cost"
														Format="N2"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Route Estimated Hours / Fuel -->
							<div class="form-field">
								<div class="date-year-wrapper">
									<CustomNumericField T="int"
														@bind-Value="_selectedRoute.EstimatedHours"
														Placeholder="Estimated hours to Destination"
														Label="Estimated Hours"
														Format="N0"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
									<CustomNumericField T="int"
														@bind-Value="_selectedRoute.EstimatedFuelConsumption"
														Placeholder="Estimated fuel consumption"
														Label="Estimated Fuel"
														Format="N0"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Total Expense -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="@_trip.TotalExpense"
													Label="Total Expense"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<!-- Remarks -->
							<div class="form-field">
								<CustomTextField @bind-Value="_trip.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>

						</div>
					</div>
				</div>

				<!-- OMC Card Payments -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">OMC Card Payments</h2>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<!-- OMC Card -->
							<div class="cart-field cart-field-wide">
								<CustomAutoComplete T="OMCCardModel"
													@ref="_sfOMCCardAutoComplete"
													FieldValue="@nameof(OMCCardModel.CardNumber)" Value="_selectedOMCCard"
													DataSource="@_omcCards" Placeholder="Select OMC Card"
													ValueChanged="OnCardPaymentsTypeChanged" OpenOnFocus="false"
													Label="Card (Ctrl + Shift + F)" AddNewRoute="@FleetRouteNames.OMCCardMaster" />
							</div>

							<!-- Amount -->
							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal"
													@bind-Value="_selectedCardPaymentCart.Amount"
													Min="0"
													Label="Amount"
													Placeholder="0.00" />
							</div>

							<!-- Remarks -->
							<div class="cart-field cart-field-wide">
								<CustomTextField @bind-Value="_selectedCardPaymentCart.Remarks"
												 Label="Remarks"
												 Placeholder="Item Narration..."
												 Required="false" />
							</div>

							<!-- Add Button -->
							<div class="cart-field cart-field-wide">
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add to Cart" OnClick="AddCardPaymentsToCart" />
							</div>
						</div>

						<SfGrid ID="_sfCartGrid" @ref="_sfCardPaymentsCartGrid" DataSource="_cardPaymentsCart"
								AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" AllowReordering="true"
								GridLines="GridLine.Horizontal" ContextMenuItems="@_cardPaymentsCartGridContextMenuItems" CssClass="professional-grid">

							<GridEvents TValue="TripCardPaymentsCartModel" ContextMenuItemClicked="OnCardPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(TripCardPaymentsCartModel.OMCCardNumber)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Payment Types: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(TripCardPaymentsCartModel.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(TripCardPaymentsCartModel.OMCCardNumber)" HeaderText="Name" Width="200" />
								<GridColumn Field="@nameof(TripCardPaymentsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(TripCardPaymentsCartModel.Remarks)" HeaderText="Remarks" Width="150" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

				<!-- Ledger Payments -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Ledger Payments</h2>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<div class="cart-field cart-field-wide">
								<CustomAutoComplete T="LedgerModel"
													@ref="_sfLedgerAutoComplete"
													FieldValue="@nameof(LedgerModel.Name)" Value="_selectedLedger"
													DataSource="@_ledgers" Placeholder="Select a Ledger"
													ValueChanged="OnLedgerPaymentsTypeChanged" OpenOnFocus="false"
													Label="Ledger (Ctrl + Shift + G)" AddNewRoute="@AccountRouteNames.LedgerMaster" />
							</div>

							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal"
													@bind-Value="_selectedLedgerPaymentCart.Amount"
													Min="0"
													Label="Amount"
													Placeholder="0.00" />
							</div>

							<div class="cart-field cart-field-wide">
								<CustomTextField @bind-Value="_selectedLedgerPaymentCart.Remarks"
												 Label="Remarks"
												 Placeholder="Item Narration..."
												 Required="false" />
							</div>

							<div class="cart-field cart-field-wide">
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add Ledger Payment (Ctrl + Shift + Enter)" OnClick="AddLedgerPaymentsToCart" />
							</div>
						</div>

						<SfGrid @ref="_sfLedgerPaymentsCartGrid" DataSource="_ledgerPaymentsCart"
								AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" AllowReordering="true"
								GridLines="GridLine.Horizontal" ContextMenuItems="@_ledgerPaymentsCartGridContextMenuItems" CssClass="professional-grid">

							<GridEvents TValue="TripLedgerPaymentsCartModel" ContextMenuItemClicked="OnLedgerPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(TripLedgerPaymentsCartModel.LedgerName)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Ledgers: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(TripLedgerPaymentsCartModel.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(TripLedgerPaymentsCartModel.LedgerName)" HeaderText="Ledger" Width="200" />
								<GridColumn Field="@nameof(TripLedgerPaymentsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(TripLedgerPaymentsCartModel.Remarks)" HeaderText="Remarks" Width="150" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

			</div>

			<!-- Add to Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Add Items to Cart</h2>
				</div>

				<div class="section-body">
					<div class="cart-input-row">
						<!-- Expense Type -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="ExpenseTypeModel"
												@ref="_sfExpenseTypeAutoComplete"
												FieldValue="@nameof(ExpenseTypeModel.Name)" Value="_selectedExpenseType"
												DataSource="@_expenseTypes" Placeholder="Select Expense Type"
												ValueChanged="OnExpensesTypeChanged" OpenOnFocus="false"
												Label="Expense Type (Ctrl + G)" AddNewRoute="@FleetRouteNames.ExpenseTypeMaster" />
						</div>

						<!-- Amount -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												@bind-Value="_selectedExpensesCart.Amount"
												Min="0"
												Label="Amount"
												Placeholder="0.00" />
						</div>

						<!-- Remarks -->
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedExpensesCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<!-- Add Button -->
						<div class="cart-field">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart"
										OnClick="AddExpensesToCart" />
						</div>
					</div>
				</div>

			</div>

			<!-- Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Cart</h2>
				</div>

				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfExpensesCartGrid" DataSource="_expensesCart"
							AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_expensesCartGridContextMenuItems" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridEvents TValue="TripExpensesCartModel" ContextMenuItemClicked="OnExpensesCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(TripExpensesCartModel.ExpenseTypeName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Expense Types: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesCartModel.Amount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(TripExpensesCartModel.ExpenseTypeName)" HeaderText="Name" Width="200" />
							<GridColumn Field="@nameof(TripExpensesCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Amount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(TripExpensesCartModel.Remarks)" HeaderText="Remarks" Width="150" />
						</GridColumns>

					</SfGrid>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
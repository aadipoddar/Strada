@using StradaLibrary.Accounts.Masters.Models
@using StradaLibrary.Fleet.OMC.Models
@using StradaLibrary.Fleet.Vehicle.Models
@using StradaLibrary.Fleet.Route.Models
@using StradaLibrary.Fleet.Trip.Models

@attribute [Route(PageRouteNames.TripExpensesReport)]

<PageTitle>Trip Expenses Report - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.Trip, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.TripReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ViewSelectedTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Trip Expenses Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.Trip, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadTransactionOverviews" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="ToggleDetailsView" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Trip Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.TripReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Card Payments Report" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.TripCardPaymentsReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Ledger Payments Report" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.TripLedgerPaymentsReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="View (Alt + O)" OnClick="ViewSelectedTransaction" />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedTransaction" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Filters Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
						</svg>
						<h2 class="section-title">Filters</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="filters-grid">
						<!-- Date Range -->
						<div class="form-field">
							<CustomDateRangePicker @ref="_sfFirstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<!-- Expense Type -->
						<div class="form-field">
							<CustomAutoComplete T="ExpenseTypeModel"
												Value="_selectedExpenseType"
												DataSource="@_expenseTypes"
												Placeholder="All Expense Types"
												Label="Expense Type" Required="false"
												ValueChanged="OnExpenseTypeChanged"
												FieldValue="@nameof(ExpenseTypeModel.Name)"
												AddNewRoute="@PageRouteNames.ExpenseTypeMaster" />
						</div>

						<!-- Company -->
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="All Companies"
												Label="Company" Required="false"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@PageRouteNames.CompanyMaster" />
						</div>

						<!-- OMC -->
						<div class="form-field">
							<CustomAutoComplete T="OMCModel"
												Value="_selectedOMC"
												DataSource="@_omcs"
												Placeholder="All OMCs"
												Label="OMC" Required="false"
												ValueChanged="OnOMCChanged"
												FieldValue="@nameof(OMCModel.Name)"
												AddNewRoute="@PageRouteNames.OMCMaster" />
						</div>

						<!-- Vehicle -->
						<div class="form-field">
							<CustomAutoComplete T="VehicleModel"
												Value="_selectedVehicle"
												DataSource="@_vehicles"
												Placeholder="All Vehicles"
												Label="Vehicle" Required="false"
												ValueChanged="OnVehicleChanged"
												FieldValue="@nameof(VehicleModel.Code)"
												AddNewRoute="@PageRouteNames.VehicleMaster" />
						</div>

						<!-- Route -->
						<div class="form-field">
							<CustomAutoComplete T="RouteOverviewModel"
												Value="_selectedRoute"
												DataSource="@_routes"
												Placeholder="All Routes"
												Label="Route" Required="false"
												ValueChanged="OnRouteChanged"
												FieldValue="@nameof(RouteOverviewModel.RouteDisplay)"
												AddNewRoute="@PageRouteNames.RouteMaster" />
						</div>

						<!-- Driver -->
						<div class="form-field">
							<CustomAutoComplete T="DriverOverviewModel"
												Value="_selectedDriver"
												DataSource="@_drivers"
												Placeholder="All Drivers"
												Label="Driver" Required="false"
												ValueChanged="OnDriverChanged"
												FieldValue="@nameof(DriverOverviewModel.DisplayName)"
												AddNewRoute="@PageRouteNames.DriverMaster" />
						</div>

						<!-- Vehicle Empty -->
						<div class="form-field">
							<CustomAutoComplete T="YesNoFilterOption"
												Value="_selectedVehicleEmptyFilter"
												DataSource="@YesNoFilterOptions.YesNo"
												Placeholder="All"
												Label="Vehicle Empty" Required="false"
												ValueChanged="OnVehicleEmptyFilterChanged"
												FieldValue="@nameof(YesNoFilterOption.Name)" />
						</div>

						<!-- Pending Bills -->
						<div class="form-field">
							<CustomAutoComplete T="YesNoFilterOption"
												Value="_selectedPendingBillsFilter"
												DataSource="@YesNoFilterOptions.YesNo"
												Placeholder="All"
												Label="Pending Bills" Required="false"
												ValueChanged="OnPendingBillsFilterChanged"
												FieldValue="@nameof(YesNoFilterOption.Name)" />
						</div>
					</div>
				</div>
			</div>

			<!-- Report Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<line x1="8" y1="6" x2="21" y2="6" />
							<line x1="8" y1="12" x2="21" y2="12" />
							<line x1="8" y1="18" x2="21" y2="18" />
							<line x1="3" y1="6" x2="3.01" y2="6" />
							<line x1="3" y1="12" x2="3.01" y2="12" />
							<line x1="3" y1="18" x2="3.01" y2="18" />
						</svg>
						<h2 class="section-title">Transactions</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" TValue="TripExpensesOverviewModel" DataSource="_transactionOverviews"
							AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true" GridLines="GridLine.Horizontal"
							AllowGrouping="true" CssClass="professional-grid" ContextMenuItems="@_gridContextMenuItems"
							Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="TripExpensesOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.TransactionNo)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label"><strong>Total Transactions: @aggregate.Count</strong></div>
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label"><strong>Total Transactions: @aggregate.Count</strong></div>
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label"><strong>Total Transactions: @aggregate.Count</strong></div>
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.ExpenseAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.Quantity)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.EstimatedDistance)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.EstimatedHours)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.EstimatedFuelConsumption)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.EstimatedCost)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.TotalExpense)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.GrossAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.PenaltyAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.NetAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total"><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.ProfitLoss)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var isLoss = aggregate.Sum?.StartsWith("-") == true;
												<div class="aggregate-value @(isLoss ? "aggregate-debit" : "aggregate-total")"><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var isLoss = aggregate.Sum?.StartsWith("-") == true;
												<div class="aggregate-value @(isLoss ? "aggregate-debit" : "aggregate-total")"><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var isLoss = aggregate.Sum?.StartsWith("-") == true;
												<div class="aggregate-value @(isLoss ? "aggregate-debit" : "aggregate-total")"><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(TripExpensesOverviewModel.PendingDays)" Type="AggregateType.Sum" Format="N0">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(TripExpensesOverviewModel.ExpenseTypeName)" HeaderText="Expense Type" Width="170" Visible="@(_showAllColumns || _selectedExpenseType is null || _selectedExpenseType.Id <= 0)" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.ExpenseTypeCode)" HeaderText="Expense Type Code" Width="130" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.ExpenseAmount)" HeaderText="Expense Amt" Width="150" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as TripExpensesOverviewModel);
										<span class="grid-total">@item.ExpenseAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(TripExpensesOverviewModel.ExpenseRemarks)" HeaderText="Expense Remarks" Width="170" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(TripExpensesOverviewModel.TransactionNo)" HeaderText="Trans No" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.CompanyName)" HeaderText="Company" Width="180" Visible="@(_showAllColumns && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.TransactionDateTime)" HeaderText="Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.FinancialYear)" HeaderText="Financial Year" Width="220" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(TripExpensesOverviewModel.SlNo)" HeaderText="Sl No" Width="130" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.ChallanNo)" HeaderText="Challan" Width="170" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.OMCName)" HeaderText="OMC" Width="100" Visible="@(_showAllColumns && (_selectedOMC is null || _selectedOMC.Id <= 0))" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="130" Visible="@(_showAllColumns || _selectedVehicle is null || _selectedVehicle.Id <= 0)" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.FromLocation)" HeaderText="From Location" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.ToLocation)" HeaderText="To Location" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.RouteDisplay)" HeaderText="Route" Width="220" Visible="@(_showAllColumns || _selectedRoute is null || _selectedRoute.Id <= 0)" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.DriverName)" HeaderText="Driver Name" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.DriverMobile)" HeaderText="Driver Mobile" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.DriverDisplay)" HeaderText="Driver" Width="170" Visible="@(_showAllColumns || _selectedDriver is null || _selectedDriver.Id <= 0)" />

							<GridColumn Field="@nameof(TripExpensesOverviewModel.Quantity)" HeaderText="Qty" Width="100" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.EstimatedDistance)" HeaderText="Est. Dist" Width="130" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.EstimatedHours)" HeaderText="Est. Hours" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns" Format="N2" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.EstimatedFuelConsumption)" HeaderText="Est. Fuel" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns" Format="N2" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.EstimatedCost)" HeaderText="Est. Cost" Width="130" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.TotalExpense)" HeaderText="Total Expense" Width="150" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as TripExpensesOverviewModel);
										<span class="grid-total">@item.TotalExpense.ToString("N2")</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(TripExpensesOverviewModel.VehicleEmpty)" HeaderText="Empty" Width="110" TextAlign="TextAlign.Center" Visible="_showAllColumns">
								<Template>
									@{
										var item = (context as TripExpensesOverviewModel);
										<span class="@(item.VehicleEmpty ? "grid-debit" : string.Empty)">
											@(item.VehicleEmpty ? "Empty" : "Loaded")
										</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(TripExpensesOverviewModel.BillNo)" HeaderText="Bill No" Width="150" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.BillDateTime)" HeaderText="Bill Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.GrossAmount)" HeaderText="Gross Amt" Width="130" TextAlign="TextAlign.Right" Format="N2" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.PenaltyAmount)" HeaderText="Penalty Amt" Width="130" TextAlign="TextAlign.Right" Format="N2" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.NetAmount)" HeaderText="Net Amt" Width="150" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as TripExpensesOverviewModel);
										<span class="grid-total">@(item.NetAmount?.ToString("N2") ?? string.Empty)</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(TripExpensesOverviewModel.ProfitLoss)" HeaderText="P&L" Width="140" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as TripExpensesOverviewModel);
										if (item.ProfitLoss.HasValue)
										{
											<span class="@(item.ProfitLoss >= 0 ? "grid-credit" : "grid-debit")">
												@item.ProfitLoss.Value.ToString("N2")
											</span>
										}
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(TripExpensesOverviewModel.PendingDays)" HeaderText="Pending Days" Width="130" TextAlign="TextAlign.Right" />

							<GridColumn Field="@nameof(TripExpensesOverviewModel.Remarks)" HeaderText="Remarks" Width="200" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.CreatedByName)" HeaderText="Created By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.CreatedAt)" HeaderText="Created At" Width="160" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.CreatedFromPlatform)" HeaderText="Created Platform" Width="300" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.LastModifiedByUserName)" HeaderText="Modified By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.LastModifiedAt)" HeaderText="Modified At" Width="160" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(TripExpensesOverviewModel.LastModifiedFromPlatform)" HeaderText="Modified Platform" Width="300" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(TripExpensesOverviewModel.MasterStatus)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as TripExpensesOverviewModel);
										<span class="@(item.MasterStatus ? string.Empty : "grid-debit")">
											@(item.MasterStatus ? "Active" : "Deleted")
										</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />

@attribute [Route(PageRouteNames.FleetDashboard)]

<PageTitle>Fleet - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => NavigationManager.NavigateTo(PageRouteNames.Dashboard)" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Fleet Dashboard" />

		<div class="page-container">

			<!-- TRANSACTIONS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 20h9" />
							<path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
						</svg>
						<h2 class="section-title">Transactions</h2>
					</div>
					<p class="section-subtitle">Create and edit fleet entries — trips, expenses and document uploads</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle Trip" Description="Record a new trip with route and expenses" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTrip)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="1" y="3" width="15" height="13" />
									<polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
									<circle cx="5.5" cy="18.5" r="2.5" />
									<circle cx="18.5" cy="18.5" r="2.5" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Vehicle Trip Bill" Description="Generate and manage billing for completed trips" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripBill)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="3" width="20" height="18" rx="2" />
									<line x1="7" y1="8" x2="17" y2="8" />
									<line x1="7" y1="12" x2="17" y2="12" />
									<line x1="7" y1="16" x2="13" y2="16" />
									<path d="M17 16l1.5 1.5L21 15" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Vehicle Expense" Description="Log repair, fuel and other vehicle expenses" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpense)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 2h13l3 3v17a1 1 0 0 1-1.5.87L17 22l-2 .87L13 22l-2 .87L9 22l-2 .87L5 22l-1.5.87A1 1 0 0 1 2 22V4a2 2 0 0 1 2-2z" />
									<line x1="7" y1="9" x2="17" y2="9" />
									<line x1="7" y1="13" x2="17" y2="13" />
									<line x1="7" y1="17" x2="13" y2="17" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- VEHICLE TRIP REPORTS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="18" y1="20" x2="18" y2="10" />
							<line x1="12" y1="20" x2="12" y2="4" />
							<line x1="6" y1="20" x2="6" y2="14" />
						</svg>
						<h2 class="section-title">Vehicle Trip Reports</h2>
					</div>
					<p class="section-subtitle">Review trip activity, breakdown of expenses and OMC card payments</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Trip Report" Description="Summary of all vehicle trips by date and vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="16" y1="13" x2="8" y2="13" />
									<line x1="16" y1="17" x2="8" y2="17" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Trip Expenses Report" Description="Itemised expenses recorded against trips" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripExpensesReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="12" y1="18" x2="12" y2="12" />
									<path d="M10 14h4" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Trip Payments Report" Description="OMC card payments collected on trips" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripPaymentsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="2" ry="2" />
									<line x1="2" y1="10" x2="22" y2="10" />
									<line x1="6" y1="15" x2="10" y2="15" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- VEHICLE TRIP BILL REPORTS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="3" width="20" height="18" rx="2" />
							<line x1="7" y1="8" x2="17" y2="8" />
							<line x1="7" y1="12" x2="17" y2="12" />
							<line x1="7" y1="16" x2="13" y2="16" />
							<path d="M17 16l1.5 1.5L21 15" />
						</svg>
						<h2 class="section-title">Trip Bill Reports</h2>
					</div>
					<p class="section-subtitle">Review billing summaries, card payments and ledger settlements on trip bills</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Trip Bill Report" Description="Summary of all trip bills by date and vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripBillReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="16" y1="13" x2="8" y2="13" />
									<line x1="16" y1="17" x2="8" y2="17" />
									<polyline points="10 9 9 9 8 9" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Bill Card Payments Report" Description="OMC card payments collected against trip bills" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripBillCardPaymentsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="2" ry="2" />
									<line x1="2" y1="10" x2="22" y2="10" />
									<polyline points="7 15 9 15 11 15" />
									<path d="M16 15h2" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Bill Ledger Payments Report" Description="Ledger settlements recorded against trip bills" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripBillLedgerPaymentsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 2h13l3 3v17a1 1 0 0 1-1.5.87L17 22l-2 .87L13 22l-2 .87L9 22l-2 .87L5 22l-1.5.87A1 1 0 0 1 2 22V4a2 2 0 0 1 2-2z" />
									<line x1="7" y1="9" x2="17" y2="9" />
									<line x1="7" y1="13" x2="17" y2="13" />
									<path d="M7 17h4" />
									<path d="M14 17l1.5 1.5L18 16" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- VEHICLE EXPENSE REPORTS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
							<polyline points="17 6 23 6 23 12" />
						</svg>
						<h2 class="section-title">Vehicle Expense Reports</h2>
					</div>
					<p class="section-subtitle">Track non-trip expenses by vehicle, ledger and date range</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Expense Report" Description="Summary of expense transactions by vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="16" y1="13" x2="8" y2="13" />
									<line x1="16" y1="17" x2="8" y2="17" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Expense Details Report" Description="Line-item breakdown of every expense entry" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseDetailsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="11" cy="11" r="8" />
									<line x1="21" y1="21" x2="16.65" y2="16.65" />
									<line x1="8" y1="11" x2="14" y2="11" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- ROUTES & DRIVERS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
							<line x1="8" y1="2" x2="8" y2="18" />
							<line x1="16" y1="6" x2="16" y2="22" />
						</svg>
						<h2 class="section-title">Routes &amp; Drivers</h2>
					</div>
					<p class="section-subtitle">Catalog of routes, locations and drivers used when planning trips</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Route" Description="Manage routes between source and destination" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleRouteMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="6" cy="19" r="3" />
									<path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15" />
									<circle cx="18" cy="5" r="3" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Route Location" Description="Pickup and drop locations used in routes" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleRouteLocationMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 21s-6-4.35-6-10a6 6 0 0 1 12 0c0 5.65-6 10-6 10z" />
									<circle cx="12" cy="11" r="2" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Driver" Description="Manage drivers assigned to your fleet" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.DriverMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
									<circle cx="12" cy="7" r="4" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- OMC -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 22h12V4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v18z" />
							<path d="M15 9h3l3 3v9a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3a1 1 0 0 0-1-1h-1" />
							<line x1="6" y1="7" x2="12" y2="7" />
							<line x1="6" y1="11" x2="12" y2="11" />
						</svg>
						<h2 class="section-title">OMC</h2>
					</div>
					<p class="section-subtitle">Manage oil marketing companies and their fuel cards</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="OMC" Description="Manage oil marketing company list" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.OMCMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 21h18" />
									<path d="M5 21V7l8-4v18" />
									<path d="M19 21V11l-6-4" />
									<line x1="9" y1="9" x2="9" y2="9.01" />
									<line x1="9" y1="13" x2="9" y2="13.01" />
									<line x1="9" y1="17" x2="9" y2="17.01" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="OMC Card" Description="Manage fuel cards issued by OMCs" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.OMCCardMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="2" ry="2" />
									<line x1="2" y1="10" x2="22" y2="10" />
									<line x1="6" y1="15" x2="10" y2="15" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- DOCUMENTS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
						</svg>
						<h2 class="section-title">Documents</h2>
					</div>
					<p class="section-subtitle">Configure the kinds of documents tracked against vehicles</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle Document" Description="Upload and track vehicle documents" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDocument)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="9" y1="15" x2="15" y2="15" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Document Type" Description="Manage vehicle document categories like RC, insurance and PUC" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleDocumentTypeMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="8" y1="13" x2="16" y2="13" />
									<line x1="8" y1="17" x2="13" y2="17" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- VEHICLE MASTERS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M10 17h4V5H2v12h3" />
							<path d="M14 9h4l4 4v4h-3" />
							<circle cx="7.5" cy="17.5" r="2.5" />
							<circle cx="17.5" cy="17.5" r="2.5" />
						</svg>
						<h2 class="section-title">Vehicle Masters</h2>
					</div>
					<p class="section-subtitle">Reference data for vehicles, vehicle types and expense categories</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle" Description="Manage your fleet of vehicles" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M10 17h4V5H2v12h3" />
									<path d="M14 9h4l4 4v4h-3" />
									<circle cx="7.5" cy="17.5" r="2.5" />
									<circle cx="17.5" cy="17.5" r="2.5" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Vehicle Type" Description="Categorise vehicles by class — truck, tanker, trailer" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTypeMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 7h18" />
									<path d="M6 3h12v4H6z" />
									<path d="M8 11v10" />
									<path d="M12 11v10" />
									<path d="M16 11v10" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Expense Type" Description="Define expense categories used during data entry" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseTypeMaster)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
									<line x1="7" y1="7" x2="7.01" y2="7" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

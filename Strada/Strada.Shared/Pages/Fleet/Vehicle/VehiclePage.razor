@attribute [Route(PageRouteNames.VehicleMaster)]

@using StradaLibrary.Accounts.Masters.Models
@using StradaLibrary.Fleet.OMC.Models
@using StradaLibrary.Fleet.Vehicle.Models

<PageTitle>Vehicle - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Management">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">Vehicle Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @ref="_sfFirstFocus"
											 @bind-Value="_vehicle.Code"
											 Label="Code (Ctrl + F)"
											 Placeholder="Enter Vehicle Code" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_vehicle.ShortCode"
											 Label="Short Code"
											 Placeholder="Enter short code" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_vehicle.ChasisCode"
											 Label="Chasis Code"
											 Placeholder="Enter chasis code"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_vehicle.EngineCode"
											 Label="Engine Code"
											 Placeholder="Enter engine code"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="VehicleTypeModel"
												@bind-Value="_selectedVehicleType"
												DataSource="@_vehicleTypes"
												Placeholder="Select vehicle type"
												FieldValue="@nameof(VehicleTypeModel.Name)"
												Label="Vehicle Type"
												AddNewRoute="@PageRouteNames.VehicleTypeMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												@bind-Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="Select company"
												FieldValue="@nameof(CompanyModel.Name)"
												Label="Company"
												AddNewRoute="@PageRouteNames.CompanyMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="OMCModel"
												@bind-Value="_selectedOMC"
												DataSource="@_omcs"
												Placeholder="Select OMC"
												FieldValue="@nameof(OMCModel.Name)"
												Label="OMC" Required="false"
												AddNewRoute="@PageRouteNames.OMCMaster" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_vehicle.PurchaseDate" Label="Purchase Date" ShowFinancialYear="false" />
						</div>

						<div class="form-field">
							<CustomNumericField T="decimal"
												@bind-Value="_vehicle.OpeningKM"
												Label="Opening KM"
												Placeholder="Enter opening KM"
												Min="0" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_vehicle.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Vehicles List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_vehicles" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="VehicleModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(VehicleModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleModel.Code)" HeaderText="Code" Width="150" />
							<GridColumn Field="@nameof(VehicleModel.ShortCode)" HeaderText="Short Code" Width="150" />
							<GridColumn Field="@nameof(VehicleModel.ChasisCode)" HeaderText="Chasis Code" Width="160" />
							<GridColumn Field="@nameof(VehicleModel.EngineCode)" HeaderText="Engine Code" Width="160" />
							<GridColumn Field="@nameof(VehicleModel.VehicleTypeId)" HeaderText="Vehicle Type" Width="180">
								<Template>
									@{
										var item = (context as VehicleModel);
										var vehicleType = _vehicleTypes.FirstOrDefault(vt => vt.Id == item.VehicleTypeId);
										<span>@(vehicleType is not null ? vehicleType.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleModel.CompanyId)" HeaderText="Company" Width="220">
								<Template>
									@{
										var item = (context as VehicleModel);
										var company = _companies.FirstOrDefault(c => c.Id == item.CompanyId);
										<span>@(company is not null ? company.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleModel.OMCId)" HeaderText="OMC" Width="220">
								<Template>
									@{
										var item = (context as VehicleModel);
										var omc = _omcs.FirstOrDefault(o => o.Id == item.OMCId);
										<span>@(omc is not null ? omc.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleModel.PurchaseDate)" HeaderText="Purchase Date" Width="150" Format="dd-MMM-yyyy" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleModel.OpeningKM)" HeaderText="Opening KM" Width="140" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleModel.Remarks)" HeaderText="Remarks" Width="250" />
							<GridColumn Field="@nameof(VehicleModel.Status)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as VehicleModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
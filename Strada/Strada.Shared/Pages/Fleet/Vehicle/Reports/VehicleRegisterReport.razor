@attribute [Route(PageRouteNames.VehicleRegisterReport)]

@using StradaLibrary.Accounts.Masters.Models
@using StradaLibrary.Fleet.OMC.Models
@using StradaLibrary.Fleet.Vehicle.Models
@using StradaLibrary.Fleet.Trip.Models
@using StradaLibrary.Fleet.Expense.Models

<PageTitle>Vehicle Register - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Register">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="Refresh Data (Ctrl + R / F5)" IconCss="e-icons e-refresh" Id="Refresh" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" IconCss="e-icons e-table" Id="ToggleDetailsView" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf" Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Open" IconCss="e-icons e-folder-open">
							<MenuItems>
								<MenuItem Text="Trip Report" Id="TripReport" Disabled="@_isProcessing" />
								<MenuItem Text="Expense Report" Id="ExpenseReport" Disabled="@_isProcessing" />
								<MenuItem Text="Bill Report" Id="BillReport" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Periods" IconCss="e-icons e-clock">
							<MenuItems>
								<MenuItem Text="Today" Id="PeriodToday" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Day" Id="PeriodPreviousDay" Disabled="@_isProcessing" />
								<MenuItem Text="Next Day" Id="PeriodNextDay" Disabled="@_isProcessing" />
								<MenuItem Text="Current Month" Id="PeriodCurrentMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Month" Id="PeriodPreviousMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Next Month" Id="PeriodNextMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Current FY" Id="PeriodCurrentFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Previous FY" Id="PeriodPreviousFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Next FY" Id="PeriodNextFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="All Time" Id="PeriodAllTime" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<div class="page-container">

			<!-- Filters -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
							 stroke-linecap="round" stroke-linejoin="round">
							<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
						</svg>
						<h2 class="section-title">Filters</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="filters-container">
						<div class="filters-grid">
							<!-- Date Range -->
							<div class="form-field">
								<CustomDateRangePicker @ref="_sfFirstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
													   ValueChanged="OnDateRangeChanged"
													   Label="Date Range (Ctrl + F)"
													   Required="false" />
							</div>

							<div class="form-field">
								<CustomAutoComplete T="CompanyModel"
													Value="_selectedCompany" DataSource="@_companies"
													Placeholder="All Companies" Label="Company" Required="false"
													ValueChanged="OnCompanyChanged" FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@PageRouteNames.CompanyMaster" />
							</div>
							<div class="form-field">
								<CustomAutoComplete T="OMCModel"
													Value="_selectedOMC" DataSource="@_omcs"
													Placeholder="All OMCs" Label="OMC" Required="false"
													ValueChanged="OnOMCChanged" FieldValue="@nameof(OMCModel.Name)"
													AddNewRoute="@PageRouteNames.OMCMaster" />
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Register Grid -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
							 stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
							<line x1="3" y1="9" x2="21" y2="9" />
							<line x1="3" y1="15" x2="21" y2="15" />
							<line x1="9" y1="3" x2="9" y2="21" />
						</svg>
						<h2 class="section-title">Vehicle Register</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" TValue="VehicleRegisterModel" DataSource="_transactionOverviews"
							AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true"
							GridLines="GridLine.Horizontal" AllowGrouping="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="VehicleRegisterModel" ExcelDetailTemplateExporting="OnExcelDetailTemplateExporting" />

						@if (_showAllColumns)
						{
							<GridTemplates>
								<DetailTemplate>
									@{
										var vehicle = context as VehicleRegisterModel;
									}
									<div class="detail-panel">
										@if (vehicle.TripOverviews.Count > 0)
										{
											<div class="detail-section">
												<div class="detail-section-header">
													<span class="detail-section-title">Trips</span>
													<span class="detail-section-badge">@vehicle.TripOverviews.Count</span>
												</div>
												<SfGrid TValue="TripOverviewModel" DataSource="vehicle.TripOverviews" AllowSorting="true" AllowResizing="true" AllowFiltering="true" GridLines="GridLine.Both">
													<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
													<GridColumns>
														<GridColumn Field="@nameof(TripOverviewModel.TransactionDateTime)" HeaderText="Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />

														<GridColumn Field="@nameof(TripOverviewModel.SlNo)" HeaderText="Sl No" Width="130" />
														<GridColumn Field="@nameof(TripOverviewModel.ChallanNo)" HeaderText="Challan" Width="170" />
														<GridColumn Field="@nameof(TripOverviewModel.OMCName)" HeaderText="OMC" Width="100" />
														<GridColumn Field="@nameof(TripOverviewModel.RouteDisplay)" HeaderText="Route" Width="220" />
														<GridColumn Field="@nameof(TripOverviewModel.DriverDisplay)" HeaderText="Driver" Width="170" />

														<GridColumn Field="@nameof(TripOverviewModel.Quantity)" HeaderText="Qty" Width="100" TextAlign="TextAlign.Right" Format="N2" />
														<GridColumn Field="@nameof(TripOverviewModel.EstimatedDistance)" HeaderText="Est. Dist" Width="130" TextAlign="TextAlign.Right" Format="N2" />
														<GridColumn Field="@nameof(TripOverviewModel.EstimatedHours)" HeaderText="Est. Hours" Width="130" TextAlign="TextAlign.Right" Format="N2" />
														<GridColumn Field="@nameof(TripOverviewModel.EstimatedFuelConsumption)" HeaderText="Est. Fuel" Width="130" TextAlign="TextAlign.Right" Format="N2" />
														<GridColumn Field="@nameof(TripOverviewModel.EstimatedCost)" HeaderText="Est. Cost" Width="130" TextAlign="TextAlign.Right" Format="N2" />
														<GridColumn Field="@nameof(TripOverviewModel.TotalExpense)" HeaderText="Total Expense" Width="150" TextAlign="TextAlign.Right">
															<Template Context="tripExp">
																@{
																	var item = (tripExp as TripOverviewModel);
																	<span class="grid-total">@item.TotalExpense.ToString("N2")</span>
																}
															</Template>
														</GridColumn>

														<GridColumn Field="@nameof(TripOverviewModel.VehicleEmpty)" HeaderText="Empty" Width="110" TextAlign="TextAlign.Center" Visible="_showAllColumns">
															<Template Context="tripEmpty">
																@{
																	var item = (tripEmpty as TripOverviewModel);
																	<span class="@(item.VehicleEmpty ? "grid-debit" : string.Empty)">
																		@(item.VehicleEmpty ? "Empty" : "Loaded")
																	</span>
																}
															</Template>
														</GridColumn>

														<GridColumn Field="@nameof(TripOverviewModel.BillNo)" HeaderText="Bill No" Width="150" />
														<GridColumn Field="@nameof(TripOverviewModel.BillDateTime)" HeaderText="Bill Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />
														<GridColumn Field="@nameof(TripOverviewModel.GrossAmount)" HeaderText="Gross Amt" Width="130" TextAlign="TextAlign.Right" Format="N2" />
														<GridColumn Field="@nameof(TripOverviewModel.PenaltyAmount)" HeaderText="Penalty Amt" Width="130" TextAlign="TextAlign.Right" Format="N2" />
														<GridColumn Field="@nameof(TripOverviewModel.NetAmount)" HeaderText="Net Amt" Width="150" TextAlign="TextAlign.Right">
															<Template Context="tripNet">
																@{
																	var item = (tripNet as TripOverviewModel);
																	<span class="grid-total">@(item.NetAmount?.ToString("N2") ?? string.Empty)</span>
																}
															</Template>
														</GridColumn>

														<GridColumn Field="@nameof(TripOverviewModel.ProfitLoss)" HeaderText="P&L" Width="140" TextAlign="TextAlign.Right">
															<Template Context="tripPL">
																@{
																	var item = (tripPL as TripOverviewModel);
																	if (item.ProfitLoss.HasValue)
																	{
																		<span class="@(item.ProfitLoss >= 0 ? "grid-credit" : "grid-debit")">
																			@item.ProfitLoss.Value.ToString("N2")
																		</span>
																	}
																}
															</Template>
														</GridColumn>
														<GridColumn Field="@nameof(TripOverviewModel.PendingDays)" HeaderText="Pending Days" Width="130" TextAlign="TextAlign.Right" />
														<GridColumn Field="@nameof(TripOverviewModel.Remarks)" HeaderText="Remarks" Width="200" />
													</GridColumns>
												</SfGrid>
											</div>
										}
										@if (vehicle.ExpenseDetailsOverviews.Count > 0)
										{
											<div class="detail-section">
												<div class="detail-section-header">
													<span class="detail-section-title">Expenses</span>
													<span class="detail-section-badge">@vehicle.ExpenseDetailsOverviews.Count</span>
												</div>
												<SfGrid TValue="ExpenseDetailsOverviewModel" DataSource="vehicle.ExpenseDetailsOverviews" AllowSorting="true" AllowResizing="true" AllowFiltering="true" GridLines="GridLine.Both">
													<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
													<GridColumns>
														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.TransactionDateTime)" HeaderText="Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />

														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.ExpenseTypeName)" HeaderText="Expense Type" Width="170" />
														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.LedgerName)" HeaderText="Ledger" Width="130" />
														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.ExpenseAmount)" HeaderText="Expense Amt" Width="150" TextAlign="TextAlign.Right">
															<Template Context="expenseAmt">
																@{
																	var item = (expenseAmt as ExpenseDetailsOverviewModel);
																	<span class="grid-total">@item.ExpenseAmount.ToString("N2")</span>
																}
															</Template>
														</GridColumn>

														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.IdentificationNo)" HeaderText="Identification No" Width="170" />
														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.ExpenseRemarks)" HeaderText="Expense Remarks" Width="170" />

														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.TotalExpense)" HeaderText="Total Expense" Width="150" TextAlign="TextAlign.Right">
															<Template Context="totalExpense">
																@{
																	var item = (totalExpense as ExpenseDetailsOverviewModel);
																	<span class="grid-total">@item.TotalExpense.ToString("N2")</span>
																}
															</Template>
														</GridColumn>

														<GridColumn Field="@nameof(ExpenseDetailsOverviewModel.Remarks)" HeaderText="Remarks" Width="200" />
													</GridColumns>
												</SfGrid>
											</div>
										}
									</div>
								</DetailTemplate>
							</GridTemplates>
						}

						<GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.VehicleCode)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Vehicles: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalTrips)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.LoadedTrips)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.EmptyTrips)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalQuantity)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalTripExpenses)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalExpenses)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalBills)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalGrossAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div><strong>@aggregate.Sum</strong></div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalNetAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-value aggregate-total">
												<strong>@aggregate.Sum</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleRegisterModel.TotalProfitLoss)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var isLoss = aggregate.Sum?.StartsWith("-") == true;
											}
											<div class="aggregate-value @(isLoss ? "aggregate-debit" : "aggregate-total")">
												<strong>@aggregate.Sum</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<!-- Identity -->
							<GridColumn Field="@nameof(VehicleRegisterModel.VehicleCode)" HeaderText="Vehicle" Width="130" />

							<!-- Trips -->
							<GridColumn Field="@nameof(VehicleRegisterModel.TotalTrips)" HeaderText="Trips" Width="100" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleRegisterModel.LoadedTrips)" HeaderText="Loaded" Width="100" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleRegisterModel.EmptyTrips)" HeaderText="Empty" Width="100" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleRegisterModel.TotalQuantity)" HeaderText="Qty" Width="110" TextAlign="TextAlign.Right" Format="N2" />

							<!-- Trip Expenses: stacked header with total + per-type breakdown -->
							<GridColumn HeaderText="Trip Expenses" TextAlign="TextAlign.Center">
								<ChildContent>
									<GridColumns>
										<GridColumn Field="@nameof(VehicleRegisterModel.TotalTripExpenses)" HeaderText="Total" Width="115" TextAlign="TextAlign.Right" Format="N2" />
										@foreach (var expType in _activeTripExpenseTypes)
										{
											var capturedId = expType.ExpenseTypeId;
											var capturedName = expType.ExpenseType;
											<GridColumn HeaderText="@capturedName" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns">
												<Template>
													@{
														var item = context as VehicleRegisterModel;
														var amt = item?.TripExpenses.FirstOrDefault(e => e.ExpenseTypeId == capturedId)?.ExpenseAmount ?? 0;
														<span>@amt.ToString("N2")</span>
													}
												</Template>
											</GridColumn>
										}
									</GridColumns>
								</ChildContent>
							</GridColumn>

							<!-- Expenses: stacked header with total + per-type breakdown -->
							<GridColumn HeaderText="Expenses" TextAlign="TextAlign.Center">
								<ChildContent>
									<GridColumns>
										<GridColumn Field="@nameof(VehicleRegisterModel.TotalExpenses)" HeaderText="Total" Width="115" TextAlign="TextAlign.Right" Format="N2" />
										@foreach (var expType in _activeExpenseTypes)
										{
											var capturedId = expType.ExpenseTypeId;
											var capturedName = expType.ExpenseType;
											<GridColumn HeaderText="@capturedName" Width="130"
														TextAlign="TextAlign.Right" Visible="_showAllColumns">
												<Template>
													@{
														var item = context as VehicleRegisterModel;
														var amt = item?.Expenses.FirstOrDefault(e => e.ExpenseTypeId == capturedId)?.ExpenseAmount ?? 0;
														<span>@amt.ToString("N2")</span>
													}
												</Template>
											</GridColumn>
										}
									</GridColumns>
								</ChildContent>
							</GridColumn>

							<!-- Bills -->
							<GridColumn Field="@nameof(VehicleRegisterModel.TotalBills)" HeaderText="Bills" Width="75" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleRegisterModel.TotalGrossAmount)" HeaderText="Gross Amt" Width="125" TextAlign="TextAlign.Right" Format="N2" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleRegisterModel.TotalNetAmount)" HeaderText="Net Amt" Width="125" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = context as VehicleRegisterModel;
										<span class="grid-total">@item.TotalNetAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>

							<!-- Profit / Loss -->
							<GridColumn Field="@nameof(VehicleRegisterModel.TotalProfitLoss)" HeaderText="P / L" Width="125" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = context as VehicleRegisterModel;
										<span class="@(item.TotalProfitLoss >= 0 ? "grid-total" : "grid-debit")">
											@item.TotalProfitLoss.ToString("N2")
										</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<NavigationLock ConfirmExternalNavigation="@_isProcessing" />

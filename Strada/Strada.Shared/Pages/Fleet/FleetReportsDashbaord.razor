@attribute [Route(PageRouteNames.FleetReportsDashboard)]

<PageTitle>Fleet Reports - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => NavigationManager.NavigateTo(PageRouteNames.Dashboard)" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Fleet Reports" />

		<div class="page-container">

			<!-- VEHICLE REGISTER -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M10 17h4V5H2v12h3" />
							<path d="M14 9h4l4 4v4h-3" />
							<circle cx="7.5" cy="17.5" r="2.5" />
							<circle cx="17.5" cy="17.5" r="2.5" />
						</svg>
						<h2 class="section-title">Vehicle Register</h2>
					</div>
					<p class="section-subtitle">Fleet-wide register of all vehicles with registration and type details</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">
						<FileCard Title="Vehicle Register" Description="Complete register of all fleet vehicles with type and registration details" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleRegisterReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M10 17h4V5H2v12h3" />
									<path d="M14 9h4l4 4v4h-3" />
									<circle cx="7.5" cy="17.5" r="2.5" />
									<circle cx="17.5" cy="17.5" r="2.5" />
								</svg>
							</IconContent>
						</FileCard>
					</div>
				</div>
			</div>

			<!-- VEHICLE TRIP REPORTS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="18" y1="20" x2="18" y2="10" />
							<line x1="12" y1="20" x2="12" y2="4" />
							<line x1="6" y1="20" x2="6" y2="14" />
						</svg>
						<h2 class="section-title">Trip Reports</h2>
					</div>
					<p class="section-subtitle">Review trip activity, expense breakdowns and OMC card payments across trips</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">

						<FileCard Title="Trip Report" Description="Summary of all vehicle trips filtered by date range and vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="16" y1="13" x2="8" y2="13" />
									<line x1="16" y1="17" x2="8" y2="17" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Trip Expenses Report" Description="Itemised breakdown of all expenses recorded against trips" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripExpensesReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="12" y1="18" x2="12" y2="12" />
									<line x1="9" y1="15" x2="15" y2="15" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Trip Payments Report" Description="OMC card payments collected against vehicle trips" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripPaymentsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="2" ry="2" />
									<line x1="2" y1="10" x2="22" y2="10" />
									<line x1="6" y1="15" x2="10" y2="15" />
								</svg>
							</IconContent>
						</FileCard>

					</div>
				</div>
			</div>

			<!-- TRIP BILL REPORTS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="3" width="20" height="18" rx="2" />
							<line x1="7" y1="8" x2="17" y2="8" />
							<line x1="7" y1="12" x2="17" y2="12" />
							<line x1="7" y1="16" x2="13" y2="16" />
							<path d="M17 16l1.5 1.5L21 15" />
						</svg>
						<h2 class="section-title">Billing Reports</h2>
					</div>
					<p class="section-subtitle">Billing summaries, card payments and ledger settlements recorded on trip bills</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">

						<FileCard Title="Bill Report" Description="Summary of all trip bills filtered by date range and vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripBillReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="16" y1="13" x2="8" y2="13" />
									<line x1="16" y1="17" x2="8" y2="17" />
									<polyline points="10 9 9 9 8 9" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Bill Card Payments Report" Description="OMC card payments collected against trip bills" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripBillCardPaymentsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="2" ry="2" />
									<line x1="2" y1="10" x2="22" y2="10" />
									<polyline points="7 15 9 15 11 15" />
									<path d="M16 15h2" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Bill Ledger Payments Report" Description="Ledger settlements recorded against trip bills" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleTripBillLedgerPaymentsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 2h13l3 3v17a1 1 0 0 1-1.5.87L17 22l-2 .87L13 22l-2 .87L9 22l-2 .87L5 22l-1.5.87A1 1 0 0 1 2 22V4a2 2 0 0 1 2-2z" />
									<line x1="7" y1="9" x2="17" y2="9" />
									<line x1="7" y1="13" x2="17" y2="13" />
									<path d="M7 17h4" />
									<path d="M14 17l1.5 1.5L18 16" />
								</svg>
							</IconContent>
						</FileCard>

					</div>
				</div>
			</div>

			<!-- VEHICLE EXPENSE REPORTS -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
							<polyline points="17 6 23 6 23 12" />
						</svg>
						<h2 class="section-title">Expense Reports</h2>
					</div>
					<p class="section-subtitle">Track non-trip expenses by vehicle, expense type and date range</p>
				</div>
				<div class="section-body">
					<div class="dashboard-grid">

						<FileCard Title="Expense Report" Description="Summary of expense transactions grouped by vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
									<polyline points="14 2 14 8 20 8" />
									<line x1="16" y1="13" x2="8" y2="13" />
									<line x1="16" y1="17" x2="8" y2="17" />
								</svg>
							</IconContent>
						</FileCard>

						<FileCard Title="Expense Details Report" Description="Line-item breakdown of every expense entry by vehicle" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VehicleExpenseDetailsReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="11" cy="11" r="8" />
									<line x1="21" y1="21" x2="16.65" y2="16.65" />
									<line x1="8" y1="11" x2="14" y2="11" />
									<line x1="11" y1="8" x2="11" y2="14" />
								</svg>
							</IconContent>
						</FileCard>

					</div>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

@attribute [Route(PageRouteNames.Bill)]
@attribute [Route(PageRouteNames.Bill + "/{Id:int}")]

@using StradaLibrary.Models.Accounts.Masters
@using StradaLibrary.Models.Fleet.OMC
@using StradaLibrary.Models.Fleet.Trip
@using StradaLibrary.Models.Fleet.Bill

<PageTitle>Bill - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfOMCCardAutoComplete.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfLedgerAutoComplete.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddTripToCart" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportPdfInvoice" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportExcelInvoice" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.BillReport, FormFactor, JSRuntime, NavigationManager)" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Create Bill">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction" Disabled="@_isProcessing" />
								<MenuItem Text="Save & PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="SavePdfInvoice" Disabled="@_isProcessing" />
								<MenuItem Text="Save & Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="SaveExcelInvoice" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="ExportPdfInvoice" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel" Id="ExportExcelInvoice" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Open" IconCss="e-icons e-folder-open">
							<MenuItems>
								<MenuItem Text="Transaction History Report (Ctrl + H)" Id="TransactionHistory" Disabled="@_isProcessing" />
								<MenuItem Text="Card Payments Report" Id="CardPaymentsReport" Disabled="@_isProcessing" />
								<MenuItem Text="Ledger Payments Report" Id="LedgerPaymentsReport" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<div class="four-column-layout">

				<!-- Transaction Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="16" y1="13" x2="8" y2="13" />
								<line x1="16" y1="17" x2="8" y2="17" />
								<polyline points="10 9 9 9 8 9" />
							</svg>
							<h2 class="section-title">Transaction Summary</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Company -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="CompanyModel" TValue="CompanyModel"
													 Value="_selectedCompany"
													 DataSource="@_companies"
													 Placeholder="Select a Company"
													 Label="Company" Required="true"
													 ValueChange="OnCompanyChanged"
													 FieldValue="@nameof(CompanyModel.Name)"
													 AddNewRoute="@PageRouteNames.CompanyMaster" />
							</div>

							<!-- Transaction Date / Financial Year -->
							<div class="form-field">
								<label class="field-label">
									Transaction Date <span class="required">*</span> / Financial Year
								</label>
								<div class="date-year-wrapper">
									<SfDatePicker @bind-Value="_bill.TransactionDateTime" TValue="DateTime"
												  Format="dd/MM/yy" Placeholder="Select Date" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-datepicker" />
									<SfTextBox Value="@($"{_selectedFinancialYear?.StartDate:yyyy} to {_selectedFinancialYear?.EndDate:yyyy}")"
											   Readonly="true" Placeholder="Financial Year" FloatLabelType="FloatLabelType.Never"
											   CssClass="custom-textbox readonly-field" />
								</div>
							</div>

							<!-- Bill No -->
							<div class="form-field">
								<label class="field-label">
									Bill No <span class="required">*</span>
								</label>
								<SfTextBox @bind-Value="_bill.BillNo" Placeholder="Enter Bill No..."
										   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
							</div>

							<!-- OMC -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="OMCModel" TValue="OMCModel"
													 Value="_selectedOMC"
													 DataSource="@_omcs"
													 Placeholder="Select an OMC"
													 Label="OMC" Required="true"
													 ValueChange="OnOMCChanged"
													 FieldValue="@nameof(OMCModel.Name)"
													 AddNewRoute="@PageRouteNames.OMCMaster" />
							</div>

							<!-- Remarks -->
							<div class="form-field">
								<label class="field-label">Remarks / Narration</label>
								<SfTextBox @bind-Value="_bill.Remarks" Multiline="true"
										   Placeholder="Enter remarks..." FloatLabelType="FloatLabelType.Never"
										   CssClass="custom-textbox" />
							</div>

							<!-- Trip Date Range -->
							<div class="form-field">
								<label class="field-label">Trip Date Range</label>
								<SfDateRangePicker CssClass="custom-daterange" StartDate="_startTripDate" EndDate="_endTripDate"
												   TValue="DateTime" Format="dd/MM/yyyy" AllowEdit="true" Placeholder="Select date range">
									<DateRangePickerEvents TValue="DateTime" ValueChange="OnTripDateRangeChanged" />
								</SfDateRangePicker>
							</div>

						</div>
					</div>
				</div>

				<!-- Financial Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23" />
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
							</svg>
							<h2 class="section-title">Financial Summary</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Transaction No -->
							<div class="form-field">
								<label class="field-label">
									Transaction No <span class="required">*</span>
								</label>
								<SfTextBox @bind-Value="_bill.TransactionNo" Placeholder="Transaction No"
										   FloatLabelType="FloatLabelType.Never" Readonly="true"
										   CssClass="custom-textbox readonly-field" />
							</div>

							<!-- Total Gross Amount -->
							<div class="form-field">
								<label class="field-label">Total Gross Amount</label>
								<SfNumericTextBox Value="@_bill.TotalGrossAmount" Readonly="true" TValue="decimal"
												  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-numeric readonly-field" />
							</div>

							<!-- Total TDS Amount -->
							<div class="form-field">
								<label class="field-label">Total TDS Amount</label>
								<SfNumericTextBox Value="@_bill.TotalTDSAmount" Readonly="true" TValue="decimal"
												  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-numeric readonly-field" />
							</div>

							<!-- Total Penalty Amount -->
							<div class="form-field">
								<label class="field-label">Total Penalty Amount</label>
								<SfNumericTextBox Value="@_bill.TotalPenaltyAmount" Readonly="true" TValue="decimal"
												  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-numeric readonly-field" />
							</div>

							<!-- Total Net Amount -->
							<div class="form-field">
								<label class="field-label">Total Net Amount</label>
								<SfNumericTextBox Value="@_bill.TotalNetAmount" Readonly="true" TValue="decimal"
												  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-numeric total-field" />
							</div>

						</div>
					</div>
				</div>

				<!-- Card Payments Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
								<line x1="1" y1="10" x2="23" y2="10" />
							</svg>
							<h2 class="section-title">Card Payments</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<div class="cart-field cart-field-wide">
								<AutoCompleteWithAdd TItem="OMCCardModel" TValue="OMCCardModel"
													 @ref="_sfOMCCardAutoComplete"
													 FieldValue="@nameof(OMCCardModel.CardNumber)" Value="_selectedOMCCard"
													 DataSource="@_omcCards" Placeholder="Select OMC Card (Ctrl + Shift + F)"
													 ValueChange="OnCardPaymentsTypeChanged"
													 Label="OMC Card" Required="true" AddNewRoute="@PageRouteNames.OMCCardMaster" />
							</div>

							<div class="cart-field cart-field-wide">
								<label class="cart-label">Amount <span class="required">*</span></label>
								<SfNumericTextBox @bind-Value="_selectedCardPaymentCart.Amount" TValue="decimal" Min="0"
												  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-numeric editable-field" />
							</div>

							<div class="cart-field cart-field-wide">
								<label class="cart-label">Remarks</label>
								<SfTextBox @bind-Value="_selectedCardPaymentCart.Remarks" Placeholder="Item Narration..."
										   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
							</div>

							<div class="cart-field cart-field-wide">
								<label class="cart-label">&nbsp;</label>
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add Card Payment (Ctrl + Enter)" OnClick="AddCardPaymentsToCart" />
							</div>
						</div>

						<SfGrid @ref="_sfCardPaymentsCartGrid" DataSource="_cardPaymentsCart"
								AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
								ContextMenuItems="@_cardPaymentsCartGridContextMenuItems">

							<GridEvents TValue="BillCardPaymentsCartModel"
										ContextMenuItemClicked="OnCardPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(BillCardPaymentsCartModel.OMCCardNumber)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Cards: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(BillCardPaymentsCartModel.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(BillCardPaymentsCartModel.OMCCardNumber)" HeaderText="Card" Width="200" />
								<GridColumn Field="@nameof(BillCardPaymentsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(BillCardPaymentsCartModel.Remarks)"
											HeaderText="Remarks" Width="150" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

				<!-- Ledger Payments Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
								<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
							</svg>
							<h2 class="section-title">Ledger Payments</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<div class="cart-field cart-field-wide">
								<AutoCompleteWithAdd TItem="LedgerModel" TValue="LedgerModel"
													 @ref="_sfLedgerAutoComplete"
													 FieldValue="@nameof(LedgerModel.Name)" Value="_selectedLedger"
													 DataSource="@_ledgers" Placeholder="Select Ledger (Ctrl + Shift + G)"
													 ValueChange="OnLedgerPaymentsTypeChanged"
													 Label="Ledger" Required="true" AddNewRoute="@PageRouteNames.LedgerMaster" />
							</div>

							<div class="cart-field cart-field-wide">
								<label class="cart-label">Amount <span class="required">*</span></label>
								<SfNumericTextBox @bind-Value="_selectedLedgerPaymentCart.Amount" TValue="decimal" Min="0"
												  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-numeric editable-field" />
							</div>

							<div class="cart-field cart-field-wide">
								<label class="cart-label">Remarks</label>
								<SfTextBox @bind-Value="_selectedLedgerPaymentCart.Remarks" Placeholder="Item Narration..."
										   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
							</div>

							<div class="cart-field cart-field-wide">
								<label class="cart-label">&nbsp;</label>
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add Ledger Payment (Ctrl + Shift + Enter)" OnClick="AddLedgerPaymentsToCart" />
							</div>
						</div>

						<SfGrid @ref="_sfLedgerPaymentsCartGrid" DataSource="_ledgerPaymentsCart"
								AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
								ContextMenuItems="@_ledgerPaymentsCartGridContextMenuItems">

							<GridEvents TValue="BillLedgerPaymentsCartModel" ContextMenuItemClicked="OnLedgerPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(BillLedgerPaymentsCartModel.LedgerName)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Ledgers: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(BillLedgerPaymentsCartModel.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(BillLedgerPaymentsCartModel.LedgerName)" HeaderText="Ledger" Width="200" />
								<GridColumn Field="@nameof(BillLedgerPaymentsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(BillLedgerPaymentsCartModel.Remarks)"
											HeaderText="Remarks" Width="150" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

			</div>

			<div class="two-column-layout-equal">
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
								 stroke-linejoin="round">
								<line x1="8" y1="6" x2="21" y2="6" />
								<line x1="8" y1="12" x2="21" y2="12" />
								<line x1="8" y1="18" x2="21" y2="18" />
								<line x1="3" y1="6" x2="3.01" y2="6" />
								<line x1="3" y1="12" x2="3.01" y2="12" />
								<line x1="3" y1="18" x2="3.01" y2="18" />
							</svg>
							<h2 class="section-title">Pending Trips</h2>
						</div>
					</div>
					<div class="section-body grid-body">
						<SfGrid @ref="_sfPendingTripGrid" TValue="TripOverviewModel" DataSource="_pendingTrips"
								AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
								ContextMenuItems="@_pendingTripGridContextMenuItems"
								Toolbar="@(new List<string>() { "Search" })">

							<GridEvents TValue="TripOverviewModel" ContextMenuItemClicked="OnPendingTripGridContextMenuItemClicked" OnRecordDoubleClick="OnPendingTripDoubleClick" />
							<GridPageSettings PageSize="10" PageSizes="@(new string[] { "10", "20", "50", "All" })" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(TripOverviewModel.VehicleCode)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Pending Trips: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(TripOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="120" />
								<GridColumn Field="@nameof(TripOverviewModel.TransactionDateTime)" HeaderText="Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />
								<GridColumn Field="@nameof(TripOverviewModel.RouteDisplay)" HeaderText="Route" Width="200" />
								<GridColumn Field="@nameof(TripOverviewModel.OMCName)" HeaderText="OMC" Width="100" />
								<GridColumn Field="@nameof(TripOverviewModel.TransactionNo)" HeaderText="Trans No" Width="170" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

				<div>
					<div class="section-card">
						<div class="section-header">
							<div class="section-title-wrapper">
								<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
									 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
									 stroke-linecap="round" stroke-linejoin="round">
									<path d="M9 11H3v10h6V11zM21 3h-6v18h6V3zM15 7H9v14h6V7z" />
								</svg>
								<h2 class="section-title">Trip Details</h2>
							</div>
						</div>

						<div class="section-body">
							<div class="cart-input-row">
								<div class="cart-field">
									<label class="cart-label">Vehicle</label>
									<SfTextBox Value="@_selectedTrip?.VehicleCode" Readonly="true"
											   Placeholder="Select trip from pending list"
											   FloatLabelType="FloatLabelType.Never"
											   CssClass="custom-textbox readonly-field" />
								</div>

								<div class="cart-field cart-field-wide">
									<label class="cart-label">Route</label>
									<SfTextBox Value="@_selectedTrip?.RouteDisplay" Readonly="true"
											   Placeholder="Select trip from pending list"
											   FloatLabelType="FloatLabelType.Never"
											   CssClass="custom-textbox readonly-field" />
								</div>

								<div class="cart-field cart-field-wide">
									<label class="cart-label">Challan No <span class="required">*</span></label>
									<SfTextBox @ref="_sfChallanNoTextBox" @bind-Value="_selectedTrip.ChallanNo" Placeholder="Enter Challan No..."
											   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
								</div>

								<div class="cart-field">
									<label class="cart-label">Quantity</label>
									<SfNumericTextBox @bind-Value="_selectedTrip.Quantity" TValue="decimal" Min="0"
													  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
													  CssClass="custom-numeric editable-field" />
								</div>
							</div>

							<div class="cart-input-row">
								<div class="cart-field">
									<label class="cart-label">Gross Amount <span class="required">*</span></label>
									<SfNumericTextBox @bind-Value="_selectedTrip.GrossAmount" TValue="decimal?" Min="0"
													  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
													  CssClass="custom-numeric editable-field" />
								</div>

								<div class="cart-field">
									<label class="cart-label">TDS Amount</label>
									<SfNumericTextBox @bind-Value="_selectedTrip.TDSAmount" TValue="decimal?" Min="0"
													  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
													  CssClass="custom-numeric editable-field" />
								</div>

								<div class="cart-field">
									<label class="cart-label">Penalty Amount</label>
									<SfNumericTextBox @bind-Value="_selectedTrip.PenaltyAmount" TValue="decimal?" Min="0"
													  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
													  CssClass="custom-numeric editable-field" />
								</div>

								<div class="cart-field">
									<label class="cart-label">Net Amount</label>
									<SfNumericTextBox Value="@((_selectedTrip?.GrossAmount ?? 0) - (_selectedTrip?.TDSAmount ?? 0) - (_selectedTrip?.PenaltyAmount ?? 0))"
													  Readonly="true" TValue="decimal" ShowSpinButton="false" Placeholder="0.00"
													  FloatLabelType="FloatLabelType.Never" CssClass="custom-numeric total-field" />
								</div>

								<div class="cart-field">
									<label class="cart-label">&nbsp;</label>
									<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
												Title="Add Trip to Cart" OnClick="AddTripToCart" />
								</div>
							</div>
						</div>
					</div>

					<div class="section-card">
						<div class="section-header">
							<div class="section-title-wrapper">
								<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
									 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
									 stroke-linecap="round" stroke-linejoin="round">
									<circle cx="9" cy="21" r="1" />
									<circle cx="20" cy="21" r="1" />
									<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
								</svg>
								<h2 class="section-title">Trips Cart</h2>
							</div>
						</div>

						<div class="section-body grid-body">
							<SfGrid @ref="_sfTripCartGrid" TValue="TripOverviewModel" DataSource="_tripCart"
									AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true"
									AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
									ContextMenuItems="@_tripCartGridContextMenuItems">

								<GridEvents TValue="TripOverviewModel" ContextMenuItemClicked="OnTripCartGridContextMenuItemClicked" />
								<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

								<GridAggregates>
									<GridAggregate>
										<GridAggregateColumns>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.VehicleCode)" Type="AggregateType.Count">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
													}
													<div class="aggregate-label">
														<strong>Total Trips: @aggregate.Count</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.Quantity)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.GrossAmount)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.TDSAmount)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.PenaltyAmount)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.NetAmount)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value aggregate-total">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
										</GridAggregateColumns>
									</GridAggregate>
								</GridAggregates>

								<GridColumns>
									<GridColumn Field="@nameof(TripOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="120" />
									<GridColumn Field="@nameof(TripOverviewModel.ChallanNo)" HeaderText="Challan No" Width="140" />
									<GridColumn Field="@nameof(TripOverviewModel.RouteDisplay)" HeaderText="Route" Width="180" />
									<GridColumn Field="@nameof(TripOverviewModel.Quantity)" HeaderText="Quantity" Width="110" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.GrossAmount)" HeaderText="Gross" Width="120" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.TDSAmount)" HeaderText="TDS" Width="110" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.PenaltyAmount)" HeaderText="Penalty" Width="110" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.NetAmount)" HeaderText="Net" Width="120" TextAlign="TextAlign.Right" Format="N2">
										<Template>
											@{
												var item = (context as dynamic);
												<span class="grid-total">@(((decimal?)item.NetAmount ?? 0).ToString("N2"))</span>
											}
										</Template>
									</GridColumn>
								</GridColumns>

							</SfGrid>
						</div>
					</div>
				</div>

			</div>

		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

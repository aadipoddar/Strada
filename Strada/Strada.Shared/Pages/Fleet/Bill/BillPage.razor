@attribute [Route(PageRouteNames.Bill)]
@attribute [Route(PageRouteNames.Bill + "/{Id:int}")]

@using StradaLibrary.Accounts.Masters.Models
@using StradaLibrary.Fleet.OMC.Models
@using StradaLibrary.Fleet.Trip.Models
@using StradaLibrary.Fleet.Bill.Models

<PageTitle>Bill - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfLedgerAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddTripToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.BillReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_bill.Id > 0 ? $"Edit Bill {_bill.TransactionNo}" : "Create Bill")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => ResetPage()" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Bill Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.BillReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Ledger Payments Report" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.BillLedgerPaymentsReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
			<RightContent>
				<RecheckSaveButton OnClick="() => SaveTransaction()" Disabled="@_isProcessing" />
			</RightContent>
		</Header>

		<div class="page-container">

			<div class="three-column-layout">

				<!-- Transaction -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Transaction</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete T="CompanyModel"
													@ref="_firstFocus"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="Select a Company"
													Label="Company (Ctrl + F)"
													ValueChanged="OnCompanyChanged"
													FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@PageRouteNames.CompanyMaster" />
							</div>

							<!-- Transaction Date -->
							<div class="form-field">
								<CustomDatePicker @bind-Value="_bill.TransactionDateTime"
												  FinancialYear="@_selectedFinancialYear" />
							</div>

							<!-- Bill No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_bill.BillNo"
												 Label="Bill No"
												 Placeholder="Enter Bill No..." />
							</div>

							<!-- OMC -->
							<div class="form-field">
								<CustomAutoComplete T="OMCModel"
													Value="_selectedOMC"
													DataSource="@_omcs"
													Placeholder="Select an OMC"
													Label="OMC"
													ValueChanged="OnOMCChanged"
													FieldValue="@nameof(OMCModel.Name)"
													AddNewRoute="@PageRouteNames.OMCMaster" />
							</div>

							<!-- Remarks -->
							<div class="form-field">
								<CustomTextField @bind-Value="_bill.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>

						</div>
					</div>
				</div>

				<!-- Financial -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Financial</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_bill.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							<!-- Total Gross Amount -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_bill.TotalGrossAmount"
													Label="Total Gross Amount"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<!-- Total Penalty Amount -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_bill.TotalPenaltyAmount"
													Label="Total Penalty Amount"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<!-- Total Net Amount -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_bill.TotalNetAmount"
													Label="Total Net Amount"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

						</div>
					</div>
				</div>

				<!-- Ledger Payments  -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Ledger Payments</h2>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<div class="cart-field cart-field-wide">
								<CustomAutoComplete T="LedgerModel"
													@ref="_sfLedgerAutoComplete"
													FieldValue="@nameof(LedgerModel.Name)" Value="_selectedLedger"
													DataSource="@_ledgers" Placeholder="Select a Ledger"
													ValueChanged="OnLedgerPaymentsTypeChanged" OpenOnFocus="false"
													Label="Ledger (Ctrl + Shift + G)" AddNewRoute="@PageRouteNames.LedgerMaster" />
							</div>

							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal"
													@bind-Value="_selectedLedgerPaymentCart.Amount"
													Min="0"
													Label="Amount"
													Placeholder="0.00" />
							</div>

							<div class="cart-field cart-field-wide">
								<CustomTextField @bind-Value="_selectedLedgerPaymentCart.Remarks"
												 Label="Remarks"
												 Placeholder="Item Narration..."
												 Required="false" />
							</div>

							<div class="cart-field cart-field-wide">
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add Ledger Payment (Ctrl + Shift + Enter)" OnClick="AddLedgerPaymentsToCart" />
							</div>
						</div>

						<SfGrid @ref="_sfLedgerPaymentsCartGrid" DataSource="_ledgerPaymentsCart"
								AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" AllowReordering="true"
								GridLines="GridLine.Horizontal" ContextMenuItems="@_ledgerPaymentsCartGridContextMenuItems" CssClass="professional-grid">

							<GridEvents TValue="BillLedgerPaymentsCartModel" ContextMenuItemClicked="OnLedgerPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(BillLedgerPaymentsCartModel.LedgerName)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Ledgers: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(BillLedgerPaymentsCartModel.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(BillLedgerPaymentsCartModel.LedgerName)" HeaderText="Ledger" Width="200" />
								<GridColumn Field="@nameof(BillLedgerPaymentsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(BillLedgerPaymentsCartModel.Remarks)" HeaderText="Remarks" Width="150" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

			</div>

			<div class="two-column-layout-equal">

				<!-- Pending Trips -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Pending Trips</h2>
					</div>
					<div class="section-body grid-body">
						<SfGrid @ref="_sfPendingTripGrid" TValue="TripOverviewModel" DataSource="_pendingTrips"
								AllowPaging="true" AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
								GridLines="GridLine.Horizontal" ContextMenuItems="@_pendingTripGridContextMenuItems" CssClass="professional-grid"
								Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

							<GridEvents TValue="TripOverviewModel" ContextMenuItemClicked="OnPendingTripGridContextMenuItemClicked" OnRecordDoubleClick="OnPendingTripDoubleClick" />
							<GridPageSettings PageSize="10" PageSizes="@(new string[] { "10", "20", "50", "All" })" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(TripOverviewModel.VehicleCode)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Pending Trips: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(TripOverviewModel.TotalExpense)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(TripOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="120" />
								<GridColumn Field="@nameof(TripOverviewModel.SlNo)" HeaderText="Sl No" Width="120" />
								<GridColumn Field="@nameof(TripOverviewModel.TransactionDateTime)" HeaderText="Date" Width="150" Format="dd/MM/yy" Type="ColumnType.DateTime" />
								<GridColumn Field="@nameof(TripOverviewModel.RouteDisplay)" HeaderText="Route" Width="200" />
								<GridColumn Field="@nameof(TripOverviewModel.OMCName)" HeaderText="OMC" Width="100" />
								<GridColumn Field="@nameof(TripOverviewModel.TotalExpense)" HeaderText="Expense" Width="110" TextAlign="TextAlign.Right" Format="N2" />
								<GridColumn Field="@nameof(TripOverviewModel.TransactionNo)" HeaderText="Trans No" Width="170" />
							</GridColumns>

						</SfGrid>
					</div>
				</div>

				<div>
					<!-- Trip Details -->
					<div class="section-card">
						<div class="section-header">
							<h2 class="section-title">Trip Details</h2>
						</div>

						<div class="section-body">
							<div class="cart-input-row">
								<div class="cart-field">
									<CustomTextField Value="@_selectedTrip?.VehicleCode"
													 Label="Vehicle"
													 Placeholder="Select trip from pending list"
													 ReadOnly="true"
													 Required="false" />
								</div>

								<div class="cart-field cart-field-wide">
									<CustomTextField Value="@_selectedTrip?.RouteDisplay"
													 Label="Route"
													 Placeholder="Select trip from pending list"
													 ReadOnly="true"
													 Required="false" />
								</div>

								<div class="cart-field">
									<CustomNumericField T="decimal"
														@bind-Value="_selectedTrip.TotalExpense"
														Min="0"
														Label="Expense"
														Placeholder="0.00"
														ReadOnly="true"
														Required="false" />
								</div>

								<div class="cart-field cart-field-wide">
									<CustomTextField @ref="_sfChallanNoTextBox"
													 @bind-Value="_selectedTrip.ChallanNo"
													 Label="Challan No"
													 Placeholder="Enter Challan No..." />
								</div>
							</div>

							<div class="cart-input-row">
								<div class="cart-field">
									<CustomNumericField T="decimal"
														@bind-Value="_selectedTrip.Quantity"
														Min="0"
														Label="Quantity"
														Placeholder="0.00"
														Required="false" />
								</div>

								<div class="cart-field">
									<CustomNumericField T="decimal?"
														@bind-Value="_selectedTrip.GrossAmount"
														Min="0"
														Label="Gross Amount"
														Placeholder="0.00" />
								</div>

								<div class="cart-field">
									<CustomNumericField T="decimal?"
														@bind-Value="_selectedTrip.PenaltyAmount"
														Min="0"
														Label="Penalty Amount"
														Placeholder="0.00"
														Required="false" />
								</div>

								<div class="cart-field">
									<CustomNumericField T="decimal"
														Value="@((_selectedTrip?.GrossAmount ?? 0) - (_selectedTrip?.PenaltyAmount ?? 0))"
														Label="Net Amount"
														Placeholder="0.00"
														ReadOnly="true"
														Required="false" />
								</div>

								<div class="cart-field">
									<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
												Title="Add Trip to Cart" OnClick="AddTripToCart" />
								</div>
							</div>
						</div>
					</div>

					<!-- Cart -->
					<div class="section-card">
						<div class="section-header">
							<h2 class="section-title">Cart</h2>
						</div>

						<div class="section-body grid-body">
							<SfGrid @ref="_sfTripCartGrid" TValue="TripOverviewModel" DataSource="_tripCart"
									AllowSorting="true" AllowResizing="true"
									AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
									GridLines="GridLine.Horizontal" ContextMenuItems="@_tripCartGridContextMenuItems" CssClass="professional-grid"
									Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

								<GridEvents TValue="TripOverviewModel" ContextMenuItemClicked="OnTripCartGridContextMenuItemClicked" />
								<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

								<GridAggregates>
									<GridAggregate>
										<GridAggregateColumns>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.VehicleCode)" Type="AggregateType.Count">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
													}
													<div class="aggregate-label">
														<strong>Total Trips: @aggregate.Count</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.TotalExpense)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.Quantity)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.GrossAmount)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.PenaltyAmount)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(TripOverviewModel.NetAmount)" Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value aggregate-total">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
										</GridAggregateColumns>
									</GridAggregate>
								</GridAggregates>

								<GridColumns>
									<GridColumn Field="@nameof(TripOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="120" />
									<GridColumn Field="@nameof(TripOverviewModel.ChallanNo)" HeaderText="Challan No" Width="140" />
									<GridColumn Field="@nameof(TripOverviewModel.SlNo)" HeaderText="Sl No" Width="120" />
									<GridColumn Field="@nameof(TripOverviewModel.RouteDisplay)" HeaderText="Route" Width="180" />
									<GridColumn Field="@nameof(TripOverviewModel.TransactionNo)" HeaderText="Route" Width="180" />
									<GridColumn Field="@nameof(TripOverviewModel.TotalExpense)" HeaderText="Expense" Width="110" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.Quantity)" HeaderText="Quantity" Width="110" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.GrossAmount)" HeaderText="Gross" Width="120" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.PenaltyAmount)" HeaderText="Penalty" Width="110" TextAlign="TextAlign.Right" Format="N2" />
									<GridColumn Field="@nameof(TripOverviewModel.NetAmount)" HeaderText="Net" Width="120" TextAlign="TextAlign.Right" Format="N2">
										<Template>
											@{
												var item = (context as dynamic);
												<span class="grid-total">@(((decimal?)item.NetAmount ?? 0).ToString("N2"))</span>
											}
										</Template>
									</GridColumn>
								</GridColumns>

							</SfGrid>
						</div>
					</div>
				</div>

			</div>

		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
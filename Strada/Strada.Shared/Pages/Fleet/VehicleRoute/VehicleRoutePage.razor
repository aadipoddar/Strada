@attribute [Route(PageRouteNames.VehicleRouteMaster)]

@using StradaLibrary.Models.Fleet.VehicleRoute

<PageTitle>Vehicle Route - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Route Management">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
									   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash"
										  Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelectedItem"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelectedItem"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">Vehicle Route Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<AutoCompleteWithAdd TItem="VehicleRouteLocationModel" TValue="VehicleRouteLocationModel"
												 @bind-Value="_selectedFromLocation"
												 DataSource="@_routeLocations"
												 Placeholder="Select From Location"
												 Label="From Location" Required="true"
												 FieldValue="@nameof(VehicleRouteLocationModel.Name)"
												 AddNewRoute="@PageRouteNames.VehicleRouteLocationMaster" />
						</div>

						<div class="form-field">
							<AutoCompleteWithAdd TItem="VehicleRouteLocationModel" TValue="VehicleRouteLocationModel"
												 @bind-Value="_selectedToLocation"
												 DataSource="@_routeLocations"
												 Placeholder="Select To Location"
												 Label="To Location" Required="true"
												 FieldValue="@nameof(VehicleRouteLocationModel.Name)"
												 AddNewRoute="@PageRouteNames.VehicleRouteLocationMaster" />
						</div>

						<div class="form-field">
							<label class="field-label">
								Code <span class="required">*</span>
							</label>
							<SfTextBox @bind-Value="_vehicleRoute.Code" Placeholder="Auto-generated"
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" Readonly="true" />
						</div>

						<div class="form-field">
							<label class="field-label">
								Estimated Hours <span class="required">*</span>
							</label>
							<SfNumericTextBox @bind-Value="_vehicleRoute.EstimatedHours" TValue="int" Min="0"
										  ShowSpinButton="false" Placeholder="Enter estimated hours"
										  FloatLabelType="FloatLabelType.Never" Format="N0"
										  CssClass="custom-numeric" />
						</div>

						<div class="form-field">
							<label class="field-label">
								Estimated Distance <span class="required">*</span>
							</label>
							<SfNumericTextBox @bind-Value="_vehicleRoute.EstimatedDistance" TValue="int" Min="0"
										  ShowSpinButton="false" Placeholder="Enter estimated distance"
										  FloatLabelType="FloatLabelType.Never" Format="N0"
										  CssClass="custom-numeric" />
						</div>

						<div class="form-field">
							<label class="field-label">
								Estimated Fuel Consumption <span class="required">*</span>
							</label>
							<SfNumericTextBox @bind-Value="_vehicleRoute.EstimatedFuelConsumption" TValue="int" Min="0"
										  ShowSpinButton="false" Placeholder="Enter estimated fuel consumption"
										  FloatLabelType="FloatLabelType.Never" Format="N0"
										  CssClass="custom-numeric" />
						</div>

						<div class="form-field">
							<label class="field-label">
								Estimated Cost <span class="required">*</span>
							</label>
							<SfNumericTextBox @bind-Value="_vehicleRoute.EstimatedCost" TValue="decimal" Min="0"
										  ShowSpinButton="false" Placeholder="Enter estimated cost"
										  FloatLabelType="FloatLabelType.Never" Format="N2"
										  CssClass="custom-numeric" />
						</div>

						<div class="form-field">
							<label class="field-label">Remarks</label>
							<SfTextBox @bind-Value="_vehicleRoute.Remarks" Placeholder="Enter remarks (optional)"
									   Multiline="true" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Vehicle Routes List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_vehicleRoutes" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="VehicleRouteModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(VehicleRouteModel.Id)" HeaderText="ID" Width="80"
										TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleRouteModel.FromLocationId)" HeaderText="From Location" Width="250">
								<Template>
									@{
										var item = (context as VehicleRouteModel);
										var fromLocation = _routeLocations.FirstOrDefault(rl => rl.Id == item.FromLocationId);
										<span>@(fromLocation is not null ? fromLocation.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleRouteModel.ToLocationId)" HeaderText="To Location" Width="250">
								<Template>
									@{
										var item = (context as VehicleRouteModel);
										var toLocation = _routeLocations.FirstOrDefault(rl => rl.Id == item.ToLocationId);
										<span>@(toLocation is not null ? toLocation.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleRouteModel.Code)" HeaderText="Code" Width="150" />
							<GridColumn Field="@nameof(VehicleRouteModel.EstimatedHours)" HeaderText="Estimated Hours" Width="160"
										Format="N0" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleRouteModel.EstimatedDistance)" HeaderText="Estimated Distance" Width="170"
										Format="N0" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleRouteModel.EstimatedFuelConsumption)" HeaderText="Estimated Fuel" Width="160"
										Format="N0" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleRouteModel.EstimatedCost)" HeaderText="Estimated Cost" Width="160"
										Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleRouteModel.Remarks)" HeaderText="Remarks" Width="300" />
							<GridColumn Field="@nameof(VehicleRouteModel.Status)" HeaderText="Status" Width="110"
										TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as VehicleRouteModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Vehicle Route" IdentifierLabel="Code"
						  IdentifierValue="@_deleteTransactionName" Disabled="@_isProcessing" OnConfirm="ConfirmDelete"
						  OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Vehicle Route"
					   IdentifierLabel="Code" IdentifierValue="@_recoverTransactionName" Disabled="@_isProcessing"
					   OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />

@using StradaLibrary.Fleet.Vehicle.Models
@using StradaLibrary.Fleet.VehicleDocument.Models

@attribute [Route(PageRouteNames.VehicleDocument)]

<PageTitle>Vehicle Document Management - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyU KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="UploadDocument" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyD KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="DownloadSelectedDocument" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Document Entry">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudMenuItem Label="Upload Document (Ctrl + U)" OnClick="UploadDocument" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
							 stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="16" y1="13" x2="8" y2="13" />
							<line x1="16" y1="17" x2="8" y2="17" />
						</svg>
						<h2 class="section-title">Transaction Summary</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @ref="_sfFirstFocus"
											 @bind-Value="_vehicleDocument.TransactionNo"
											 Label="Transaction No (Ctrl + F)"
											 Placeholder="Enter Transaction Number" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_vehicleDocument.TransactionDateTime" Label="Transaction Date" ShowFinancialYear="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="VehicleDocumentTypeModel"
												Value="_selectedVehicleDocumentType"
												ValueChanged="OnVehicleDocumentTypeChanged"
												DataSource="@_vehicleDocumentTypes"
												Placeholder="Select Document Type"
												Label="Document Type"
												FieldValue="@nameof(VehicleDocumentTypeModel.Name)"
												AddNewRoute="@PageRouteNames.VehicleDocumentTypeMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="VehicleModel"
												@bind-Value="_selectedVehicle"
												DataSource="@_vehicles"
												Placeholder="Select Vehicle"
												Label="Vehicle"
												FieldValue="@nameof(VehicleModel.Code)"
												AddNewRoute="@PageRouteNames.VehicleMaster" />
						</div>

						<div class="form-field">
							<CustomNumericField T="decimal"
												@bind-Value="_vehicleDocument.CurrentKM"
												Label="Current KM"
												Placeholder="0.00"
												Min="0"
												Required="false" />
						</div>

						<div class="form-field">
							<CustomNumericField T="decimal"
												@bind-Value="_vehicleDocument.Rate"
												Label="Rate"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_vehicleDocument.RenewalDate"
											  Label="Renewal Date"
											  ShowFinancialYear="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_vehicleDocument.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Vehicle Document Transactions</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_vehicleDocuments" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="VehicleDocumentModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(VehicleDocumentModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDocumentModel.TransactionNo)" HeaderText="Transaction No" Width="180" />
							<GridColumn Field="@nameof(VehicleDocumentModel.TransactionDateTime)" HeaderText="Transaction Date" Width="150" Format="dd-MMM-yyyy" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDocumentModel.VehicleDocumentTypeId)" HeaderText="Document Type" Width="200">
								<Template>
									@{
										var item = (context as VehicleDocumentModel);
										var documentType = _vehicleDocumentTypes.FirstOrDefault(vdt => vdt.Id == item.VehicleDocumentTypeId);
										<span>@(documentType is not null ? documentType.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleDocumentModel.VehicleId)" HeaderText="Vehicle" Width="150">
								<Template>
									@{
										var item = (context as VehicleDocumentModel);
										var vehicle = _vehicles.FirstOrDefault(v => v.Id == item.VehicleId);
										<span>@(vehicle is not null ? vehicle.Code : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleDocumentModel.CurrentKM)" HeaderText="Current KM" Width="140" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleDocumentModel.Rate)" HeaderText="Rate" Width="140" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleDocumentModel.RenewalDate)" HeaderText="Next Renewal Date" Width="150" Format="dd-MMM-yyyy" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDocumentModel.Remarks)" HeaderText="Remarks" Width="250" />
							<GridColumn Field="@nameof(VehicleDocumentModel.Status)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as VehicleDocumentModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DocumentUploadDialog ExistingDocumentUrl="@_vehicleDocument.DocumentUrl"
					  @bind-IsVisible="_isUploadDialogVisible"
					  OnFileChange="OnUploaderFileChange" OnFileRemove="OnRemoveFile"
					  OnDownloadClick="DownloadExistingDocument" OnRemoveClick="RemoveExistingDocument"
					  OnClose="CloseUploadDialog" />

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />

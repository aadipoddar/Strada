@attribute [Route(PageRouteNames.VehicleDocument)]

@using StradaLibrary.Models.Accounts.Masters
@using StradaLibrary.Models.Fleet.Vehicle
@using StradaLibrary.Models.Fleet.VehicleDocument

<PageTitle>Vehicle Document - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.KeyU KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="UploadDocument" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Document Entry">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
										   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Upload Document (Ctrl + U)" IconCss="e-icons e-upload" Id="UploadDocument"
										  Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash"
										  Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelectedItem"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelectedItem"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
							 stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="16" y1="13" x2="8" y2="13" />
							<line x1="16" y1="17" x2="8" y2="17" />
						</svg>
						<h2 class="section-title">Transaction Summary</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<label class="field-label">
								Transaction No <span class="required">*</span>
							</label>
							<SfTextBox @ref="_sfFirstFocus" @bind-Value="_vehicleDocument.TransactionNo" Placeholder="Enter transaction number (Ctrl + F)"
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_vehicleDocument.TransactionDateTime" Label="Transaction Date" ShowFinancialYear="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="VehicleDocumentTypeModel"
												@bind-Value="_selectedVehicleDocumentType"
												@bind-Value:after="OnVehicleDocumentTypeChanged"
												DataSource="@_vehicleDocumentTypes"
												Placeholder="Select Document Type"
												Label="Document Type"
												FieldValue="@nameof(VehicleDocumentTypeModel.Name)"
												AddNewRoute="@PageRouteNames.VehicleDocumentTypeMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="VehicleModel"
												@bind-Value="_selectedVehicle"
												@bind-Value:after="OnVehicleChanged"
												DataSource="@_vehicles"
												Placeholder="Select Vehicle"
												Label="Vehicle"
												FieldValue="@nameof(VehicleModel.Code)"
												AddNewRoute="@PageRouteNames.VehicleMaster" />
						</div>

						<div class="form-field">
							<label class="field-label">
								Current KM
							</label>
							<SfNumericTextBox @bind-Value="_vehicleDocument.CurrentKM" TValue="decimal" Min="0"
											  ShowSpinButton="false" Placeholder="0.00"
											  FloatLabelType="FloatLabelType.Never" Format="N2"
											  CssClass="custom-numeric editable-field" />
						</div>

						<div class="form-field">
							<label class="field-label">
								Rate <span class="required">*</span>
							</label>
							<SfNumericTextBox @bind-Value="_vehicleDocument.Rate" TValue="decimal" Min="0"
											  ShowSpinButton="false" Placeholder="0.00"
											  FloatLabelType="FloatLabelType.Never" Format="N2"
											  CssClass="custom-numeric editable-field" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_vehicleDocument.RenewalDate" Label="Renewal Date" ShowFinancialYear="false" />
						</div>

						<div class="form-field">
							<label class="field-label">Remarks</label>
							<SfTextBox @bind-Value="_vehicleDocument.Remarks" Placeholder="Enter remarks (optional)"
									   Multiline="true" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Vehicle Document Transactions</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_vehicleDocuments" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="VehicleDocumentModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(VehicleDocumentModel.Id)" HeaderText="ID" Width="80"
										TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDocumentModel.TransactionNo)" HeaderText="Transaction No" Width="180" />
							<GridColumn Field="@nameof(VehicleDocumentModel.TransactionDateTime)" HeaderText="Transaction Date" Width="150"
										Format="dd-MMM-yyyy" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDocumentModel.VehicleDocumentTypeId)" HeaderText="Document Type" Width="200">
								<Template>
									@{
										var item = (context as VehicleDocumentModel);
										var documentType = _vehicleDocumentTypes.FirstOrDefault(vdt => vdt.Id == item.VehicleDocumentTypeId);
										<span>@(documentType is not null ? documentType.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleDocumentModel.VehicleId)" HeaderText="Vehicle" Width="150">
								<Template>
									@{
										var item = (context as VehicleDocumentModel);
										var vehicle = _vehicles.FirstOrDefault(v => v.Id == item.VehicleId);
										<span>@(vehicle is not null ? vehicle.Code : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleDocumentModel.CurrentKM)" HeaderText="Current KM" Width="140"
										Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleDocumentModel.Rate)" HeaderText="Rate" Width="140"
										Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(VehicleDocumentModel.RenewalDate)" HeaderText="Next Renewal Date" Width="150"
										Format="dd-MMM-yyyy" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDocumentModel.Remarks)" HeaderText="Remarks" Width="250" />
							<GridColumn Field="@nameof(VehicleDocumentModel.Status)" HeaderText="Status" Width="110"
										TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var item = (context as VehicleDocumentModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DocumentUploadDialog Title="Upload Original Document"
					  InfoMessage="Document will be uploaded only when you save the transaction."
					  ExistingDocumentUrl="@_vehicleDocument.DocumentUrl"
					  PendingDocumentFileName="@_pendingDocumentFileName"
					  ShowInterpretButton="false" @bind-IsVisible="_isUploadDialogVisible"
					  OnFileChange="OnUploaderFileChange" OnFileRemove="OnRemoveFile"
					  OnDownloadClick="DownloadExistingDocument" OnRemoveClick="MarkDocumentForRemoval"
					  OnClose="CloseUploadDialog" />

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Vehicle Document" IdentifierLabel="Transaction No"
						  IdentifierValue="@_deleteTransactionNo" Disabled="@_isProcessing" OnConfirm="ConfirmDelete"
						  OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Vehicle Document"
						   IdentifierLabel="Transaction No" IdentifierValue="@_recoverTransactionNo" Disabled="@_isProcessing"
						   OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />

@using StradaLibrary.Fleet.Vehicle.Models
@using StradaLibrary.Fleet.VehicleDocument.Models

@attribute [Route(PageRouteNames.VehicleDocumentRenewalReport)]

<PageTitle>Document Renewal Report - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.VehicleDocument, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyD KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="DownloadSelectedDocument" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Document Renewal Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.VehicleDocument, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadTransactionOverviews" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="() => ToggleDetailsView()" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Download Document (Alt + D)" OnClick="DownloadSelectedDocument" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<!-- Vehicle -->
						<div class="form-field">
							<CustomAutoComplete @ref="_firstFocus"
												T="VehicleModel"
												Value="_selectedVehicle"
												DataSource="@_vehicles"
												Placeholder="All Vehicles"
												Label="Vehicle (Ctrl + F)" Required="false"
												OpenOnFocus="false"
												ValueChanged="OnVehicleChanged"
												FieldValue="@nameof(VehicleModel.Code)"
												AddNewRoute="@PageRouteNames.VehicleMaster" />
						</div>

						<!-- Document Type -->
						<div class="form-field">
							<CustomAutoComplete T="VehicleDocumentTypeModel"
												Value="_selectedDocumentType"
												DataSource="@_documentTypes"
												Placeholder="All Document Types"
												Label="Document Type" Required="false"
												ValueChanged="OnDocumentTypeChanged"
												FieldValue="@nameof(VehicleDocumentTypeModel.Name)"
												AddNewRoute="@PageRouteNames.VehicleDocumentTypeMaster" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" TValue="VehicleDocumentRenewalOverviewModel" DataSource="_transactionOverviews"
							AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridEvents TValue="VehicleDocumentRenewalOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.TransactionNo)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Transactions: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Transactions: @aggregate.Count</strong>
											</div>
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Transactions: @aggregate.Count</strong>
											</div>
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.TransactionNo)" HeaderText="Trans No" Width="170" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.TransactionDateTime)" HeaderText="Last Entry" Width="130" Format="dd/MM/yy" Type="ColumnType.DateTime" />

							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.VehicleCode)" HeaderText="Vehicle" Width="140" Visible="@(_showAllColumns || _selectedVehicle is null || _selectedVehicle.Id <= 0)" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.VehicleDocumentTypeName)" HeaderText="Document Type" Width="180" Visible="@(_showAllColumns || _selectedDocumentType is null || _selectedDocumentType.Id <= 0)" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.VehicleDocumentTypeCode)" HeaderText="Code" Width="100" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.RenewalDate)" HeaderText="Renewal Date" Width="140" Format="dd/MM/yy" Type="ColumnType.DateTime">
								<Template>
									@{
										var item = (context as VehicleDocumentRenewalOverviewModel);
										<span class="@(item.DaysRemaining < _warningDays ? "grid-debit" : string.Empty)">@item.RenewalDate.ToString("dd/MM/yy")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.DaysRemaining)" HeaderText="Days Remaining" Width="140" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as VehicleDocumentRenewalOverviewModel);
										<span class="@(item.DaysRemaining < _warningDays ? "grid-debit" : string.Empty)">@item.DaysRemaining</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.CurrentKM)" HeaderText="Current KM" Width="130" TextAlign="TextAlign.Right" Format="N2" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.Rate)" HeaderText="Rate" Width="110" TextAlign="TextAlign.Right" Format="N2" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.Remarks)" HeaderText="Remarks" Width="200" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.CreatedByName)" HeaderText="Created By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.CreatedAt)" HeaderText="Created At" Width="160" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.CreatedFromPlatform)" HeaderText="Created Platform" Width="200" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.LastModifiedByUserName)" HeaderText="Modified By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.LastModifiedAt)" HeaderText="Modified At" Width="160" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleDocumentRenewalOverviewModel.LastModifiedFromPlatform)" HeaderText="Modified Platform" Width="200" Visible="_showAllColumns" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />

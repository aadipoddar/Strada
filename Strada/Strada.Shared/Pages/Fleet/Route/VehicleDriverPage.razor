@attribute [Route(PageRouteNames.VehicleDriverMaster)]

@using Strada.Models.Fleet.Route
@using Strada.Models.Fleet.Vehicle

<PageTitle>Vehicle Driver Management - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Vehicle Driver Management">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete (Del)" OnClick="DeleteSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Master Details</h2>
				</div>

				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete @ref="_firstFocus" T="VehicleModel" @bind-Value="_selectedVehicle" DataSource="@_vehicles" Placeholder="Select Vehicle" Label="Vehicle (Ctrl + F)" FieldValue="@nameof(VehicleModel.Code)"
												AddNewRoute="@PageRouteNames.VehicleMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="DriverModel" @bind-Value="_selectedDriver" DataSource="@_drivers" Placeholder="Select Driver" Label="Driver" FieldValue="@nameof(DriverModel.Name)" AddNewRoute="@PageRouteNames.DriverMaster" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_vehicleDriver.StartDateTime" Label="Start Date" ShowFinancialYear="false" AddNewRoute="@(null)" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_endDateTime" Label="End Date (optional)" Required="false" ShowFinancialYear="false" AddNewRoute="@(null)" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_vehicleDriver.Remarks" Label="Remarks" Placeholder="Enter remarks (optional)" Required="false" Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Master List</h2>
				</div>

				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_vehicleDrivers" AllowPaging="true" AllowSorting="true" AllowResizing="true" AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems" CssClass="professional-grid" Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridEvents TValue="VehicleDriverModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridColumns>
							<GridColumn Field="@nameof(VehicleDriverModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDriverModel.VehicleId)" HeaderText="Vehicle" Width="200">
								<Template>
									@{
										var item = (context as VehicleDriverModel);
										var vehicle = _vehicles.FirstOrDefault(v => v.Id == item.VehicleId);
										<span>@(vehicle is not null ? vehicle.Code : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleDriverModel.DriverId)" HeaderText="Driver" Width="220">
								<Template>
									@{
										var item = (context as VehicleDriverModel);
										var driver = _drivers.FirstOrDefault(d => d.Id == item.DriverId);
										<span>@(driver is not null ? driver.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleDriverModel.StartDateTime)" HeaderText="Start" Width="160" Format="dd-MMM-yy" Type="ColumnType.DateTime" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDriverModel.EndDateTime)" HeaderText="End" Width="160" Format="dd-MMM-yy" Type="ColumnType.DateTime" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(VehicleDriverModel.Remarks)" HeaderText="Remarks" Width="300" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage" OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />

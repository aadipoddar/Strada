@attribute [Route(PageRouteNames.TyreMounting)]

@using StradaLibrary.Fleet.Tyre.Models
@using StradaLibrary.Fleet.Vehicle.Models

<PageTitle>Tyre Mounting - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Tyre Mounting">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete (Del)" OnClick="DeleteSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<circle cx="12" cy="12" r="9" />
							<circle cx="12" cy="12" r="3" />
						</svg>
						<h2 class="section-title">Tyre Mounting Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @ref="_sfFirstFocus"
											 @bind-Value="_tyreMounting.TyreNo"
											 Label="Tyre No (Ctrl + F)"
											 Placeholder="Enter Tyre Number" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="TyreCompanyModel"
												@bind-Value="_selectedTyreCompany"
												DataSource="@_tyreCompanies"
												Placeholder="Select Tyre Company"
												Label="Tyre Company"
												FieldValue="@nameof(TyreCompanyModel.Name)"
												AddNewRoute="@PageRouteNames.TyreCompanyMaster" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_tyreMounting.TyreModel"
											 Label="Tyre Model"
											 Placeholder="Enter Tyre Model (optional)"
											 Required="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="VehicleModel"
												@bind-Value="_selectedVehicle"
												DataSource="_vehicles"
												Placeholder="Select Vehicle"
												Label="Vehicle"
												FieldValue="@nameof(VehicleModel.Code)"
												AddNewRoute="@PageRouteNames.VehicleMaster" />
						</div>

						<div class="form-field">
							<CustomNumericField T="decimal"
												@bind-Value="_tyreMounting.MountingKM"
												Label="Mounting KM"
												Placeholder="Enter mounting KM"
												Format="N2"
												Min="0" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-Value="_tyreMounting.MountingDateTime"
											  Label="Mounting Date"
											  ShowFinancialYear="false"
											  AddNewRoute="@(null)" />
						</div>

						<div class="form-field">
							<CustomNumericField T="decimal?"
												@bind-Value="_tyreMounting.DismountingKM"
												Label="Dismounting KM"
												Placeholder="Enter dismounting KM (optional)"
												Format="N2"
												Min="0"
												Required="false" />
						</div>

						<div class="form-field">
							<CustomDatePicker @bind-NullableValue="_tyreMounting.DismountingDateTime"
											  Label="Dismounting Date"
											  Required="false"
											  ShowFinancialYear="false"
											  AddNewRoute="@(null)" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_tyreMounting.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Tyre Mountings List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_tyreMountings" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="TyreMountingModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(TyreMountingModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(TyreMountingModel.TyreNo)" HeaderText="Tyre No" Width="160" />
							<GridColumn Field="@nameof(TyreMountingModel.TyreCompanyId)" HeaderText="Tyre Company" Width="200">
								<Template>
									@{
										var item = (context as TyreMountingModel);
										var tyreCompany = _tyreCompanies.FirstOrDefault(tc => tc.Id == item.TyreCompanyId);
										<span>@(tyreCompany is not null ? tyreCompany.Name : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(TyreMountingModel.TyreModel)" HeaderText="Tyre Model" Width="160" />
							<GridColumn Field="@nameof(TyreMountingModel.VehicleId)" HeaderText="Vehicle" Width="180">
								<Template>
									@{
										var item = (context as TyreMountingModel);
										var vehicle = _vehicles.FirstOrDefault(v => v.Id == item.VehicleId);
										<span>@(vehicle is not null ? vehicle.Code : "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(TyreMountingModel.MountingKM)" HeaderText="Mounting KM" Width="150" Format="N0" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(TyreMountingModel.DismountingKM)" HeaderText="Dismounting KM" Width="160" Format="N0" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(TyreMountingModel.MountingDateTime)" HeaderText="Mounting Date" Width="150" Format="dd-MMM-yy" Type="ColumnType.DateTime" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(TyreMountingModel.DismountingDateTime)" HeaderText="Dismounting Date" Width="160" Format="dd-MMM-yy" Type="ColumnType.DateTime" TextAlign="TextAlign.Center" />
							<GridColumn HeaderText="Distance Covered" Width="160" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as TyreMountingModel);
										@(item.DismountingKM.HasValue
											? $"{(item.DismountingKM.Value - item.MountingKM):N0} KM"
											: "In Service")
									}
								</Template>
							</GridColumn>
							<GridColumn HeaderText="Days Served" Width="140" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as TyreMountingModel);
										if (item.DismountingDateTime.HasValue)
										{
											var days = (item.DismountingDateTime.Value.Date - item.MountingDateTime.Date).Days;
											@($"{days} {(days == 1 ? "day" : "days")}")
										}
										else
										{
											@("In Service")
										}
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(TyreMountingModel.Remarks)" HeaderText="Remarks" Width="250" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />

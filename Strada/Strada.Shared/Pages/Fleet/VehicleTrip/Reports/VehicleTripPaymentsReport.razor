@attribute [Route(PageRouteNames.VehicleTripPaymentsReport)]

@using StradaLibrary.Models.Accounts.Masters
@using StradaLibrary.Models.Fleet.OMC
@using StradaLibrary.Models.Fleet.Vehicle
@using StradaLibrary.Models.Fleet.VehicleRoute
@using StradaLibrary.Models.Fleet.VehicleTrip

<PageTitle>Trip Payments Report - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft]
					 OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.VehicleTrip, FormFactor, JSRuntime, NavigationManager)" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft]
					 OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.VehicleTripReport, FormFactor, JSRuntime, NavigationManager)" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft]
					 OnHotkeyPressed="LoadTransactionOverviews" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ViewSelectedTransaction" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft]
					 OnHotkeyPressed="ExportSelectedTransactionPdf" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft]
					 OnHotkeyPressed="ExportSelectedTransactionExcel" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Trip Payments Report">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
										   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected"
								OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Refresh Data (Ctrl + R / F5)" IconCss="e-icons e-refresh" Id="Refresh"
										  Disabled="@_isProcessing" />
								<MenuItem Text="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")"
										  IconCss="e-icons e-table" Id="ToggleDetailsView" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Open" IconCss="e-icons e-folder-open">
							<MenuItems>
								<MenuItem Text="Transaction History Report (Ctrl + H)" Id="TransactionHistory"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Expenses Report" Id="ExpensesReport" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Periods" IconCss="e-icons e-clock">
							<MenuItems>
								<MenuItem Text="Today" Id="PeriodToday" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Day" Id="PeriodPreviousDay" Disabled="@_isProcessing" />
								<MenuItem Text="Next Day" Id="PeriodNextDay" Disabled="@_isProcessing" />
								<MenuItem Text="Current Month" Id="PeriodCurrentMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Month" Id="PeriodPreviousMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Next Month" Id="PeriodNextMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Current FY" Id="PeriodCurrentFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Previous FY" Id="PeriodPreviousFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Next FY" Id="PeriodNextFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="All Time" Id="PeriodAllTime" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="View (Alt + O)" IconCss="e-icons e-eye" Id="ViewSelected"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="DownloadSelectedPdf"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel"
										  Id="DownloadSelectedExcel" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Filters Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
						</svg>
						<h2 class="section-title">Filters</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="filters-container">
						<div class="filters-grid">
							<!-- Date Range -->
							<div class="form-field">
								<label class="field-label">Date Range</label>
								<SfDateRangePicker CssClass="custom-daterange" StartDate="_fromDate" EndDate="_toDate"
												   TValue="DateTime" Format="dd/MM/yyyy" AllowEdit="true" Placeholder="Select date range">
									<DateRangePickerEvents TValue="DateTime" ValueChange="OnDateRangeChanged" />
								</SfDateRangePicker>
							</div>

							<!-- Company -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="CompanyModel" TValue="CompanyModel"
													 Value="_selectedCompany"
													 DataSource="@_companies"
													 Placeholder="All Companies"
													 Label="Company" Required="true"
													 ValueChange="OnCompanyChanged"
													 FieldValue="@nameof(CompanyModel.Name)"
													 AddNewRoute="@PageRouteNames.CompanyMaster" />
							</div>

							<!-- OMC -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="OMCModel" TValue="OMCModel"
													 Value="_selectedOMC"
													 DataSource="@_omcs"
													 Placeholder="All OMCs"
													 Label="OMC" Required="true"
													 ValueChange="OnOMCChanged"
													 FieldValue="@nameof(OMCModel.Name)"
													 AddNewRoute="@PageRouteNames.OMCMaster" />
							</div>

							<!-- Vehicle -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="VehicleModel" TValue="VehicleModel"
													 Value="_selectedVehicle"
													 DataSource="@_vehicles"
													 Placeholder="All Vehicles"
													 Label="Vehicle" Required="true"
													 ValueChange="OnVehicleChanged"
													 FieldValue="@nameof(VehicleModel.Code)"
													 AddNewRoute="@PageRouteNames.VehicleMaster" />
							</div>

							<!-- Route -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="VehicleRouteOverviewModel" TValue="VehicleRouteOverviewModel"
													 Value="_selectedRoute"
													 DataSource="@_vehicleRoutes"
													 Placeholder="All Routes"
													 Label="Route" Required="true"
													 ValueChange="OnRouteChanged"
													 FieldValue="@nameof(VehicleRouteOverviewModel.RouteDisplay)"
													 AddNewRoute="@PageRouteNames.VehicleRouteMaster" />
							</div>

							<!-- Driver -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="VehicleDriverOverviewModel" TValue="VehicleDriverOverviewModel"
													 Value="_selectedDriver"
													 DataSource="@_vehicleDrivers"
													 Placeholder="All Drivers"
													 Label="Driver" Required="true"
													 ValueChange="OnDriverChanged"
													 FieldValue="@nameof(VehicleDriverOverviewModel.DisplayName)"
													 AddNewRoute="@PageRouteNames.VehicleDriverMaster" />
							</div>

							<!-- Vehicle Empty -->
							<div class="form-field">
								<label class="field-label">Vehicle Empty</label>
								<SfDropDownList TValue="int" TItem="YesNoFilterOption"
												DataSource="@TripFilterOptions.YesNo" Value="_vehicleEmptyFilter"
												CssClass="custom-textbox" FloatLabelType="FloatLabelType.Never">
									<DropDownListFieldSettings Text="Name" Value="Id" />
									<DropDownListEvents TValue="int" TItem="YesNoFilterOption"
														ValueChange="OnVehicleEmptyFilterChanged" />
								</SfDropDownList>
							</div>

							<!-- Pending Bills -->
							<div class="form-field">
								<label class="field-label">Pending Bills</label>
								<SfDropDownList TValue="int" TItem="YesNoFilterOption"
												DataSource="@TripFilterOptions.YesNo" Value="_pendingBillsFilter"
												CssClass="custom-textbox" FloatLabelType="FloatLabelType.Never">
									<DropDownListFieldSettings Text="Name" Value="Id" />
									<DropDownListEvents TValue="int" TItem="YesNoFilterOption"
														ValueChange="OnPendingBillsFilterChanged" />
								</SfDropDownList>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Report Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<line x1="8" y1="6" x2="21" y2="6" />
							<line x1="8" y1="12" x2="21" y2="12" />
							<line x1="8" y1="18" x2="21" y2="18" />
							<line x1="3" y1="6" x2="3.01" y2="6" />
							<line x1="3" y1="12" x2="3.01" y2="12" />
							<line x1="3" y1="18" x2="3.01" y2="18" />
						</svg>
						<h2 class="section-title">Transactions</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" TValue="VehicleTripCardPaymentsOverviewModel"
							DataSource="_transactionOverviews" AllowTextWrap="true" AllowPaging="true" AllowSorting="true"
							AllowResizing="true" AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true"
							GridLines="GridLine.Horizontal" AllowGrouping="true" CssClass="professional-grid"
							ContextMenuItems="@_gridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="VehicleTripCardPaymentsOverviewModel"
									ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.TransactionNo)"
														 Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Transactions: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Transactions: @aggregate.Count</strong>
											</div>
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Transactions: @aggregate.Count</strong>
											</div>
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.PaymentAmount)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.OMCCardNumber)"
										HeaderText="OMC Card Number" Width="170" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.OMCCardCode)"
										HeaderText="OMC Card Code" Width="130" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.PaymentAmount)"
										HeaderText="Payment Amt" Width="150" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as VehicleTripCardPaymentsOverviewModel);
										<span class="grid-total">@item.PaymentAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.TransactionNo)"
										HeaderText="Trans No" Width="170" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.CompanyName)"
										HeaderText="Company" Width="180"
										Visible="@(_showAllColumns || _selectedCompany is null || _selectedCompany.Id <= 0)" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.TransactionDateTime)"
										HeaderText="Date" Width="150" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.FinancialYear)"
										HeaderText="Financial Year" Width="220" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.ChallanNo)"
										HeaderText="Challan" Width="170" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.OMCName)" HeaderText="OMC"
										Width="100" Visible="@(_showAllColumns || _selectedOMC is null || _selectedOMC.Id <= 0)" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.VehicleCode)"
										HeaderText="Vehicle" Width="130"
										Visible="@(_showAllColumns || _selectedVehicle is null || _selectedVehicle.Id <= 0)" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.FromLocation)"
										HeaderText="From Location" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.ToLocation)"
										HeaderText="To Location" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.RouteDisplay)"
										HeaderText="Route" Width="220"
										Visible="@(_showAllColumns || _selectedRoute is null || _selectedRoute.Id <= 0)" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.DriverName)"
										HeaderText="Driver Name" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.DriverMobile)"
										HeaderText="Driver Mobile" Width="170" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.DriverDisplay)"
										HeaderText="Driver" Width="170"
										Visible="@(_showAllColumns || _selectedDriver is null || _selectedDriver.Id <= 0)" />

							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.Quantity)" HeaderText="Qty"
										Width="100" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.EstimatedDistance)"
										HeaderText="Est. Dist" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns"
										Format="N2" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.EstimatedHours)"
										HeaderText="Est. Hours" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns"
										Format="N2" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.EstimatedFuelConsumption)"
										HeaderText="Est. Fuel" Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns"
										Format="N2" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.EstimatedCost)"
										HeaderText="Est. Cost" Width="130" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.TotalExpense)"
										HeaderText="Total Expense" Width="150" TextAlign="TextAlign.Right" Format="N2" />

							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.VehicleEmpty)" HeaderText="Empty" Width="110" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as VehicleTripCardPaymentsOverviewModel);
										<span class="@(item.VehicleEmpty ? "grid-debit" : string.Empty)">
											@(item.VehicleEmpty ? "Empty" : "Loaded")
										</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.BillNo)" HeaderText="Bill No"
										Width="150" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.GrossAmount)"
										HeaderText="Gross Amt" Width="130" TextAlign="TextAlign.Right" Format="N2"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.TDSAmount)"
										HeaderText="TDS Amt" Width="130" TextAlign="TextAlign.Right" Format="N2"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.PenaltyAmount)"
										HeaderText="Penalty Amt" Width="130" TextAlign="TextAlign.Right" Format="N2"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.NetAmount)"
										HeaderText="Net Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />

							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.Remarks)"
										HeaderText="Remarks" Width="200" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.CreatedByName)"
										HeaderText="Created By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.CreatedAt)"
										HeaderText="Created At" Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.CreatedFromPlatform)"
										HeaderText="Created Platform" Width="300" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.LastModifiedByUserName)"
										HeaderText="Modified By" Width="150" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.LastModifiedAt)"
										HeaderText="Modified At" Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(VehicleTripCardPaymentsOverviewModel.LastModifiedFromPlatform)"
										HeaderText="Modified Platform" Width="300" Visible="_showAllColumns" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />
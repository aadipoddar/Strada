@attribute [Route(PageRouteNames.VehicleTrip)]
@attribute [Route(PageRouteNames.VehicleTrip + "/{Id:int}")]

@using StradaLibrary.Models.Accounts.Masters
@using StradaLibrary.Models.Fleet.OMC
@using StradaLibrary.Models.Fleet.Vehicle
@using StradaLibrary.Models.Fleet.VehicleRoute
@using StradaLibrary.Models.Fleet.VehicleTrip

<PageTitle>Trip - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfExpenseTypeAutoComplete.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfOMCCardAutoComplete.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddExpensesToCart" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportPdfInvoice" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ExportExcelInvoice" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.VehicleTripReport, FormFactor, JSRuntime, NavigationManager)" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedExpensesCartItem" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedExpensesCartItem" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Create Vehicle Trip">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
										   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected"
								OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Save & PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="SavePdfInvoice"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Save & Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="SaveExcelInvoice"
										  Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="ExportPdfInvoice"
										  Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel" Id="ExportExcelInvoice"
										  Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Open" IconCss="e-icons e-folder-open">
							<MenuItems>
								<MenuItem Text="Transaction History Report (Ctrl + H)" Id="TransactionHistory"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Expenses Report" Id="ExpensesReport" Disabled="@_isProcessing" />
								<MenuItem Text="Payments Report" Id="PaymentsReport" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Top Section: Transaction Summary and Financial Summary Side by Side -->
			<div class="two-column-layout">
				<!-- Transaction Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="16" y1="13" x2="8" y2="13" />
								<line x1="16" y1="17" x2="8" y2="17" />
								<polyline points="10 9 9 9 8 9" />
							</svg>
							<h2 class="section-title">Transaction Summary</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="form-grid">
							<!-- Company -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="CompanyModel" TValue="CompanyModel"
												 @bind-Value="_selectedCompany"
												 DataSource="@_companies"
												 Placeholder="Select a Company"
												 Label="Company" Required="true"
												 ValueChange="OnCompanyChanged"
												 FieldValue="@nameof(CompanyModel.Name)"
												 AddNewRoute="@PageRouteNames.CompanyMaster" />
							</div>

							<!-- Transaction Date -->
							<div class="form-field">
								<label class="field-label">
									Transaction Date <span class="required">*</span> / Financial Year
								</label>
								<div class="date-year-wrapper">
									<SfDatePicker @bind-Value="_vehicleTrip.TransactionDateTime" TValue="DateTime"
												  Format="dd/MM/yy" Placeholder="Select Date" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-datepicker">
									</SfDatePicker>
									<SfTextBox
									Value="@($"{_selectedFinancialYear?.StartDate:yyyy} to {_selectedFinancialYear?.EndDate:yyyy}")"
									Readonly="true" Placeholder="Financial Year" FloatLabelType="FloatLabelType.Never"
									CssClass="custom-textbox readonly-field" />
								</div>
							</div>

							<!-- Transaction No -->
							<div class="form-field">
								<label class="field-label">
									Transaction No <span class="required">*</span>
								</label>
								<SfTextBox @bind-Value="_vehicleTrip.TransactionNo" Placeholder="Transaction No"
										   FloatLabelType="FloatLabelType.Never" Readonly="true"
										   CssClass="custom-textbox readonly-field" />
							</div>

							<!-- Challan No -->
							<div class="form-field">
								<label class="field-label">
									Challan No <span class="required">*</span>
								</label>
								<SfTextBox @bind-Value="_vehicleTrip.ChallanNo" Placeholder="Enter Challan No..."
										   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
							</div>

							<!-- OMC -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="OMCModel" TValue="OMCModel"
												 @bind-Value="_selectedOMC"
												 DataSource="@_omcs"
												 Placeholder="Select an OMC"
												 Label="OMC" Required="true"
												 ValueChange="OnOMCChanged"
												 FieldValue="@nameof(OMCModel.Name)"
												 AddNewRoute="@PageRouteNames.OMCMaster" />
							</div>

							<!-- Vehicle -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="VehicleModel" TValue="VehicleModel"
												 @bind-Value="_selectedVehicle"
												 DataSource="@_vehicles"
												 Placeholder="Select a Vehicle"
												 Label="Vehicle" Required="true"
												 ValueChange="OnVehicleChanged"
												 FieldValue="@nameof(VehicleModel.Code)"
												 AddNewRoute="@PageRouteNames.VehicleMaster" />
							</div>

							<!-- Quantity -->
							<div class="form-field">
								<label class="field-label">
									Quantity <span class="required">*</span>
								</label>
								<SfNumericTextBox @bind-Value="_vehicleTrip.Quantity" Placeholder="Enter Quantity"
												  FloatLabelType="FloatLabelType.Never" CssClass="custom-numeric" />
							</div>

							<!-- Route -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="VehicleRouteOverviewModel" TValue="VehicleRouteOverviewModel"
												 @bind-Value="_selectedRoute"
												 DataSource="@_vehicleRoutes"
												 Placeholder="Select a Route"
												 Label="Route" Required="true"
												 ValueChange="OnVehicleRouteChanged"
												 FieldValue="@nameof(VehicleRouteOverviewModel.RouteDisplay)"
												 AddNewRoute="@PageRouteNames.VehicleRouteMaster" />
							</div>

							<!-- Route Estimated Distance / Cost -->
							<div class="form-field">
								<label class="field-label">
									Estimated Distance / Cost
								</label>
								<div class="date-year-wrapper">
									<SfNumericTextBox @bind-Value="_selectedRoute.EstimatedDistance"
													  Placeholder="Enter estimated distance..." FloatLabelType="FloatLabelType.Never"
													  ShowSpinButton="false" Readonly="true" CssClass="custom-numeric readonly-field" />
									<SfNumericTextBox @bind-Value="_selectedRoute.EstimatedCost"
													  Placeholder="Enter estimated cost..." FloatLabelType="FloatLabelType.Never"
													  ShowSpinButton="false" Readonly="true" CssClass="custom-numeric readonly-field" />
								</div>
							</div>

							<!-- Route Estimated Hours / Fuel -->
							<div class="form-field">
								<label class="field-label">
									Estimated Hours / Fuel
								</label>
								<div class="date-year-wrapper">
									<SfNumericTextBox @bind-Value="_selectedRoute.EstimatedHours"
													  Placeholder="Enter estimated hours..." FloatLabelType="FloatLabelType.Never"
													  ShowSpinButton="false" Readonly="true" CssClass="custom-numeric readonly-field" />
									<SfNumericTextBox @bind-Value="_selectedRoute.EstimatedFuelConsumption"
													  Placeholder="Enter estimated fuel..." FloatLabelType="FloatLabelType.Never"
													  ShowSpinButton="false" Readonly="true" CssClass="custom-numeric readonly-field" />
								</div>
							</div>

							<!-- Driver -->
							<div class="form-field">
								<AutoCompleteWithAdd TItem="VehicleDriverOverviewModel" TValue="VehicleDriverOverviewModel"
												 @bind-Value="_selectedDriver"
												 DataSource="@_vehicleDrivers"
												 Placeholder="Select a Driver"
												 Label="Driver" Required="true"
												 ValueChange="OnVehicleDriverChanged"
												 FieldValue="@nameof(VehicleDriverOverviewModel.DisplayName)"
												 AddNewRoute="@PageRouteNames.VehicleDriverMaster" />
							</div>

							<div class="form-field">
								<label class="field-label">Vehicle Empty</label>
								<div class="checkbox-wrapper">
									<SfCheckBox @bind-Checked="_vehicleTrip.VehicleEmpty" Label="Vehicle Empty" CssClass="custom-checkbox" />
								</div>
							</div>

							<!-- Remarks -->
							<div class="form-field">
								<label class="field-label">
									Remarks / Narration
								</label>
								<SfTextBox @bind-Value="_vehicleTrip.Remarks" Multiline="true"
										   Placeholder="Enter remarks..." FloatLabelType="FloatLabelType.Never"
										   CssClass="custom-textbox" />
							</div>
						</div>
					</div>
				</div>

				<!-- Financial Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23" />
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
							</svg>
							<h2 class="section-title">Financial Summary</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="financial-grid">
							<!-- Total Amount -->
							<div class="financial-row">
								<label class="financial-label-total">Total Expense</label>
								<SfNumericTextBox Value="@_vehicleTrip.TotalExpense" Readonly="true" TValue="decimal"
												  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
												  CssClass="custom-numeric total-field" />
							</div>

							<div class="financial-divider"></div>

							<!-- Add Payment to Cart Section -->
							<div class="cart-input-row">
								<!-- OMC Card -->
								<div class="cart-field cart-field-wide">
									<AutoCompleteWithAdd TItem="OMCCardModel" TValue="OMCCardModel"
														 @ref="_sfOMCCardAutoComplete"
														 FieldValue="@nameof(OMCCardModel.CardNumber)" @bind-Value="_selectedOMCCard"
														 DataSource="@_omcCards" Placeholder="Select OMC Card (Ctrl + Shift + F)"
														 ValueChange="OnPaymentsTypeChanged"
														 Label="OMC Card" Required="true" AddNewRoute="@PageRouteNames.OMCCardMaster" />
								</div>

								<!-- Amount -->
								<div class="cart-field cart-field-wide">
									<label class="cart-label">Amount <span class="required">*</span></label>
									<SfNumericTextBox @bind-Value=@_selectedPaymentCart.Amount TValue="decimal" Min="0"
													  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
													  CssClass="custom-numeric editable-field" />
								</div>

								<!-- Remarks -->
								<div class="cart-field cart-field-wide">
									<label class="cart-label">Remarks</label>
									<SfTextBox @bind-Value="_selectedPaymentCart.Remarks" Placeholder="Item Narration..."
											   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
								</div>

								<!-- Add Button -->
								<div class="cart-field cart-field-wide">
									<label class="cart-label">&nbsp;</label>
									<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
												Title="Add to Cart" OnClick="AddPaymentsToCart" />
								</div>
							</div>

							<SfGrid ID="_sfCartGrid" @ref="_sfPaymentsCartGrid" DataSource="_paymentsCart"
									AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true"
									AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
									ContextMenuItems="@_paymentsCartGridContextMenuItems">

								<GridEvents TValue="VehicleTripCardPaymentsCartModel"
											ContextMenuItemClicked="OnPaymentsCartGridContextMenuItemClicked" />
								<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

								<GridAggregates>
									<GridAggregate>
										<GridAggregateColumns>
											<GridAggregateColumn
												Field="@nameof(VehicleTripCardPaymentsCartModel.OMCCardNumber)"
												Type="AggregateType.Count">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
													}
													<div class="aggregate-label">
														<strong>Total Payment Types: @aggregate.Count</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
											<GridAggregateColumn Field="@nameof(VehicleTripCardPaymentsCartModel.Amount)"
																 Type="AggregateType.Sum">
												<FooterTemplate>
													@{
														var aggregate = (context as AggregateTemplateContext);
														var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
													}
													<div class="aggregate-value aggregate-total">
														<strong>@sum.ToString("N2")</strong>
													</div>
												</FooterTemplate>
											</GridAggregateColumn>
										</GridAggregateColumns>
									</GridAggregate>
								</GridAggregates>

								<GridColumns>
									<GridColumn Field="@nameof(VehicleTripCardPaymentsCartModel.OMCCardNumber)"
												HeaderText="Name" Width="200" />
									<GridColumn Field="@nameof(VehicleTripCardPaymentsCartModel.Amount)"
												HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
										<Template>
											@{
												var item = (context as dynamic);
												<span class="grid-total">@item.Amount.ToString("N2")</span>
											}
										</Template>
									</GridColumn>
									<GridColumn Field="@nameof(VehicleTripCardPaymentsCartModel.Remarks)"
												HeaderText="Remarks" Width="150" />
								</GridColumns>

							</SfGrid>

						</div>
					</div>
				</div>

			</div>

			<!-- Add to Cart Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Expenses to Cart</h2>
					</div>
				</div>

				<div class="section-body">
					<div class="cart-input-row">
						<!-- Expense Type -->
						<div class="cart-field cart-field-wide">
							<AutoCompleteWithAdd TItem="VehicleExpenseTypeModel" TValue="VehicleExpenseTypeModel"
														 @ref="_sfExpenseTypeAutoComplete"
														 FieldValue="@nameof(VehicleExpenseTypeModel.Name)" @bind-Value="_selectedExpenseType"
														 DataSource="@_expenseTypes" Placeholder="Select Expense Type (Ctrl + F)"
														 ValueChange="OnExpensesTypeChanged"
														 Label="Expense Type" Required="true" AddNewRoute="@PageRouteNames.VehicleExpenseTypeMaster" />
						</div>

						<!-- Amount -->
						<div class="cart-field">
							<label class="cart-label">Amount <span class="required">*</span></label>
							<SfNumericTextBox @bind-Value=@_selectedExpensesCart.Amount TValue="decimal" Min="0"
											  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
											  CssClass="custom-numeric editable-field" />
						</div>

						<!-- Remarks -->
						<div class="cart-field cart-field-wide">
							<label class="cart-label">Remarks</label>
							<SfTextBox @bind-Value="_selectedExpensesCart.Remarks" Placeholder="Item Narration..."
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>

						<!-- Add Button -->
						<div class="cart-field">
							<label class="cart-label">&nbsp;</label>
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart"
										OnClick="AddExpensesToCart" />
						</div>
					</div>
				</div>

			</div>

			<!-- Expenses Cart Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Expenses Cart</h2>
					</div>
				</div>

				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfExpensesCartGrid" DataSource="_expensesCart" AllowTextWrap="true"
							AllowPaging="false" AllowSorting="true" AllowResizing="true" AllowFiltering="true"
							GridLines="GridLine.Horizontal" CssClass="professional-grid"
							ContextMenuItems="@_expensesCartGridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="VehicleTripExpensesCartModel"
									ContextMenuItemClicked="OnExpensesCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn
										Field="@nameof(VehicleTripExpensesCartModel.VehicleExpenseTypeName)"
										Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Expense Types: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(VehicleTripExpensesCartModel.Amount)"
														 Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(VehicleTripExpensesCartModel.VehicleExpenseTypeName)"
										HeaderText="Name" Width="200" />
							<GridColumn Field="@nameof(VehicleTripExpensesCartModel.Amount)" HeaderText="Amount" Width="130"
										TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Amount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(VehicleTripExpensesCartModel.Remarks)" HeaderText="Remarks"
										Width="150" />
						</GridColumns>

					</SfGrid>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />
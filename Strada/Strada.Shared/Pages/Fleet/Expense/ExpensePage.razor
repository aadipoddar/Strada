@attribute [Route(PageRouteNames.Expense)]
@attribute [Route(PageRouteNames.Expense + "/{Id:int}")]

@using StradaLibrary.Accounts.Masters.Models
@using StradaLibrary.Fleet.Vehicle.Models
@using StradaLibrary.Fleet.Expense.Models

<PageTitle>Expense - Strada</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfExpenseTypeAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddExpensesToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(PageRouteNames.ExpenseReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedExpensesCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedExpensesCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_expense.Id > 0 ? $"Edit Expense {_expense.TransactionNo}" : "Create Expense")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => ResetPage()" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Expense Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.ExpenseReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Expense Details Report" OnClick="() => AuthenticationService.NavigateToRoute(PageRouteNames.ExpenseDetailsReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
			<RightContent>
				<RecheckSaveButton OnClick="() => SaveTransaction()" Disabled="@_isProcessing" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Transaction Summary Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
							 stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="16" y1="13" x2="8" y2="13" />
							<line x1="16" y1="17" x2="8" y2="17" />
							<polyline points="10 9 9 9 8 9" />
						</svg>
						<h2 class="section-title">Transaction Summary</h2>
					</div>
				</div>

				<div class="section-body">
					<div class="form-grid">
						<!-- Vehicle -->
						<div class="form-field">
							<CustomAutoComplete @ref="_sfFirstFocus" T="VehicleModel"
												Value="_selectedVehicle"
												DataSource="@_vehicles"
												Placeholder="Select a Vehicle"
												Label="Vehicle (Ctrl + F)"
												ValueChanged="OnVehicleChanged"
												FieldValue="@nameof(VehicleModel.Code)"
												AddNewRoute="@PageRouteNames.VehicleMaster" />
						</div>

						<!-- Company -->
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="Select a Company (Ctrl + F)"
												Label="Company"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@PageRouteNames.CompanyMaster" />
						</div>

						<!-- Transaction Date -->
						<div class="form-field">
							<CustomDatePicker @bind-Value="_expense.TransactionDateTime"
											  FinancialYear="@_selectedFinancialYear" />
						</div>

						<!-- Transaction No -->
						<div class="form-field">
							<CustomTextField @bind-Value="_expense.TransactionNo"
											 Label="Transaction No"
											 Placeholder="Transaction No"
											 ReadOnly="true"
											 TabIndex="-1" />
						</div>

						<!-- Total Expense -->
						<div class="form-field">
							<CustomNumericField T="decimal"
												Value="@_expense.TotalExpense"
												Label="Total Expense"
												Placeholder="Total Expense"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Remarks -->
						<div class="form-field">
							<CustomTextField @bind-Value="_expense.Remarks"
											 Label="Remarks / Narration"
											 Placeholder="Enter remarks..."
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<!-- Add to Cart Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Expenses to Cart</h2>
					</div>
				</div>

				<div class="section-body">
					<div class="cart-input-row">
						<!-- Expense Type -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="ExpenseTypeModel"
												@ref="_sfExpenseTypeAutoComplete"
												FieldValue="@nameof(ExpenseTypeModel.Name)" Value="_selectedExpenseType"
												DataSource="@_expenseTypes" Placeholder="Select Expense Type"
												ValueChanged="OnExpensesTypeChanged"
												OpenOnFocus="false"
												Label="Expense Type (Ctrl + G)"
												AddNewRoute="@PageRouteNames.ExpenseTypeMaster" />
						</div>

						<!-- Ledger -->
						<div class="cart-field">
							<CustomAutoComplete T="LedgerModel"
												FieldValue="@nameof(LedgerModel.Name)" Value="_selectedLedger"
												DataSource="@_ledgers" Placeholder="Select Ledger"
												ValueChanged="OnLedgerChanged"
												OpenOnFocus="false" Required="false"
												Label="Ledger" AddNewRoute="@PageRouteNames.LedgerMaster" />
						</div>

						<!-- Amount -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												@bind-Value="_selectedExpensesCart.Amount"
												Min="0"
												Label="Amount"
												Placeholder="0.00" />
						</div>

						<!-- Identification -->
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedExpensesCart.IdentificationNo"
											 Label="Identification"
											 Placeholder="Enter identification..."
											 Required="false" />
						</div>

						<!-- Remarks -->
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedExpensesCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<!-- Add Button -->
						<div class="cart-field">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart"
										OnClick="AddExpensesToCart" />
						</div>
					</div>
				</div>

			</div>

			<!-- Expenses Cart Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Expenses Cart</h2>
					</div>
				</div>

				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfExpensesCartGrid" DataSource="_expensesCart" AllowTextWrap="true"
							AllowPaging="false" AllowSorting="true" AllowResizing="true" AllowFiltering="true"
							GridLines="GridLine.Horizontal" CssClass="professional-grid"
							ContextMenuItems="@_expensesCartGridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="ExpenseDetailsCartModel" ContextMenuItemClicked="OnExpensesCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(ExpenseDetailsCartModel.ExpenseTypeName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Expense Types: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(ExpenseDetailsCartModel.Amount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(ExpenseDetailsCartModel.ExpenseTypeName)" HeaderText="Name" Width="200" />
							<GridColumn Field="@nameof(ExpenseDetailsCartModel.LedgerName)" HeaderText="Ledger" Width="200" />
							<GridColumn Field="@nameof(ExpenseDetailsCartModel.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Amount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(ExpenseDetailsCartModel.IdentificationNo)" HeaderText="Identification No" Width="150" />
							<GridColumn Field="@nameof(ExpenseDetailsCartModel.Remarks)" HeaderText="Remarks" Width="150" />
						</GridColumns>

					</SfGrid>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />